@page
@model GescomSaas.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Connexion";
}

<h1>Connexion</h1>

<form id="account" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

    <div class="form-floating mb-3">
        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Utilisateur" />
        <label asp-for="Input.Email">Utilisateur</label>
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>

    <div class="form-floating mb-3" style="position:relative">
        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Mot de passe" id="lc-login-password" style="padding-right:44px" />
        <label asp-for="Input.Password">Mot de passe</label>
        <button type="button" id="lc-login-pwd-toggle" aria-label="Afficher ou masquer le mot de passe"
                style="position:absolute;top:0;right:0;height:56px;width:44px;display:flex;align-items:center;justify-content:center;background:none;border:none;color:var(--text-tertiary);cursor:pointer;z-index:5">
            <svg id="lc-eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg id="lc-eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-10-8-10-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 10 8 10 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
        </button>
        <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" asp-for="Input.RememberMe" />
        <label class="form-check-label" asp-for="Input.RememberMe">Se souvenir ?</label>
    </div>

    <button id="login-submit" type="submit" class="w-100 btn btn-primary">Se connecter</button>

    <p class="mt-3">
        <a id="forgot-password" asp-page="./ForgotPassword">Mot de passe oublié ?</a>
    </p>
</form>

@section Scripts {
    <script>
        (function () {
            var toggle = document.getElementById('lc-login-pwd-toggle');
            var input = document.getElementById('lc-login-password');
            var eyeOpen = document.getElementById('lc-eye-open');
            var eyeClosed = document.getElementById('lc-eye-closed');
            if (toggle && input) {
                toggle.addEventListener('click', function () {
                    var show = input.type === 'password';
                    input.type = show ? 'text' : 'password';
                    if (eyeOpen) eyeOpen.style.display = show ? 'none' : '';
                    if (eyeClosed) eyeClosed.style.display = show ? '' : 'none';
                    input.focus();
                });
            }
        })();
    </script>
}
