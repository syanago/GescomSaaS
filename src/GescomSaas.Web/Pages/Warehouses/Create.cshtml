@page
@model GescomSaas.Web.Pages.Warehouses.CreateModel
@{
    ViewData["Title"] = "Nouveau depot";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Creation</span>
        <h1>Nouveau depot</h1>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/Warehouses/Index">Retour a la liste</a>
    </div>
</section>

<section class="panel-card">
    <form method="post" class="stack-form compact-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div id="warehouse-quota-warning" class="app-alert warning quota-inline-warning" hidden></div>
        <div class="form-grid">
            <div><label asp-for="Input.Code" class="form-label"></label><input asp-for="Input.Code" class="form-control" /><span asp-validation-for="Input.Code" class="text-danger"></span></div>
            <div><label asp-for="Input.Label" class="form-label"></label><input asp-for="Input.Label" class="form-control" /><span asp-validation-for="Input.Label" class="text-danger"></span></div>
        </div>
        <div class="form-check form-switch mb-4">
            <input asp-for="Input.IsDefault" class="form-check-input" />
            <label asp-for="Input.IsDefault" class="form-check-label"></label>
        </div>
        <div class="form-actions">
            <button type="submit" id="warehouse-submit-button" class="btn btn-primary-soft">Enregistrer</button>
            <a class="btn btn-outline-light" asp-page="/Warehouses/Index">Annuler</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const submitButton = document.getElementById('warehouse-submit-button');
            const warning = document.getElementById('warehouse-quota-warning');
            const used = @((Model.WarehouseQuota?.Used ?? 0));
            const limit = @((Model.WarehouseQuota?.Limit ?? 0));
            const blocked = used >= limit;

            submitButton.disabled = blocked;
            warning.hidden = !blocked;
            warning.textContent = blocked
                ? `Creation bloquee avant soumission : quota depots atteint (${used}/${limit}). Passe ce tenant sur un plan superieur dans SaaS Admin > Tenants, ou demande a l'administrateur plateforme de mettre a niveau l'abonnement.`
                : '';
        })();
    </script>
}
