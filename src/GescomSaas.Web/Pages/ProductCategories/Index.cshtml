@page
@model GescomSaas.Web.Pages.ProductCategories.IndexModel
@{
    ViewData["Title"] = "Familles d'articles";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Referentiel</span>
        <h1>Familles d'articles</h1>
        <p class="muted-copy">Structurez le catalogue par famille pour faciliter tarifs, reporting et recherche.</p>
    </div>
    <div class="header-actions">
        <a class="btn btn-primary-soft" asp-page="/ProductCategories/Create">Nouvelle famille</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="app-alert">@Model.StatusMessage</div>
}

<section class="panel-card">
    <div class="table-shell">
        <table class="table table-darkless align-middle app-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Libelle</th>
                    <th>Suivi stock</th>
                    <th>Lot / serie</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Categories.Count == 0)
            {
                <tr><td colspan="5" class="empty-cell">Aucune famille d'articles.</td></tr>
            }
            else
            {
                @foreach (var item in Model.Categories)
                {
                    <tr>
                        <td>@item.Code</td>
                        <td>@item.Label</td>
                        <td>@GetValuationLabel(item.StockValuationMethod)</td>
                        <td>@GetIdentityLabel(item.StockIdentityTrackingMode)</td>
                        <td class="text-end action-cell">
                            <a asp-page="/ProductCategories/Edit" asp-route-id="@item.Id">Modifier</a>
                            <a asp-page="/ProductCategories/Delete" asp-route-id="@item.Id">Supprimer</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@functions {
    private static string GetValuationLabel(GescomSaas.Domain.Enums.StockValuationMethod method) => method switch
    {
        GescomSaas.Domain.Enums.StockValuationMethod.Cmup => "CMUP",
        GescomSaas.Domain.Enums.StockValuationMethod.Fifo => "FIFO",
        GescomSaas.Domain.Enums.StockValuationMethod.LastPurchaseCost => "Dernier prix d'achat",
        _ => method.ToString()
    };

    private static string GetIdentityLabel(GescomSaas.Domain.Enums.StockIdentityTrackingMode mode) => mode switch
    {
        GescomSaas.Domain.Enums.StockIdentityTrackingMode.None => "Aucun",
        GescomSaas.Domain.Enums.StockIdentityTrackingMode.Lot => "Par lot",
        GescomSaas.Domain.Enums.StockIdentityTrackingMode.SerialNumber => "Par numero de serie",
        _ => mode.ToString()
    };
}
