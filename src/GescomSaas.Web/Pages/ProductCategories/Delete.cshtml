@page "{id:guid}"
@model GescomSaas.Web.Pages.ProductCategories.DeleteModel
@{
    ViewData["Title"] = "Supprimer une famille d'articles";
    var canDelete = string.IsNullOrWhiteSpace(Model.BlockingReason);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Supprimer @Model.Category?.Code</h1>
        <div class="page-header-sub">Suppression d'une famille</div>
    </div>
    <div>
        <a class="btn btn-secondary" asp-page="/ProductCategories/Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
    </div>
</div>

@if (!canDelete)
{
    <div class="alert alert-warning mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Suppression bloquee</strong> — @Model.BlockingReason</div>
}
else
{
    <div class="alert alert-danger mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Attention</strong> — la famille <strong>@Model.Category?.Label</strong> sera supprimee.</div>
}

<div class="card">
    <div class="section-header"><i class="bi bi-trash"></i><span>Recapitulatif</span></div>
    <div class="card-body">
        <div class="row g-3 mb-4">
            <div class="col-md-6"><div class="small text-muted">Code</div><div class="fw-semibold">@Model.Category?.Code</div></div>
            <div class="col-md-6"><div class="small text-muted">Libelle</div><div class="fw-semibold">@Model.Category?.Label</div></div>
        </div>
        <form method="post" class="d-flex justify-content-end gap-2">
            <a class="btn btn-secondary" asp-page="/ProductCategories/Index">Annuler</a>
            @if (canDelete)
            {
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Confirmer</button>
            }
        </form>
    </div>
</div>
