@page "{id:guid}"
@model GescomSaas.Web.Pages.ProductCategories.DeleteModel
@{
    ViewData["Title"] = "Supprimer une famille d'articles";
}

<section class="page-header-card">
    <div><span class="eyebrow">Suppression</span><h1>Supprimer @Model.Category?.Code</h1></div>
    <div class="header-actions"><a class="btn btn-outline-light" asp-page="/ProductCategories/Index">Retour a la liste</a></div>
</section>

<section class="panel-card">
    @if (!string.IsNullOrWhiteSpace(Model.BlockingReason))
    {
        <div class="app-alert warning">@Model.BlockingReason</div>
    }
    else
    {
        <p>La famille <strong>@Model.Category?.Label</strong> sera supprimee.</p>
    }
    <dl class="detail-list">
        <div><dt>Code</dt><dd>@Model.Category?.Code</dd></div>
        <div><dt>Libelle</dt><dd>@Model.Category?.Label</dd></div>
    </dl>
    <form method="post" class="form-actions">
        @if (string.IsNullOrWhiteSpace(Model.BlockingReason))
        {
            <button type="submit" class="btn btn-danger-soft">Confirmer la suppression</button>
        }
        <a class="btn btn-outline-light" asp-page="/ProductCategories/Index">Annuler</a>
    </form>
</section>
