@page
@model GescomSaas.Web.Pages.ProductCategories.CreateModel
@{
    ViewData["Title"] = "Nouvelle famille d'articles";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Nouvelle famille d'articles</h1>
        <div class="page-header-sub">Creation d'une famille de catalogue</div>
    </div>
    <div>
        <a class="btn btn-secondary" asp-page="/ProductCategories/Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
    </div>
</div>

<div class="card">
    <div class="section-header"><i class="bi bi-tags"></i><span>Informations famille</span></div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-6"><label asp-for="Input.Code" class="form-label"></label><input asp-for="Input.Code" class="form-control" /><span asp-validation-for="Input.Code" class="text-danger small"></span></div>
                <div class="col-md-6"><label asp-for="Input.Label" class="form-label"></label><input asp-for="Input.Label" class="form-control" /><span asp-validation-for="Input.Label" class="text-danger small"></span></div>
                <div class="col-md-6"><label asp-for="Input.StockValuationMethod" class="form-label"></label><select asp-for="Input.StockValuationMethod" asp-items="Model.StockValuationMethodOptions" class="form-select"></select></div>
                <div class="col-md-6"><label asp-for="Input.StockIdentityTrackingMode" class="form-label"></label><select asp-for="Input.StockIdentityTrackingMode" asp-items="Model.StockIdentityTrackingModeOptions" class="form-select"></select></div>
            </div>
            <div class="d-flex justify-content-end gap-2 mt-3">
                <a class="btn btn-secondary" asp-page="/ProductCategories/Index">Annuler</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Enregistrer</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
