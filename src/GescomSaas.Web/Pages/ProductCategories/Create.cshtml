@page
@model GescomSaas.Web.Pages.ProductCategories.CreateModel
@{
    ViewData["Title"] = "Nouvelle famille d'articles";
}

<section class="page-header-card">
    <div><span class="eyebrow">Creation</span><h1>Nouvelle famille d'articles</h1></div>
    <div class="header-actions"><a class="btn btn-outline-light" asp-page="/ProductCategories/Index">Retour a la liste</a></div>
</section>

<section class="panel-card">
    <form method="post" class="stack-form compact-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <div><label asp-for="Input.Code" class="form-label"></label><input asp-for="Input.Code" class="form-control" /><span asp-validation-for="Input.Code" class="text-danger"></span></div>
            <div><label asp-for="Input.Label" class="form-label"></label><input asp-for="Input.Label" class="form-control" /><span asp-validation-for="Input.Label" class="text-danger"></span></div>
            <div><label asp-for="Input.StockValuationMethod" class="form-label"></label><select asp-for="Input.StockValuationMethod" asp-items="Model.StockValuationMethodOptions" class="form-select"></select></div>
            <div><label asp-for="Input.StockIdentityTrackingMode" class="form-label"></label><select asp-for="Input.StockIdentityTrackingMode" asp-items="Model.StockIdentityTrackingModeOptions" class="form-select"></select></div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary-soft">Enregistrer</button>
            <a class="btn btn-outline-light" asp-page="/ProductCategories/Index">Annuler</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
