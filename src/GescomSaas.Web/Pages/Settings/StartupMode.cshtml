@page
@model GescomSaas.Web.Pages.Settings.StartupModeModel
@{
    ViewData["Title"] = "Mode de demarrage";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Mode d'utilisation par defaut</h1>
        <div class="page-header-sub">Choisissez le mode d'utilisation actif au demarrage de l'application. Ce reglage est applique au prochain lancement de LigCom.</div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-info-circle"></i>
        <span>@Model.StatusMessage</span>
    </div>
}

<div class="card">
    <div class="card-body">
        <p class="text-muted mb-1">
            Mode actuellement charge par cette instance :
            <strong>@(Model.CurrentlyOffline ? "Hors ligne" : "En ligne")</strong>
            (@Model.CurrentDatabaseTarget).
        </p>
        <p class="small text-muted mb-4">
            Dans les deux cas, vous pourrez basculer a chaud entre les modes via le badge de statut et son toggle
            « Travailler hors ligne », en confirmant avec votre mot de passe administrateur.
        </p>

        <form method="post" asp-page-handler="Save">
            <fieldset>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="radio" name="SelectedMode" id="modeOnline" value="online"
                           checked="@(!Model.CurrentlyOffline)" />
                    <label class="form-check-label" for="modeOnline">
                        <strong>En ligne</strong>
                        <span class="d-block small text-muted">
                            Base de donnees <strong>SQL Server</strong> (base centrale). Le badge du navigateur affiche « En ligne ».
                        </span>
                    </label>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input" type="radio" name="SelectedMode" id="modeOffline" value="offline"
                           checked="@Model.CurrentlyOffline" />
                    <label class="form-check-label" for="modeOffline">
                        <strong>Hors ligne</strong>
                        <span class="d-block small text-muted">
                            Base de donnees <strong>SQLite</strong> locale (noeud local). Le badge du navigateur affiche « Hors ligne ».
                        </span>
                    </label>
                </div>
            </fieldset>

            <div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-exclamation-triangle"></i>
                <span>Changer ce reglage modifie la base de donnees connectee. Un redemarrage de LigCom est necessaire pour l'appliquer.</span>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i>Enregistrer le mode de demarrage
            </button>
        </form>
    </div>
</div>
