@page
@model GescomSaas.Web.Pages.Settings.OfflineModel
@{
    ViewData["Title"] = "Synchronisation";
    var baseUrl = $"{ViewContext.HttpContext.Request.Scheme}://{ViewContext.HttpContext.Request.Host}";
    var lastPush = Model.Dashboard?.State.LastPushRequestedOnUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "Jamais";
    var lastPull = Model.Dashboard?.State.LastPullRequestedOnUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "Jamais";
    var connected = Model.IsConnectedMode;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Synchronisation hors connexion</h1>
        <div class="d-flex align-items-center gap-2 flex-wrap mt-1">
            @if (connected)
            {
                <span class="badge" style="background:var(--gc-pill-green-bg,#dcfce7); color:var(--gc-pill-green-fg,#166534)"><i class="bi bi-wifi me-1"></i>Mode en ligne (SQL Server)</span>
            }
            else
            {
                <span class="badge" style="background:#fff7ed; color:#9a3412; border:1px solid #fed7aa"><i class="bi bi-hdd me-1"></i>Mode hors connexion (SQLite)</span>
            }
            <span class="page-header-sub mb-0">Endpoints sync disponibles pour les clients locaux</span>
        </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-secondary" href="#tech-summary"><i class="bi bi-hdd-stack me-1"></i>Apercu des bases</a>
        <a class="btn btn-secondary" href="#local-server"><i class="bi bi-hdd me-1"></i>Etat base locale</a>
    </div>
</div>

<div class="d-flex gap-4 flex-wrap mb-3">
    <span class="small"><i class="bi bi-check-circle-fill text-success me-1"></i><span class="text-muted">Dernier Push :</span> <strong>@lastPush</strong></span>
    <span class="small"><i class="bi bi-check-circle-fill text-success me-1"></i><span class="text-muted">Dernier Pull :</span> <strong>@lastPull</strong></span>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage</div>
}
@if (Model.RestartRequired)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>Un redemarrage de LigCom est necessaire pour appliquer le changement de mode ou de base locale.</div>
}

@if (Model.Dashboard is null)
{
    <div class="alert alert-secondary">Le tableau de bord de la base locale n'est pas disponible.</div>
}
else
{
    <div class="row g-3">
        @* ================= SERVEUR WEB (central) ================= *@
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="section-header">
                    <i class="bi bi-cloud"></i>
                    <span>Serveur Web <span class="text-muted fw-normal">— Instance en ligne (SQL Server)</span></span>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="ActivateLocalNode">
                        <div class="mb-3">
                            <label class="form-label" for="sync-central-url"><i class="bi bi-link-45deg me-1"></i>URL du serveur web</label>
                            <input id="sync-central-url" name="ActivationCentralBaseUrl" class="form-control"
                                   value="@(string.IsNullOrWhiteSpace(Model.CurrentCentralBaseUrl) ? baseUrl : Model.CurrentCentralBaseUrl)"
                                   placeholder="https://votre-serveur (sans slash final)" />
                            <div class="form-text">Adresse de l'instance LigCom hebergee (sans slash final).</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="sync-shared-key"><i class="bi bi-key me-1"></i>Cle API partagee</label>
                            <input id="sync-shared-key" name="ActivationSharedAccessKey" type="password" class="form-control"
                                   value="@Model.ActivationSharedAccessKey" placeholder="Cle configuree — laisser vide pour ne pas modifier" />
                            <div class="form-text text-success">Cle utilisee par les noeuds locaux dans l'en-tete X-LigCom-Offline-Key.</div>
                        </div>
                        <input type="hidden" name="SqliteDatabasePath" value="@Model.SqliteDatabasePath" />
                        <input type="hidden" name="ActivationLocalNodeId" value="@Model.ActivationLocalNodeId" />
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Enregistrer</button>
                    </form>

                    <hr />
                    <div class="small text-muted mb-2"><i class="bi bi-hdd-network me-1"></i>Endpoints disponibles sur ce serveur :</div>
                    <div style="font-family:var(--bs-font-monospace,monospace); font-size:12px; line-height:1.9; color:var(--color-error-700,#b91c1c)">
                        <div><span class="badge bg-secondary">POST</span> @baseUrl/api/offline-sync/v1/products/push</div>
                        <div><span class="badge bg-secondary">POST</span> @baseUrl/api/offline-sync/v1/documents/push</div>
                        <div><span class="badge bg-secondary">POST</span> @baseUrl/api/offline-sync/v1/stock-documents/push</div>
                        <div><span class="badge bg-secondary">POST</span> @baseUrl/api/offline-sync/v1/payments/push</div>
                        <div><span class="badge bg-secondary">GET</span> @baseUrl/api/offline-sync/v1/reference-data/pull</div>
                        <div><span class="badge bg-secondary">GET</span> @baseUrl/api/offline-sync/v1/bootstrap</div>
                    </div>
                </div>
            </div>
        </div>

        @* ================= SERVEUR LOCAL (SQLite) ================= *@
        <div class="col-lg-6" id="local-server">
            <div class="card h-100">
                <div class="section-header">
                    <i class="bi bi-hdd"></i>
                    <span>Serveur Local <span class="text-muted fw-normal">— Instance hors connexion (SQLite)</span></span>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="UpdateSqlitePath">
                        <div class="mb-3">
                            <label class="form-label" for="sync-sqlite-path"><i class="bi bi-folder me-1"></i>Dossier / fichier des bases SQLite</label>
                            <div class="input-group">
                                <input id="sync-sqlite-path" name="SqliteDatabasePath" class="form-control" value="@Model.SqliteDatabasePath" placeholder="Ex: D:\LigCom\Node01\ligcom-node.db" />
                                <button type="submit" class="btn btn-secondary" title="Enregistrer le chemin"><i class="bi bi-save"></i></button>
                            </div>
                            <div class="form-text">Persiste dans ligcom-runtime.overrides.json (prioritaire sur appsettings).</div>
                        </div>
                    </form>

                    <div class="mb-3">
                        <div class="small text-muted mb-1"><i class="bi bi-database me-1"></i>Base du tenant courant</div>
                        @if (Model.Dashboard.NodeMode == "LocalNode")
                        {
                            <span class="badge" style="background:var(--gc-pill-green-bg,#dcfce7); color:var(--gc-pill-green-fg,#166534)"><i class="bi bi-check2 me-1"></i>Presente</span>
                        }
                        else
                        {
                            <span class="badge" style="background:#fee2e2; color:#991b1b"><i class="bi bi-x me-1"></i>Absent</span>
                            <span class="text-muted ms-1">Non encore cree</span>
                        }
                        <div class="small text-muted mt-1" style="font-family:var(--bs-font-monospace,monospace)">@Model.CurrentSqlitePath</div>
                    </div>

                    <div class="mb-2">
                        <div class="small text-muted mb-1"><i class="bi bi-toggle-on me-1"></i>Mode actuel</div>
                        @if (connected)
                        {
                            <span class="badge" style="background:var(--gc-pill-green-bg,#dcfce7); color:var(--gc-pill-green-fg,#166534)"><i class="bi bi-wifi me-1"></i>En ligne — SQL Server actif</span>
                            <a class="btn btn-sm btn-secondary ms-2 disabled" tabindex="-1" aria-disabled="true"><i class="bi bi-hdd me-1"></i>Passer hors ligne</a>
                        }
                        else
                        {
                            <span class="badge" style="background:#fff7ed; color:#9a3412; border:1px solid #fed7aa"><i class="bi bi-hdd me-1"></i>Hors ligne — SQLite actif</span>
                            <form method="post" asp-page-handler="ReturnToConnected" class="d-inline ms-2">
                                <button type="submit" class="btn btn-sm btn-secondary"><i class="bi bi-wifi me-1"></i>Repasser en ligne</button>
                            </form>
                        }
                    </div>

                    @if (connected)
                    {
                        <div class="alert alert-info mb-0 mt-2">
                            <i class="bi bi-info-circle me-1"></i>La base locale n'est pas active sur cette instance. Configurez l'URL et la cle ci-contre, puis utilisez l'assistant d'initialisation avant de passer hors ligne.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ================= INITIALISER / TELECHARGER ================= *@
    <div class="row g-3 mt-0">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="section-header">
                    <i class="bi bi-arrow-repeat"></i>
                    <span>Initialiser / Alimenter la base locale <span class="text-muted fw-normal">— Peupler le SQLite depuis le serveur web</span></span>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-start gap-2 mb-2">
                        <i class="bi bi-cloud-arrow-down fs-4 text-primary"></i>
                        <div>
                            <div class="fw-semibold">Initialiser depuis le serveur</div>
                            <div class="small text-muted">Requiert le mode hors connexion actif</div>
                        </div>
                    </div>
                    <p class="text-muted">Telecharge tout le referentiel depuis le serveur web vers la base SQLite locale : parametres, tiers, articles, depots, taxes, documents de vente/achat, documents de stock et reglements. Parfait pour la premiere initialisation ou un rafraichissement complet.</p>
                    @if (connected)
                    {
                        <div class="alert alert-secondary mb-0"><i class="bi bi-info-circle me-1"></i>Disponible uniquement en mode hors connexion. Passez hors ligne d'abord, ou telechargez le fichier SQLite ci-contre.</div>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="RefreshLocalFromCentral">
                            <button type="submit" class="btn btn-primary" disabled="@(Model.Dashboard.CanPullFromCentral ? null : "disabled")"><i class="bi bi-cloud-arrow-down me-1"></i>Initialiser depuis le serveur</button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100" style="background:#f0fdf4; border-color:#bbf7d0">
                <div class="section-header">
                    <i class="bi bi-download"></i>
                    <span>Telecharger la base SQLite <span class="text-muted fw-normal">— Requiert le mode en ligne (serveur web)</span></span>
                    <span class="badge ms-auto" style="background:var(--gc-pill-green-bg,#dcfce7); color:var(--gc-pill-green-fg,#166534)">Actif</span>
                </div>
                <div class="card-body">
                    <p class="text-muted">Genere un fichier .db SQLite pre-rempli avec toutes les donnees de ce tenant. Deposez-le dans le dossier local sous le nom du tenant, puis passez hors ligne.</p>
                    <button type="button" class="btn btn-success w-100" onclick="alert('Generation du fichier .db : fonctionnalite a venir. En attendant, utilisez « Initialiser depuis le serveur » en mode hors connexion.');"><i class="bi bi-download me-1"></i>Telecharger la base SQLite du tenant</button>
                </div>
            </div>
        </div>
    </div>

    @* ================= HISTORIQUE ================= *@
    <div class="card mt-3">
        <div class="section-header">
            <i class="bi bi-clock-history"></i>
            <span>Historique des synchronisations</span>
            <span class="badge ms-auto" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">@Model.FilteredHistory.Count</span>
        </div>
        <div class="card-body">
            @if (Model.FilteredHistory.Count == 0)
            {
                <div class="text-muted text-center py-3">Aucune synchronisation enregistree pour l'instant.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr class="text-muted small text-uppercase">
                                <th>Date</th>
                                <th>Operation</th>
                                <th>Resultat</th>
                                <th class="text-end">Envoyes</th>
                                <th class="text-end">Recus</th>
                                <th class="text-end">Conflits</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.FilteredHistory)
                            {
                                var isOk = string.Equals(item.Status, "Completed", StringComparison.OrdinalIgnoreCase);
                                <tr>
                                    <td class="small">@item.OccurredOnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td>
                                        @if (string.Equals(item.Direction, "push", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-cloud-arrow-up me-1"></i>Push</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-cloud-arrow-down me-1"></i>Pull</span>
                                        }
                                    </td>
                                    <td>
                                        @if (isOk)
                                        {
                                            <span class="badge" style="background:var(--gc-pill-green-bg,#dcfce7); color:var(--gc-pill-green-fg,#166534)">Reussi</span>
                                        }
                                        else
                                        {
                                            <span class="badge" style="background:#fee2e2; color:#991b1b">@item.Status</span>
                                        }
                                    </td>
                                    <td class="text-end">—</td>
                                    <td class="text-end">—</td>
                                    <td class="text-end">0</td>
                                    <td class="small text-muted">@item.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @* ================= RESUME TECHNIQUE + AVANCE (fonctionnalite conservee) ================= *@
    <div class="card mt-3" id="tech-summary">
        <div class="section-header">
            <i class="bi bi-hdd-network"></i>
            <span>Apercu technique des bases</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3"><div class="small text-muted">Base active</div><div class="fw-semibold">@Model.Dashboard.DatabaseTarget</div></div>
                <div class="col-md-3"><div class="small text-muted">Fournisseur</div><div class="fw-semibold">@Model.Dashboard.DatabaseProvider</div></div>
                <div class="col-md-3"><div class="small text-muted">Serveur central</div><div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Dashboard.CentralBaseUrl) ? "Non renseigne" : Model.Dashboard.CentralBaseUrl)</div></div>
                <div class="col-md-3"><div class="small text-muted">Noeud local</div><div class="fw-semibold">@Model.Dashboard.LocalNodeId</div></div>
            </div>
        </div>
    </div>

    <details class="card mt-3">
        <summary class="section-header" style="cursor:pointer; list-style:none">
            <i class="bi bi-sliders"></i>
            <span>Initialisation avancee du noeud local (assistant, bootstrap rapide)</span>
            <span class="badge ms-auto" style="background:#f3f4f6; color:#6b7280">Avance</span>
        </summary>
        <div class="card-body">
            <p class="text-muted">Pour changer de chemin SQLite, initialiser le tenant local et lancer directement une premiere alimentation depuis le central.</p>
            <a class="btn btn-primary" asp-page="/OfflineBootstrap"><i class="bi bi-magic me-1"></i>Ouvrir l'assistant d'initialisation</a>
            <form method="post" asp-page-handler="BootstrapAndPull" class="mt-3">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="adv-slug">Slug du tenant central</label>
                        <input id="adv-slug" name="BootstrapTenantSlug" value="@Model.BootstrapTenantSlug" class="form-control" placeholder="ex: demo-distribution" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="adv-email">Email admin local</label>
                        <input id="adv-email" name="BootstrapAdminEmail" value="@Model.BootstrapAdminEmail" class="form-control" placeholder="admin@tenant.local" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="adv-first">Prenom</label>
                        <input id="adv-first" name="BootstrapAdminFirstName" value="@Model.BootstrapAdminFirstName" class="form-control" placeholder="Admin" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="adv-last">Nom</label>
                        <input id="adv-last" name="BootstrapAdminLastName" value="@Model.BootstrapAdminLastName" class="form-control" placeholder="LigCom" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="adv-path">Chemin SQLite cible</label>
                        <input id="adv-path" name="SqliteDatabasePath" value="@Model.SqliteDatabasePath" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="adv-pwd">Mot de passe admin local</label>
                        <input id="adv-pwd" name="BootstrapAdminPassword" type="password" value="@Model.BootstrapAdminPassword" class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-secondary"><i class="bi bi-play-fill me-1"></i>Initialiser puis alimenter automatiquement</button>
                    </div>
                </div>
            </form>
        </div>
    </details>
}
