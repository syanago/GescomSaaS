@page
@model GescomSaas.Web.Pages.Settings.OfflineModel
@{
    ViewData["Title"] = "Base locale et synchronisation";
}

@if (Model.Dashboard is null)
{
    <div class="page-header">
        <div>
            <h1 class="page-header-title">Base locale et synchronisation</h1>
            <div class="page-header-sub">Le tableau de bord de la base locale n'est pas disponible.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-secondary" asp-page="/Settings/Index"><i class="bi bi-arrow-left me-1"></i>Retour parametres</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage</div>
    }
}
else
{
    var runtimeLabel = Model.Dashboard.NodeMode switch
    {
        "LocalNodePending" => "Base locale en preparation",
        "LocalNode" => "Base locale active",
        _ => "Mode connecte"
    };

    var modeSummary = Model.Dashboard.NodeMode switch
    {
        "LocalNodePending" => "La base locale est activee, mais elle n'est pas encore initialisee.",
        "LocalNode" => "LigCom utilise la base locale SQLite pour les traitements autorises localement et synchronise manuellement avec le serveur central.",
        _ => "LigCom fonctionne sur le serveur connecte principal. Aucun noeud local n'est actif sur cette instance."
    };

    var readinessLabel = Model.Dashboard.NodeMode == "LocalNode"
        ? "Pret"
        : Model.Dashboard.NodeMode == "LocalNodePending"
            ? "Initialisation requise"
            : "Mode connecte";

    <div class="page-header">
        <div>
            <h1 class="page-header-title">Base locale et synchronisation</h1>
            <div class="page-header-sub">Active la base SQLite locale pour les traitements autorises, synchronise manuellement avec le central et reviens facilement au mode connecte.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if (!Model.IsConnectedMode)
            {
                <form method="post" asp-page-handler="ReturnToConnected" class="d-inline">
                    <button type="submit" class="btn btn-secondary"><i class="bi bi-arrow-left-right me-1"></i>Revenir en mode connecte</button>
                </form>
            }
            <a class="btn btn-secondary" asp-page="/Settings/Index"><i class="bi bi-arrow-left me-1"></i>Retour parametres</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success"><i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage</div>
    }

    @if (Model.RestartRequired)
    {
        <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>Un redemarrage de LigCom est necessaire pour appliquer le changement de mode ou de base locale.</div>
    }

    <div class="card mb-3">
        <div class="section-header">
            <i class="bi bi-arrow-left-right"></i>
            <span>Etat actuel</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-lg-7">
                    <h2 class="h4">@runtimeLabel</h2>
                    <p class="text-muted">@modeSummary</p>
                    <div class="row g-3">
                        <div class="col-md-12"><div class="small text-muted">Serveur central</div><div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.CurrentCentralBaseUrl) ? "Non renseigne" : Model.CurrentCentralBaseUrl)</div></div>
                        <div class="col-md-6"><div class="small text-muted">Noeud local</div><div class="fw-semibold">@Model.CurrentLocalNodeId</div></div>
                        <div class="col-md-6"><div class="small text-muted">Base locale</div><div class="fw-semibold">@Model.CurrentSqlitePath</div></div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="row g-2">
                        <div class="col-12">
                            <div class="stat-card">
                                <div class="stat-card-icon stat-icon-blue"><i class="bi bi-hdd-network"></i></div>
                                <div class="stat-card-body">
                                    <div class="stat-card-label">Mode</div>
                                    <div class="stat-card-value">@runtimeLabel</div>
                                    <div class="form-text mb-0">@Model.Dashboard.DatabaseProvider</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="stat-card">
                                <div class="stat-card-icon stat-icon-blue"><i class="bi bi-check2-circle"></i></div>
                                <div class="stat-card-body">
                                    <div class="stat-card-label">Etat</div>
                                    <div class="stat-card-value">@readinessLabel</div>
                                    <div class="form-text mb-0">Synchronisation manuelle @(Model.Dashboard.IsManualTriggerRequired ? "active" : "non requise")</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="stat-card">
                                <div class="stat-card-icon stat-icon-blue"><i class="bi bi-arrow-down-up"></i></div>
                                <div class="stat-card-body">
                                    <div class="stat-card-label">Dernier moteur</div>
                                    <div class="stat-card-value">@Model.Dashboard.State.LastPullStatus</div>
                                    <div class="form-text mb-0">@Model.Dashboard.State.LastMessage</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="mode-switch-panel" class="card mb-3">
        <div class="section-header">
            <i class="bi bi-arrow-left-right"></i>
            <span>Changer de mode rapidement</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card h-100" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                        <div class="card-body">
                            <div class="small text-muted">Mode actuel</div>
                            <h6 class="mt-1">@(Model.IsConnectedMode ? "Mode connecte" : "Base locale active")</h6>
                            <p class="text-muted mb-0">
                                @(Model.IsConnectedMode
                                    ? "LigCom utilise actuellement le serveur central. Pour passer en base locale, il faut d'abord configurer puis initialiser SQLite."
                                    : "LigCom utilise actuellement la base locale SQLite pour les traitements autorises localement.")
                            </p>
                        </div>
                    </div>
                </div>

                @if (Model.IsConnectedMode)
                {
                    <div class="col-md-6">
                        <div class="card h-100" style="background:#fff7ed; border-color:#fed7aa">
                            <div class="card-body">
                                <div class="small text-muted">Action</div>
                                <h6 class="mt-1">Configurer la base locale</h6>
                                <p class="text-muted">Le passage en base locale se fait ici en deux etapes : configurer SQLite, puis initialiser la base locale.</p>
                                <a class="btn btn-primary" href="#activation-panel"><i class="bi bi-gear me-1"></i>Configurer la base locale</a>
                            </div>
                        </div>
                    </div>
                }
                else if (Model.Dashboard.NodeMode == "LocalNodePending")
                {
                    <div class="col-md-6">
                        <div class="card h-100" style="background:#fff7ed; border-color:#fed7aa">
                            <div class="card-body">
                                <div class="small text-muted">Action</div>
                                <h6 class="mt-1">Terminer l'initialisation</h6>
                                <p class="text-muted">La base locale est activee mais pas encore exploitable. Il faut maintenant la peupler et creer l'administrateur local.</p>
                                <a class="btn btn-primary" asp-page="/OfflineBootstrap"><i class="bi bi-play-fill me-1"></i>Initialiser la base locale</a>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="col-md-6">
                        <div class="card h-100" style="background:#fff7ed; border-color:#fed7aa">
                            <div class="card-body">
                                <div class="small text-muted">Action</div>
                                <h6 class="mt-1">Passer en mode connecte</h6>
                                <p class="text-muted">Desactive la base locale sur cette instance. Apres redemarrage, LigCom repassera sur SQL Server connecte.</p>
                                <form method="post" asp-page-handler="ReturnToConnected" class="d-inline">
                                    <button type="submit" class="btn btn-secondary"><i class="bi bi-arrow-left-right me-1"></i>Passer en mode connecte</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="section-header">
            <i class="bi bi-info-circle"></i>
            <span>Ce que couvre la base locale</span>
        </div>
        <div class="card-body">
            <div class="alert alert-warning mb-0">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                La base locale sert uniquement aux traitements d'exploitation autorises en local.
                Les referentiels, le parametrage, les imports, la saisie d'inventaire et la gestion des utilisateurs restent administres sur le serveur central.
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="section-header">
            <i class="bi bi-list-ol"></i>
            <span>Que veux-tu faire ?</span>
        </div>
        <div class="card-body">
            @if (Model.IsConnectedMode)
            {
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card h-100" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                            <div class="card-body">
                                <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">1</span>
                                <div class="fw-semibold mt-2">Activer le noeud local</div>
                                <p class="text-muted mb-0">Choisis le fichier SQLite local, l'URL du central et la cle partagee. Cette etape prepare la base locale qui servira uniquement aux traitements autorises en local.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <span class="badge" style="background:#f3f4f6; color:#6b7280">2</span>
                                <div class="fw-semibold mt-2">Initialiser la base locale</div>
                                <p class="text-muted mb-0">Une fois la base locale activee, ouvre l'assistant pour preparer l'environnement local et creer l'administrateur de secours.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <span class="badge" style="background:#f3f4f6; color:#6b7280">3</span>
                                <div class="fw-semibold mt-2">Synchroniser ensuite manuellement</div>
                                <p class="text-muted mb-0">Quand la base locale est prete, tu peux recharger les donnees autorisees localement ou envoyer les traitements saisis vers le central.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="activation-panel" class="card mt-3" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                    <div class="card-body">
                        <h6 class="mb-1"><i class="bi bi-gear me-1"></i>Activer la base locale sur cette instance</h6>
                        <p class="text-muted">Cette action ne copie pas tout le tenant. Elle prepare seulement la base SQLite d'exploitation locale.</p>
                        <form method="post" asp-page-handler="ActivateLocalNode">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label" for="activation-sqlite-path">Chemin de la base SQLite locale</label>
                                    <input id="activation-sqlite-path" name="SqliteDatabasePath" value="@Model.SqliteDatabasePath" class="form-control" placeholder="Ex: D:\LigCom\Node01\ligcom-node.db" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="activation-central-url">URL du serveur central</label>
                                    <input id="activation-central-url" name="ActivationCentralBaseUrl" value="@Model.ActivationCentralBaseUrl" class="form-control" placeholder="https://votre-serveur-central" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="activation-shared-key">Cle partagee</label>
                                    <input id="activation-shared-key" name="ActivationSharedAccessKey" value="@Model.ActivationSharedAccessKey" class="form-control" placeholder="Cle OfflineSync partagee" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="activation-node-id">Identifiant du noeud local</label>
                                    <input id="activation-node-id" name="ActivationLocalNodeId" value="@Model.ActivationLocalNodeId" class="form-control" placeholder="Ex: SITE-ABIDJAN-01" />
                                </div>
                                <div class="col-12">
                                    <div class="d-flex flex-wrap gap-2 align-items-center">
                                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Activer la base locale SQLite</button>
                                        <a class="btn btn-secondary" asp-page="/OfflineBootstrap"><i class="bi bi-magic me-1"></i>Ouvrir l'assistant d'initialisation</a>
                                        <span class="badge" style="background:#f3f4f6; color:#6b7280">Un redemarrage sera demande</span>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else if (Model.Dashboard.NodeMode == "LocalNodePending")
            {
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <span class="badge" style="background:var(--gc-pill-green-bg); color:var(--gc-pill-green-fg)">1</span>
                                <div class="fw-semibold mt-2">Base locale activee</div>
                                <p class="text-muted mb-0">Cette instance est deja configuree en LocalNode SQLite.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                            <div class="card-body">
                                <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">2</span>
                                <div class="fw-semibold mt-2">Initialiser maintenant la base locale</div>
                                <p class="text-muted mb-0">Il faut encore copier le tenant central et creer l'administrateur local de secours.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <span class="badge" style="background:#f3f4f6; color:#6b7280">3</span>
                                <div class="fw-semibold mt-2">Synchroniser ensuite</div>
                                <p class="text-muted mb-0">Apres initialisation, tu pourras recharger les donnees locales autorisees ou envoyer les ecritures vers le central.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a class="btn btn-primary" asp-page="/OfflineBootstrap"><i class="bi bi-play-fill me-1"></i>Initialiser la base SQLite locale</a>
                    <form method="post" asp-page-handler="ReturnToConnected" class="d-inline">
                        <button type="submit" class="btn btn-secondary"><i class="bi bi-x-lg me-1"></i>Annuler et revenir en mode connecte</button>
                    </form>
                </div>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="small text-muted">Synchronisation</div>
                                <h6 class="mt-1">Mettre a niveau le local</h6>
                                <p class="text-muted">Recharge dans SQLite les donnees utiles au fonctionnement local sans repartir de zero.</p>
                                <form method="post" asp-page-handler="Pull" class="d-inline">
                                    <button type="submit" class="btn btn-secondary" disabled="@(Model.Dashboard.CanPullFromCentral ? null : "disabled")"><i class="bi bi-cloud-arrow-down me-1"></i>Mettre a niveau</button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="small text-muted">Rechargement complet</div>
                                <h6 class="mt-1">Recharger la base locale d'exploitation</h6>
                                <p class="text-muted">Vide les donnees synchronisables du local puis recharge les donnees autorisees depuis le central. Les parametrages, imports, utilisateurs et saisies d'inventaire restent geres sur le serveur.</p>
                                <form method="post" asp-page-handler="RefreshLocalFromCentral" class="d-inline">
                                    <button type="submit" class="btn btn-primary" disabled="@(Model.Dashboard.CanPullFromCentral ? null : "disabled")"><i class="bi bi-arrow-counterclockwise me-1"></i>Recharger completement</button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="small text-muted">Remontee</div>
                                <h6 class="mt-1">Envoyer vers le web</h6>
                                <p class="text-muted">Envoie vers le central les articles, documents, reglements et acomptes saisis localement.</p>
                                <form method="post" asp-page-handler="Push" class="d-inline">
                                    <button type="submit" class="btn btn-secondary" disabled="@(Model.Dashboard.CanPushToCentral ? null : "disabled")"><i class="bi bi-cloud-arrow-up me-1"></i>Envoyer</button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card h-100" style="background:#fff7ed; border-color:#fed7aa">
                            <div class="card-body">
                                <div class="small text-muted">Mode</div>
                                <h6 class="mt-1">Revenir en mode connecte</h6>
                                <p class="text-muted">Desactive le noeud local sur cette instance. Apres redemarrage, LigCom repartira sur SQL Server connecte.</p>
                                <form method="post" asp-page-handler="ReturnToConnected" class="d-inline">
                                    <button type="submit" class="btn btn-secondary"><i class="bi bi-arrow-left-right me-1"></i>Revenir en mode connecte</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="section-header">
                    <i class="bi bi-hdd-network"></i>
                    <span>Resume technique</span>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div class="fw-semibold">Base active</div>
                                <div class="small text-muted">@Model.Dashboard.DatabaseTarget</div>
                            </div>
                            <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">@Model.Dashboard.DatabaseProvider</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div class="fw-semibold">Serveur central</div>
                                <div class="small text-muted">@(string.IsNullOrWhiteSpace(Model.Dashboard.CentralBaseUrl) ? "Non renseigne" : Model.Dashboard.CentralBaseUrl)</div>
                            </div>
                            <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">Noeud: @Model.Dashboard.LocalNodeId</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div class="fw-semibold">Derniere synchro descendante</div>
                                <div class="small text-muted">@(Model.Dashboard.State.LastPullRequestedOnUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "Jamais")</div>
                            </div>
                            <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">@Model.Dashboard.State.LastPullStatus</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div class="fw-semibold">Derniere synchro montante</div>
                                <div class="small text-muted">@(Model.Dashboard.State.LastPushRequestedOnUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "Jamais")</div>
                            </div>
                            <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">@Model.Dashboard.State.LastPushStatus</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100">
                <div class="section-header">
                    <i class="bi bi-list-check"></i>
                    <span>Actions stockees localement</span>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-3">
                        @foreach (var capability in Model.Dashboard.LocalCapabilities)
                        {
                            <li class="d-flex align-items-start gap-2 mb-1"><i class="bi bi-check2 text-success"></i><span>@capability</span></li>
                        }
                    </ul>
                    <div class="section-header mt-3">
                        <i class="bi bi-cloud"></i>
                        <span>Actions reservees au serveur central</span>
                    </div>
                    <ul class="list-unstyled mb-2 mt-2">
                        @foreach (var capability in Model.Dashboard.CentralOnlyCapabilities)
                        {
                            <li class="d-flex align-items-start gap-2 mb-1"><i class="bi bi-cloud-check text-primary"></i><span>@capability</span></li>
                        }
                    </ul>
                    <p class="text-muted mb-0 small">Les referentiels necessaires au fonctionnement local peuvent etre recopies depuis le central en lecture seule, mais ils restent administres cote serveur.</p>
                </div>
            </div>
        </div>
    </div>

    <details class="card mt-3">
        <summary class="section-header" style="cursor:pointer; list-style:none">
            <i class="bi bi-sliders"></i>
            <span>Chemin SQLite, bootstrap rapide et maintenance</span>
            <span class="badge ms-auto" style="background:#f3f4f6; color:#6b7280">Avance</span>
        </summary>
        <div class="card-body">
            <div class="card mb-3" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                <div class="card-body">
                    <h6 class="mb-1"><i class="bi bi-folder me-1"></i>Modifier l'emplacement de la base locale</h6>
                    <p class="text-muted">Utilise ceci seulement si tu veux deplacer le fichier SQLite du noeud local.</p>
                    <form method="post" asp-page-handler="UpdateSqlitePath">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label" for="offline-sqlite-path">Chemin de la base SQLite</label>
                                <input id="offline-sqlite-path" name="SqliteDatabasePath" value="@Model.SqliteDatabasePath" class="form-control" placeholder="Ex: D:\LigCom\Node01\ligcom-node.db" />
                                <div class="small text-muted mt-1">Chemin actuellement charge : @Model.CurrentSqlitePath</div>
                            </div>
                            <div class="col-12">
                                <div class="d-flex flex-wrap gap-2">
                                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Enregistrer le nouvel emplacement</button>
                                    <a class="btn btn-secondary" asp-page="/OfflineBootstrap"><i class="bi bi-magic me-1"></i>Assistant d'initialisation</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                <div class="card-body">
                    <h6 class="mb-1"><i class="bi bi-rocket me-1"></i>Initialisation rapide</h6>
                    <p class="text-muted">Pour changer de chemin, initialiser le tenant local et lancer directement une premiere alimentation.</p>
                    <form method="post" asp-page-handler="BootstrapAndPull">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label" for="offline-bootstrap-path">Chemin SQLite cible</label>
                                <input id="offline-bootstrap-path" name="SqliteDatabasePath" value="@Model.SqliteDatabasePath" class="form-control" placeholder="Ex: D:\LigCom\Node01\ligcom-node.db" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="offline-bootstrap-slug">Slug du tenant central</label>
                                <input id="offline-bootstrap-slug" name="BootstrapTenantSlug" value="@Model.BootstrapTenantSlug" class="form-control" placeholder="ex: demo-distribution" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="offline-bootstrap-email">Email admin local</label>
                                <input id="offline-bootstrap-email" name="BootstrapAdminEmail" value="@Model.BootstrapAdminEmail" class="form-control" placeholder="admin@tenant.local" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="offline-bootstrap-firstname">Prenom</label>
                                <input id="offline-bootstrap-firstname" name="BootstrapAdminFirstName" value="@Model.BootstrapAdminFirstName" class="form-control" placeholder="Admin" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="offline-bootstrap-lastname">Nom</label>
                                <input id="offline-bootstrap-lastname" name="BootstrapAdminLastName" value="@Model.BootstrapAdminLastName" class="form-control" placeholder="LigCom" />
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="offline-bootstrap-password">Mot de passe admin local</label>
                                <input id="offline-bootstrap-password" name="BootstrapAdminPassword" type="password" value="@Model.BootstrapAdminPassword" class="form-control" placeholder="Mot de passe de secours du noeud local" />
                            </div>
                            <div class="col-12">
                                <div class="d-flex flex-wrap gap-2 align-items-center">
                                    <button type="submit" class="btn btn-primary"><i class="bi bi-play-fill me-1"></i>Initialiser puis alimenter automatiquement</button>
                                    <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">Tenant + admin local + synchro descendante</span>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </details>

    <details class="card mt-3">
        <summary class="section-header" style="cursor:pointer; list-style:none">
            <i class="bi bi-clock-history"></i>
            <span>Historique, conflits et filtres</span>
            <span class="badge ms-auto" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">@Model.FilteredHistory.Count execution(s)</span>
        </summary>
        <div class="card-body">
            <div class="card mb-3" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                <div class="card-body">
                    <h6 class="mb-1"><i class="bi bi-funnel me-1"></i>Filtres</h6>
                    <p class="text-muted">Affiche seulement les echanges ou conflits qui t'interessent.</p>
                    <form method="get">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="offline-search">Recherche</label>
                                <input id="offline-search" name="search" value="@Model.Search" class="form-control" placeholder="Module, message, utilisateur..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="offline-direction">Sens</label>
                                <select id="offline-direction" name="direction" class="form-select">
                                    <option value="all" selected="@(Model.Direction.Equals("all", StringComparison.OrdinalIgnoreCase))">Tous</option>
                                    <option value="push" selected="@(Model.Direction.Equals("push", StringComparison.OrdinalIgnoreCase))">Local vers web</option>
                                    <option value="pull" selected="@(Model.Direction.Equals("pull", StringComparison.OrdinalIgnoreCase))">Web vers local</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="offline-module">Module</label>
                                <select id="offline-module" name="module" class="form-select">
                                    <option value="all" selected="@(Model.Module.Equals("all", StringComparison.OrdinalIgnoreCase))">Tous</option>
                                    @foreach (var module in Model.AvailableModules)
                                    {
                                        <option value="@module" selected="@(Model.Module.Equals(module, StringComparison.OrdinalIgnoreCase))">@module</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="offline-conflict-status">Conflits</label>
                                <select id="offline-conflict-status" name="conflictStatus" class="form-select">
                                    <option value="open" selected="@(Model.ConflictStatus.Equals("open", StringComparison.OrdinalIgnoreCase))">Ouverts</option>
                                    <option value="all" selected="@(Model.ConflictStatus.Equals("all", StringComparison.OrdinalIgnoreCase))">Tous</option>
                                    <option value="resolved" selected="@(Model.ConflictStatus.Equals("resolved", StringComparison.OrdinalIgnoreCase))">Resolus</option>
                                    <option value="ignored" selected="@(Model.ConflictStatus.Equals("ignored", StringComparison.OrdinalIgnoreCase))">Ignores</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <div class="d-flex flex-wrap gap-2">
                                    <button type="submit" class="btn btn-primary"><i class="bi bi-funnel me-1"></i>Appliquer les filtres</button>
                                    <a class="btn btn-secondary" asp-page="/Settings/Offline"><i class="bi bi-arrow-counterclockwise me-1"></i>Reinitialiser</a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mb-3">
                <div class="section-header">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>Conflits ouverts</span>
                </div>
                <div class="card-body">
                    @{
                        var openConflicts = Model.FilteredConflicts
                            .Where(x => x.Status.Equals("Open", StringComparison.OrdinalIgnoreCase))
                            .ToArray();
                    }
                    @if (openConflicts.Length == 0)
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox empty-icon"></i>
                            <p class="mb-0">Aucun conflit ouvert ne correspond aux filtres courants.</p>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var conflict in openConflicts)
                            {
                                <div class="card" style="background:#fff7ed; border-color:#fed7aa">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                            <div>
                                                <div class="fw-semibold">@conflict.ModuleName</div>
                                                <div class="small text-muted">@(conflict.Direction.Equals("push", StringComparison.OrdinalIgnoreCase) ? "Local vers web" : "Web vers local") - @conflict.OccurredOnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</div>
                                                <div class="small text-muted">@conflict.Summary</div>
                                            </div>
                                            <div class="d-flex flex-wrap gap-1">
                                                <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">@conflict.Status</span>
                                                <span class="badge" style="@(conflict.Severity.Equals("High", StringComparison.OrdinalIgnoreCase) ? "background:#fef3c7; color:#b45309" : "background:var(--gc-brand-100); color:var(--gc-brand-hover)")">@conflict.Severity</span>
                                            </div>
                                        </div>
                                        @if (conflict.Notes.Count > 0)
                                        {
                                            <div class="alert alert-warning mt-2 mb-2"><i class="bi bi-exclamation-triangle-fill me-2"></i>@string.Join(" | ", conflict.Notes)</div>
                                        }
                                        <div class="d-flex flex-wrap gap-2 mt-2">
                                            <form method="post" asp-page-handler="ResolveConflict" class="d-flex flex-wrap gap-2 align-items-center">
                                                <input type="hidden" name="conflictId" value="@conflict.Id" />
                                                <input type="hidden" name="search" value="@Model.Search" />
                                                <input type="hidden" name="direction" value="@Model.Direction" />
                                                <input type="hidden" name="module" value="@Model.Module" />
                                                <input type="hidden" name="conflictStatus" value="@Model.ConflictStatus" />
                                                <input type="text" name="resolutionNote" class="form-control" placeholder="Note de resolution optionnelle" style="min-width:240px" />
                                                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Marquer resolu</button>
                                            </form>
                                            <form method="post" asp-page-handler="IgnoreConflict" class="d-inline">
                                                <input type="hidden" name="conflictId" value="@conflict.Id" />
                                                <input type="hidden" name="search" value="@Model.Search" />
                                                <input type="hidden" name="direction" value="@Model.Direction" />
                                                <input type="hidden" name="module" value="@Model.Module" />
                                                <input type="hidden" name="conflictStatus" value="@Model.ConflictStatus" />
                                                <input type="hidden" name="resolutionNote" value="Conflit ignore manuellement depuis la page Base locale et synchronisation." />
                                                <button type="submit" class="btn btn-secondary"><i class="bi bi-x-lg me-1"></i>Ignorer</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="card mb-3">
                <div class="section-header">
                    <i class="bi bi-journal-text"></i>
                    <span>Historique des synchronisations</span>
                </div>
                <div class="card-body">
                    @if (Model.FilteredHistory.Count == 0)
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox empty-icon"></i>
                            <p class="mb-0">Aucune execution de synchronisation ne correspond aux filtres courants.</p>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var run in Model.FilteredHistory)
                            {
                                <div class="card" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                            <div>
                                                <div class="fw-semibold">@(run.Direction.Equals("push", StringComparison.OrdinalIgnoreCase) ? "Local vers web" : "Web vers local")</div>
                                                <div class="small text-muted">@run.OccurredOnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") par @run.TriggeredBy</div>
                                                <div class="small text-muted">@run.Message</div>
                                            </div>
                                            <div class="d-flex flex-wrap gap-1">
                                                <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">@run.Status</span>
                                                @foreach (var module in run.Modules)
                                                {
                                                    <span class="badge" style="background:var(--gc-brand-100); color:var(--gc-brand-hover)">@module.Name : @module.Status</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </details>

    @if (Model.Dashboard.Warnings.Count > 0)
    {
        <div class="card mt-3">
            <div class="section-header">
                <i class="bi bi-exclamation-triangle"></i>
                <span>Points a finaliser</span>
            </div>
            <div class="card-body">
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <ul class="mb-0">
                        @foreach (var warning in Model.Dashboard.Warnings)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }
}
