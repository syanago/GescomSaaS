@page
@model GescomSaas.Web.Pages.Settings.DatabasesModel
@{
    ViewData["Title"] = "Apercu des bases";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Apercu des bases</h1>
        <div class="page-header-sub">Etat des deux bases de donnees de l'application et du mode actuellement actif.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-secondary" asp-page="/Settings/Offline"><i class="bi bi-arrow-repeat me-1"></i>Synchronisation</a>
    </div>
</div>

<div class="mb-3">
    <span class="text-muted me-1">Mode actif :</span>
    @if (Model.IsOnline)
    {
        <span class="badge" style="background:var(--gc-pill-green-bg,#dcfce7); color:var(--gc-pill-green-fg,#166534)"><i class="bi bi-wifi me-1"></i>En ligne (SQL Server)</span>
    }
    else
    {
        <span class="badge" style="background:#fff7ed; color:#9a3412; border:1px solid #fed7aa"><i class="bi bi-hdd me-1"></i>Hors ligne (SQLite)</span>
    }
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100 @(Model.IsOnline ? "" : "")" style="@(Model.IsOnline ? "border-color:#86efac" : "")">
            <div class="section-header">
                <i class="bi bi-cloud"></i>
                <span>Base En ligne — SQL Server @(Model.IsOnline ? "(active)" : "")</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12"><div class="small text-muted">Serveur</div><div class="fw-semibold" style="font-family:var(--bs-font-monospace,monospace)">@Model.SqlServer</div></div>
                    <div class="col-md-6"><div class="small text-muted">Base</div><div class="fw-semibold">@Model.SqlDatabase</div></div>
                    <div class="col-md-6"><div class="small text-muted">Authentification</div><div class="fw-semibold">@Model.SqlAuth</div></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100" style="@(Model.IsOnline ? "" : "border-color:#fed7aa")">
            <div class="section-header">
                <i class="bi bi-hdd"></i>
                <span>Base Hors ligne — SQLite @(Model.IsOnline ? "" : "(active)")</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12"><div class="small text-muted">Fichier</div><div class="fw-semibold" style="font-family:var(--bs-font-monospace,monospace)">@Model.SqlitePath</div></div>
                    <div class="col-md-6">
                        <div class="small text-muted">Etat</div>
                        @if (Model.SqliteExists)
                        {
                            <span class="badge" style="background:var(--gc-pill-green-bg,#dcfce7); color:var(--gc-pill-green-fg,#166534)"><i class="bi bi-check2 me-1"></i>Presente</span>
                        }
                        else
                        {
                            <span class="badge" style="background:#fee2e2; color:#991b1b"><i class="bi bi-x me-1"></i>Absente</span>
                        }
                    </div>
                    <div class="col-md-6"><div class="small text-muted">Taille</div><div class="fw-semibold">@Model.SqliteSize</div></div>
                </div>
            </div>
        </div>
    </div>
</div>
