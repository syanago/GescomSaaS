@page
@model GescomSaas.Web.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Parametres";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Parametres</span>
        <h1>Parametres de la societe</h1>
        <p class="muted-copy">Configurez l'identite de l'entreprise, la devise de caisse et les formats de presentation utilises dans LigCom.</p>
    </div>
</section>

<section class="card-grid">
    <a class="module-card nav-card" asp-page="/Settings/Company">
        <h3>Societe et formats</h3>
        <p>Nom commercial, raison sociale, coordonnees, devise, symbole et precision d'affichage.</p>
        <span>Ouvrir</span>
    </a>
    <a class="module-card nav-card" asp-page="/Settings/Numbering">
        <h3>Numerotation</h3>
        <p>Choisissez les regles de numerotation des referentiels et de chaque type de document.</p>
        <span>Ouvrir</span>
    </a>
    <a class="module-card nav-card" asp-page="/Settings/SageImport">
        <h3>Import Sage SQL</h3>
        <p>Connexion source, perimetre, filtres, mapping et mode de transfert pour rapatrier totalement ou partiellement les donnees Sage Gescom.</p>
        <span>Configurer</span>
    </a>
</section>
