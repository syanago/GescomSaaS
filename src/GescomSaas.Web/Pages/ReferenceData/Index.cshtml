@page
@model GescomSaas.Web.Pages.ReferenceData.IndexModel
@{
    ViewData["Title"] = "Referentiels";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Referentiels commerciaux</h1>
        <div class="page-header-sub">Point d'entree vers les bases de donnees metier qui structurent la gestion commerciale</div>
    </div>
</div>

<div class="row g-3">
    @foreach (var card in Model.Cards)
    {
        <div class="col-md-6 col-lg-4">
            <a href="@card.Href" class="card h-100 text-decoration-none">
                <div class="card-body">
                    <h5 class="card-title text-primary mb-2">@card.Title</h5>
                    <p class="card-text small text-muted mb-3">@card.Description</p>
                    <span class="small fw-semibold text-primary">
                        Ouvrir <i class="bi bi-arrow-right ms-1"></i>
                    </span>
                </div>
            </a>
        </div>
    }
</div>
