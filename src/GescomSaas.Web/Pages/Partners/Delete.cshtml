@page "{id:guid}"
@model GescomSaas.Web.Pages.Partners.DeleteModel
@{
    ViewData["Title"] = "Supprimer un tiers";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Suppression</span>
        <h1>Supprimer @Model.Partner?.Code</h1>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/Partners/Index" asp-route-scope="@Model.Scope">Retour a la liste</a>
    </div>
</section>

<section class="panel-card">
    @if (!string.IsNullOrWhiteSpace(Model.BlockingReason))
    {
        <div class="app-alert warning">@Model.BlockingReason</div>
    }
    else
    {
        <p>La fiche <strong>@Model.Partner?.Name</strong> sera supprimee definitivement.</p>
    }

    <dl class="detail-list">
        <div><dt>Code</dt><dd>@Model.Partner?.Code</dd></div>
        <div><dt>Raison sociale</dt><dd>@Model.Partner?.Name</dd></div>
        <div><dt>Email</dt><dd>@Model.Partner?.Email</dd></div>
        <div><dt>Type</dt><dd>@Model.Partner?.PartnerType</dd></div>
    </dl>

    <form method="post" class="form-actions">
        <input type="hidden" asp-for="Scope" />
        @if (string.IsNullOrWhiteSpace(Model.BlockingReason))
        {
            <button type="submit" class="btn btn-danger-soft">Confirmer la suppression</button>
        }
        <a class="btn btn-outline-light" asp-page="/Partners/Index" asp-route-scope="@Model.Scope">Annuler</a>
    </form>
</section>
