@page "{id:guid}"
@model GescomSaas.Web.Pages.Partners.DeleteModel
@{
    ViewData["Title"] = "Supprimer un tiers";
    var canDelete = string.IsNullOrWhiteSpace(Model.BlockingReason);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Supprimer @Model.Partner?.Code</h1>
        <div class="page-header-sub">Suppression d'une fiche tiers</div>
    </div>
    <div>
        <a class="btn btn-secondary" asp-page="/Partners/Index" asp-route-scope="@Model.Scope">
            <i class="bi bi-arrow-left me-1"></i>Retour a la liste
        </a>
    </div>
</div>

@if (!canDelete)
{
    <div class="alert alert-warning mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Suppression bloquee</strong> — @Model.BlockingReason
    </div>
}
else
{
    <div class="alert alert-danger mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Attention</strong> — la fiche <strong>@Model.Partner?.Name</strong> sera supprimee definitivement.
    </div>
}

<div class="card">
    <div class="section-header">
        <i class="bi bi-trash"></i>
        <span>Recapitulatif</span>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-4">
            <div class="col-md-6"><div class="small text-muted">Code</div><div class="fw-semibold">@Model.Partner?.Code</div></div>
            <div class="col-md-6"><div class="small text-muted">Type</div><div class="fw-semibold">@Model.Partner?.PartnerType</div></div>
            <div class="col-md-6"><div class="small text-muted">Raison sociale</div><div class="fw-semibold">@Model.Partner?.Name</div></div>
            <div class="col-md-6"><div class="small text-muted">Email</div><div>@Model.Partner?.Email</div></div>
        </div>

        <form method="post" class="d-flex justify-content-end gap-2">
            <input type="hidden" asp-for="Scope" />
            <a class="btn btn-secondary" asp-page="/Partners/Index" asp-route-scope="@Model.Scope">Annuler</a>
            @if (canDelete)
            {
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>Confirmer la suppression
                </button>
            }
        </form>
    </div>
</div>
