@page "{id:guid}"
@model GescomSaas.Web.Pages.Partners.EditModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Edition</span>
        <h1>@Model.Title</h1>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/Partners/Index" asp-route-scope="@Model.Scope">Retour a la liste</a>
    </div>
</section>

<section class="panel-card">
    <form method="post" class="stack-form">
        <input type="hidden" asp-for="Scope" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div id="partner-edit-quota-warning" class="app-alert warning quota-inline-warning" hidden></div>

        <div class="form-grid">
            <div>
                <label asp-for="Input.Code" class="form-label"></label>
                <input asp-for="Input.Code" class="form-control" />
                <span asp-validation-for="Input.Code" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.Name" class="form-label"></label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.PartnerType" class="form-label"></label>
                <select asp-for="Input.PartnerType" asp-items="Model.PartnerTypes" class="form-select"></select>
            </div>
            <div>
                <label asp-for="Input.PaymentTermId" class="form-label"></label>
                <select asp-for="Input.PaymentTermId" asp-items="Model.PaymentTerms" class="form-select">
                    <option value="">Aucune</option>
                </select>
            </div>
            <div>
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                <input asp-for="Input.PhoneNumber" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.VatNumber" class="form-label"></label>
                <input asp-for="Input.VatNumber" class="form-control" />
            </div>
            <div>
                <label asp-for="Input.CreditLimit" class="form-label"></label>
                <input asp-for="Input.CreditLimit" class="form-control" />
            </div>
        </div>

        <div class="form-check form-switch mb-4">
            <input asp-for="Input.IsActive" class="form-check-input" />
            <label asp-for="Input.IsActive" class="form-check-label"></label>
        </div>

        <div class="address-grid">
            <fieldset class="subpanel">
                <legend>Adresse de facturation</legend>
                <div class="form-grid">
                    <div><label asp-for="Input.BillingAddress.Recipient" class="form-label"></label><input asp-for="Input.BillingAddress.Recipient" class="form-control" /></div>
                    <div><label asp-for="Input.BillingAddress.StreetLine1" class="form-label">Adresse</label><input asp-for="Input.BillingAddress.StreetLine1" class="form-control" /></div>
                    <div><label asp-for="Input.BillingAddress.StreetLine2" class="form-label">Complement</label><input asp-for="Input.BillingAddress.StreetLine2" class="form-control" /></div>
                    <div><label asp-for="Input.BillingAddress.PostalCode" class="form-label">Code postal</label><input asp-for="Input.BillingAddress.PostalCode" class="form-control" /></div>
                    <div><label asp-for="Input.BillingAddress.City" class="form-label">Ville</label><input asp-for="Input.BillingAddress.City" class="form-control" /></div>
                    <div><label asp-for="Input.BillingAddress.State" class="form-label">Province / Etat</label><input asp-for="Input.BillingAddress.State" class="form-control" /></div>
                    <div><label asp-for="Input.BillingAddress.Country" class="form-label">Pays</label><input asp-for="Input.BillingAddress.Country" class="form-control" /></div>
                </div>
            </fieldset>

            <fieldset class="subpanel">
                <legend>Adresse de livraison</legend>
                <div class="form-grid">
                    <div><label asp-for="Input.ShippingAddress.Recipient" class="form-label"></label><input asp-for="Input.ShippingAddress.Recipient" class="form-control" /></div>
                    <div><label asp-for="Input.ShippingAddress.StreetLine1" class="form-label">Adresse</label><input asp-for="Input.ShippingAddress.StreetLine1" class="form-control" /></div>
                    <div><label asp-for="Input.ShippingAddress.StreetLine2" class="form-label">Complement</label><input asp-for="Input.ShippingAddress.StreetLine2" class="form-control" /></div>
                    <div><label asp-for="Input.ShippingAddress.PostalCode" class="form-label">Code postal</label><input asp-for="Input.ShippingAddress.PostalCode" class="form-control" /></div>
                    <div><label asp-for="Input.ShippingAddress.City" class="form-label">Ville</label><input asp-for="Input.ShippingAddress.City" class="form-control" /></div>
                    <div><label asp-for="Input.ShippingAddress.State" class="form-label">Province / Etat</label><input asp-for="Input.ShippingAddress.State" class="form-control" /></div>
                    <div><label asp-for="Input.ShippingAddress.Country" class="form-label">Pays</label><input asp-for="Input.ShippingAddress.Country" class="form-control" /></div>
                </div>
            </fieldset>
        </div>

        <div class="form-actions">
            <button type="submit" id="partner-edit-submit-button" class="btn btn-primary-soft">Enregistrer</button>
            <a class="btn btn-outline-light" asp-page="/Partners/Index" asp-route-scope="@Model.Scope">Annuler</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const partnerType = document.getElementById('Input_PartnerType');
            const isActive = document.getElementById('Input_IsActive');
            const submitButton = document.getElementById('partner-edit-submit-button');
            const warning = document.getElementById('partner-edit-quota-warning');
            const customerUsed = @((Model.CustomerQuota?.Used ?? 0));
            const customerLimit = @((Model.CustomerQuota?.Limit ?? 0));
            const supplierUsed = @((Model.SupplierQuota?.Used ?? 0));
            const supplierLimit = @((Model.SupplierQuota?.Limit ?? 0));
            const originalType = '@Model.OriginalPartnerType';
            const originalIsActive = @Model.OriginalIsActive.ToString().ToLowerInvariant();

            function consumesCustomer(type) {
                return type === 'Customer' || type === 'Both' || type === 'Prospect';
            }

            function consumesSupplier(type) {
                return type === 'Supplier' || type === 'Both';
            }

            function refreshQuotaGuard() {
                const selectedType = partnerType?.value ?? originalType;
                const active = isActive?.checked ?? false;
                const currentCustomerBase = customerUsed - ((originalIsActive && consumesCustomer(originalType)) ? 1 : 0);
                const currentSupplierBase = supplierUsed - ((originalIsActive && consumesSupplier(originalType)) ? 1 : 0);
                const projectedCustomers = currentCustomerBase + ((active && consumesCustomer(selectedType)) ? 1 : 0);
                const projectedSuppliers = currentSupplierBase + ((active && consumesSupplier(selectedType)) ? 1 : 0);
                const blocked = [];

                if (projectedCustomers > customerLimit && projectedCustomers > customerUsed) {
                    blocked.push(`quota clients atteint (${customerUsed}/${customerLimit})`);
                }

                if (projectedSuppliers > supplierLimit && projectedSuppliers > supplierUsed) {
                    blocked.push(`quota fournisseurs atteint (${supplierUsed}/${supplierLimit})`);
                }

                submitButton.disabled = blocked.length > 0;
                warning.hidden = blocked.length === 0;
                warning.textContent = blocked.length > 0
                    ? `Modification bloquee avant soumission : ${blocked.join(' | ')}. Passe ce tenant sur un plan superieur dans SaaS Admin > Tenants, ou demande a l'administrateur plateforme de mettre a niveau l'abonnement.`
                    : '';
            }

            partnerType?.addEventListener('change', refreshQuotaGuard);
            isActive?.addEventListener('change', refreshQuotaGuard);
            refreshQuotaGuard();
        })();
    </script>
}
