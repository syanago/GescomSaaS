@page "{id:guid}"
@model GescomSaas.Web.Pages.Partners.EditModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">@Model.Title</h1>
        <div class="page-header-sub">Modification d'une fiche tiers</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-secondary" asp-page="/Partners/Details" asp-route-id="@Model.Id" asp-route-scope="@Model.Scope">
            <i class="bi bi-eye me-1"></i>Voir la fiche
        </a>
        <a class="btn btn-secondary" asp-page="/Partners/Index" asp-route-scope="@Model.Scope">
            <i class="bi bi-arrow-left me-1"></i>Retour a la liste
        </a>
    </div>
</div>

<div class="card">
    <div class="section-header">
        <i class="bi bi-pencil"></i>
        <span>Informations tiers</span>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Scope" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div id="partner-edit-quota-warning" class="alert alert-warning" hidden></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.Code" class="form-label"></label>
                    <input asp-for="Input.Code" class="form-control" />
                    <span asp-validation-for="Input.Code" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Name" class="form-label"></label>
                    <input asp-for="Input.Name" class="form-control" />
                    <span asp-validation-for="Input.Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.PartnerType" class="form-label"></label>
                    <select asp-for="Input.PartnerType" asp-items="Model.PartnerTypes" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.PaymentTermId" class="form-label"></label>
                    <select asp-for="Input.PaymentTermId" asp-items="Model.PaymentTerms" class="form-select">
                        <option value="">Aucune</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.PhoneNumber" class="form-label"></label>
                    <input asp-for="Input.PhoneNumber" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.VatNumber" class="form-label"></label>
                    <input asp-for="Input.VatNumber" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.CreditLimit" class="form-label"></label>
                    <input asp-for="Input.CreditLimit" class="form-control" />
                </div>
                <div class="col-12">
                    <div class="form-check form-switch">
                        <input asp-for="Input.IsActive" class="form-check-input" />
                        <label asp-for="Input.IsActive" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-3">
                <div class="col-lg-6">
                    <div class="card" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                        <div class="card-body">
                            <h6 class="mb-3"><i class="bi bi-receipt me-1"></i>Adresse de facturation</h6>
                            <div class="row g-2">
                                <div class="col-12"><label asp-for="Input.BillingAddress.Recipient" class="form-label"></label><input asp-for="Input.BillingAddress.Recipient" class="form-control form-control-sm" /></div>
                                <div class="col-12"><label asp-for="Input.BillingAddress.StreetLine1" class="form-label">Adresse</label><input asp-for="Input.BillingAddress.StreetLine1" class="form-control form-control-sm" /></div>
                                <div class="col-12"><label asp-for="Input.BillingAddress.StreetLine2" class="form-label">Complement</label><input asp-for="Input.BillingAddress.StreetLine2" class="form-control form-control-sm" /></div>
                                <div class="col-md-4"><label asp-for="Input.BillingAddress.PostalCode" class="form-label">CP</label><input asp-for="Input.BillingAddress.PostalCode" class="form-control form-control-sm" /></div>
                                <div class="col-md-8"><label asp-for="Input.BillingAddress.City" class="form-label">Ville</label><input asp-for="Input.BillingAddress.City" class="form-control form-control-sm" /></div>
                                <div class="col-md-6"><label asp-for="Input.BillingAddress.State" class="form-label">Province</label><input asp-for="Input.BillingAddress.State" class="form-control form-control-sm" /></div>
                                <div class="col-md-6"><label asp-for="Input.BillingAddress.Country" class="form-label">Pays</label><input asp-for="Input.BillingAddress.Country" class="form-control form-control-sm" /></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                        <div class="card-body">
                            <h6 class="mb-3"><i class="bi bi-truck me-1"></i>Adresse de livraison</h6>
                            <div class="row g-2">
                                <div class="col-12"><label asp-for="Input.ShippingAddress.Recipient" class="form-label"></label><input asp-for="Input.ShippingAddress.Recipient" class="form-control form-control-sm" /></div>
                                <div class="col-12"><label asp-for="Input.ShippingAddress.StreetLine1" class="form-label">Adresse</label><input asp-for="Input.ShippingAddress.StreetLine1" class="form-control form-control-sm" /></div>
                                <div class="col-12"><label asp-for="Input.ShippingAddress.StreetLine2" class="form-label">Complement</label><input asp-for="Input.ShippingAddress.StreetLine2" class="form-control form-control-sm" /></div>
                                <div class="col-md-4"><label asp-for="Input.ShippingAddress.PostalCode" class="form-label">CP</label><input asp-for="Input.ShippingAddress.PostalCode" class="form-control form-control-sm" /></div>
                                <div class="col-md-8"><label asp-for="Input.ShippingAddress.City" class="form-label">Ville</label><input asp-for="Input.ShippingAddress.City" class="form-control form-control-sm" /></div>
                                <div class="col-md-6"><label asp-for="Input.ShippingAddress.State" class="form-label">Province</label><input asp-for="Input.ShippingAddress.State" class="form-control form-control-sm" /></div>
                                <div class="col-md-6"><label asp-for="Input.ShippingAddress.Country" class="form-label">Pays</label><input asp-for="Input.ShippingAddress.Country" class="form-control form-control-sm" /></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <a class="btn btn-secondary" asp-page="/Partners/Index" asp-route-scope="@Model.Scope">Annuler</a>
                <button type="submit" id="partner-edit-submit-button" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i>Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const partnerType = document.getElementById('Input_PartnerType');
            const isActive = document.getElementById('Input_IsActive');
            const submitButton = document.getElementById('partner-edit-submit-button');
            const warning = document.getElementById('partner-edit-quota-warning');
            const customerUsed = @((Model.CustomerQuota?.Used ?? 0));
            const customerLimit = @((Model.CustomerQuota?.Limit ?? 0));
            const supplierUsed = @((Model.SupplierQuota?.Used ?? 0));
            const supplierLimit = @((Model.SupplierQuota?.Limit ?? 0));
            const originalType = '@Model.OriginalPartnerType';
            const originalIsActive = @Model.OriginalIsActive.ToString().ToLowerInvariant();

            function consumesCustomer(type) { return type === 'Customer' || type === 'Both' || type === 'Prospect'; }
            function consumesSupplier(type) { return type === 'Supplier' || type === 'Both'; }

            function refreshQuotaGuard() {
                const selectedType = partnerType?.value ?? originalType;
                const active = isActive?.checked ?? false;
                const currentCustomerBase = customerUsed - ((originalIsActive && consumesCustomer(originalType)) ? 1 : 0);
                const currentSupplierBase = supplierUsed - ((originalIsActive && consumesSupplier(originalType)) ? 1 : 0);
                const projectedCustomers = currentCustomerBase + ((active && consumesCustomer(selectedType)) ? 1 : 0);
                const projectedSuppliers = currentSupplierBase + ((active && consumesSupplier(selectedType)) ? 1 : 0);
                const blocked = [];

                if (projectedCustomers > customerLimit && projectedCustomers > customerUsed) {
                    blocked.push(`quota clients atteint (${customerUsed}/${customerLimit})`);
                }
                if (projectedSuppliers > supplierLimit && projectedSuppliers > supplierUsed) {
                    blocked.push(`quota fournisseurs atteint (${supplierUsed}/${supplierLimit})`);
                }

                submitButton.disabled = blocked.length > 0;
                warning.hidden = blocked.length === 0;
                warning.textContent = blocked.length > 0
                    ? `Modification bloquee : ${blocked.join(' | ')}.`
                    : '';
            }

            partnerType?.addEventListener('change', refreshQuotaGuard);
            isActive?.addEventListener('change', refreshQuotaGuard);
            refreshQuotaGuard();
        })();
    </script>
}
