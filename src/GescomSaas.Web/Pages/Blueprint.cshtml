@page
@model BlueprintModel
@{
    ViewData["Title"] = "Architecture";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Architecture cible de LigCom SaaS</h1>
        <div class="page-header-sub">Gestion commerciale web moderne avec couche SaaS multi-tenant native</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <p class="mb-0">
            Le projet est pense comme une gestion commerciale web moderne inspiree de Sage Gescom 100,
            avec une couche SaaS native pour gerer les comptes clients, leurs abonnements et l'isolation de leurs donnees.
        </p>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="section-header">
                <i class="bi bi-stack"></i>
                <span>Piliers techniques</span>
            </div>
            <div class="card-body">
                <ul class="mb-0">
                    @foreach (var item in Model.TechnicalDecisions)
                    {
                        <li class="mb-1">@item</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100">
            <div class="section-header">
                <i class="bi bi-flag"></i>
                <span>Roadmap</span>
            </div>
            <div class="card-body">
                <ul class="mb-0">
                    @foreach (var item in Model.Roadmap)
                    {
                        <li class="mb-1">@item</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="section-header">
        <i class="bi bi-grid-3x3-gap"></i>
        <span>Modules Gescom — couverture fonctionnelle</span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            @foreach (var module in Model.Modules)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                        <div class="card-body">
                            <h6 class="text-primary mb-2">@module.Title</h6>
                            <p class="small text-muted mb-3">@module.Description</p>
                            <ul class="small mb-0">
                                @foreach (var feature in module.Features)
                                {
                                    <li>@feature</li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
