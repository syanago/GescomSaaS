@page
@model GescomSaas.Web.Pages.Inventory.SerialNumbersModel
@{
    ViewData["Title"] = "Stock par numero de serie";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Stock</span>
        <h1>Consultation par numero de serie</h1>
        <p class="muted-copy">Suivez les articles traces a l'unite et localisez les numeros de serie encore en stock.</p>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/Inventory/Index">Synthese</a>
        <a class="btn btn-outline-light" asp-page="/StockDocuments/Index">Documents</a>
        <a class="btn btn-outline-light" asp-page="/Inventory/Lots">Lots</a>
        <a class="btn btn-primary-soft" asp-page="/Inventory/Adjustments">Ajustement</a>
    </div>
</section>

<section class="panel-card">
    <form method="get" class="stack-form compact-form">
        <div class="form-grid">
            <div>
                <label asp-for="ProductId" class="form-label">Article</label>
                <select asp-for="ProductId" asp-items="Model.Products" class="form-select">
                    <option value="">Tous les articles</option>
                </select>
            </div>
            <div>
                <label asp-for="WarehouseId" class="form-label">Depot</label>
                <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select">
                    <option value="">Tous les depots</option>
                </select>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary-soft">Filtrer</button>
            <a class="btn btn-outline-light" asp-page="/Inventory/SerialNumbers">Reinitialiser</a>
        </div>
    </form>
</section>

<section class="panel-card">
    <div class="table-shell">
        <table class="table table-darkless align-middle app-table">
            <thead>
                <tr>
                    <th>Article</th>
                    <th>Depot</th>
                    <th>Numero de serie</th>
                    <th class="text-end">Qte</th>
                    <th class="text-end">Cout</th>
                    <th class="text-end">Valeur</th>
                    <th>Dernier mouvement</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.SerialNumbers.Count == 0)
            {
                <tr><td colspan="7" class="empty-cell">Aucun numero de serie actif pour les filtres selectionnes.</td></tr>
            }
            else
            {
                @foreach (var item in Model.SerialNumbers)
                {
                    <tr>
                        <td>@item.ProductCode - @item.ProductLabel</td>
                        <td>@item.WarehouseCode - @item.WarehouseLabel</td>
                        <td>@item.SerialNumber</td>
                        <td class="text-end">@DisplayFormatter.Quantity(item.OnHandQuantity)</td>
                        <td class="text-end">@DisplayFormatter.Money(item.UnitCost)</td>
                        <td class="text-end">@DisplayFormatter.Money(item.StockValue)</td>
                        <td>@item.LastMovementDate.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
