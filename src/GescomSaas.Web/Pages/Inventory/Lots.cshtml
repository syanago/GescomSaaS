@page
@model GescomSaas.Web.Pages.Inventory.LotsModel
@{
    ViewData["Title"] = "Stock par lot";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Consultation par lot</h1>
        <div class="page-header-sub">Quantites disponibles par lot, depot et date de peremption</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-secondary" asp-page="/Inventory/Index">
            <i class="bi bi-clipboard-data me-1"></i>Synthese
        </a>
        <a class="btn btn-secondary" asp-page="/StockDocuments/Index">
            <i class="bi bi-file-earmark-text me-1"></i>Documents
        </a>
        <a class="btn btn-secondary" asp-page="/Inventory/SerialNumbers">
            <i class="bi bi-upc me-1"></i>Numeros de serie
        </a>
        <a class="btn btn-primary" asp-page="/Inventory/Adjustments">
            <i class="bi bi-pencil-square me-1"></i>Ajustement
        </a>
    </div>
</div>

<div class="card mb-3">
    <div class="section-header">
        <i class="bi bi-funnel"></i>
        <span>Filtres</span>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-6">
                <label asp-for="ProductId" class="form-label small">Article</label>
                <select asp-for="ProductId" asp-items="Model.Products" class="form-select form-select-sm">
                    <option value="">Tous les articles</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="WarehouseId" class="form-label small">Depot</label>
                <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select form-select-sm">
                    <option value="">Tous les depots</option>
                </select>
            </div>
            <div class="col-12 d-flex justify-content-end gap-2">
                <a class="btn btn-secondary btn-sm" asp-page="/Inventory/Lots">
                    <i class="bi bi-x-circle me-1"></i>Reinitialiser
                </a>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Filtrer
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="section-header">
        <i class="bi bi-box"></i>
        <span>Lots actifs</span>
        <span class="ms-auto small text-muted">@Model.Lots.Count lot(s)</span>
    </div>
    @if (Model.Lots.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox empty-icon"></i>
            <h6>Aucun lot actif</h6>
            <p>Aucun lot ne correspond aux filtres selectionnes.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Article</th>
                        <th>Depot</th>
                        <th>Lot</th>
                        <th>Peremption</th>
                        <th class="text-end">Qte disponible</th>
                        <th class="text-end">Cout moyen</th>
                        <th class="text-end">Valeur</th>
                        <th>Dernier mouvement</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Lots)
                    {
                        <tr>
                            <td>
                                <strong>@item.ProductCode</strong>
                                <div class="small text-muted">@item.ProductLabel</div>
                            </td>
                            <td>
                                <strong>@item.WarehouseCode</strong>
                                <div class="small text-muted">@item.WarehouseLabel</div>
                            </td>
                            <td><strong>@item.LotNumber</strong></td>
                            <td>
                                @if (item.ExpirationDate.HasValue)
                                {
                                    var daysToExpire = (item.ExpirationDate.Value.ToDateTime(TimeOnly.MinValue) - DateTime.UtcNow).Days;
                                    var badgeStyle = daysToExpire < 0 ? "background:#fee2e2;color:#991b1b" :
                                                     daysToExpire < 30 ? "background:#fef3c7;color:#92400e" :
                                                     "background:var(--gc-pill-green-bg);color:var(--gc-pill-green-fg)";
                                    <span class="badge" style="@badgeStyle">@item.ExpirationDate.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end money">@DisplayFormatter.Quantity(item.OnHandQuantity)</td>
                            <td class="text-end money">@DisplayFormatter.Money(item.AverageUnitCost)</td>
                            <td class="text-end money fw-semibold">@DisplayFormatter.Money(item.StockValue)</td>
                            <td class="small">@item.LastMovementDate.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
