@page
@model GescomSaas.Web.Pages.Inventory.MovementsModel
@{
    ViewData["Title"] = "Mouvements de stock";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Stock</span>
        <h1>Mouvements de stock</h1>
        <p class="muted-copy">Journal complet des entrees, sorties, ajustements et traces lot / serie.</p>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/Inventory/Index">Synthese</a>
        <a class="btn btn-outline-light" asp-page="/StockDocuments/Index">Documents</a>
        <a class="btn btn-outline-light" asp-page="/Inventory/Lots">Lots</a>
        <a class="btn btn-outline-light" asp-page="/Inventory/SerialNumbers">Series</a>
        <a class="btn btn-primary-soft" asp-page="/Inventory/Adjustments">Ajustement</a>
    </div>
</section>

<section class="panel-card">
    <form method="get" class="stack-form compact-form">
        <div class="form-grid">
            <div>
                <label asp-for="ProductId" class="form-label">Article</label>
                <select asp-for="ProductId" asp-items="Model.Products" class="form-select">
                    <option value="">Tous les articles</option>
                </select>
            </div>
            <div>
                <label asp-for="WarehouseId" class="form-label">Depot</label>
                <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select">
                    <option value="">Tous les depots</option>
                </select>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary-soft">Filtrer</button>
            <a class="btn btn-outline-light" asp-page="/Inventory/Movements">Reinitialiser</a>
        </div>
    </form>
</section>

<section class="panel-card">
    <div class="table-shell">
        <table class="table table-darkless align-middle app-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Article</th>
                    <th>Depot</th>
                    <th>Type</th>
                    <th class="text-end">Qte</th>
                    <th class="text-end">Cout</th>
                    <th class="text-end">Valeur</th>
                    <th>Lot / Serie</th>
                    <th>Reference</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Movements.Count == 0)
            {
                <tr><td colspan="9" class="empty-cell">Aucun mouvement trouve.</td></tr>
            }
            else
            {
                @foreach (var movement in Model.Movements)
                {
                    <tr>
                        <td>@movement.MovementDate.ToString("dd/MM/yyyy")</td>
                        <td>@movement.ProductCode - @movement.ProductLabel</td>
                        <td>@movement.WarehouseCode - @movement.WarehouseLabel</td>
                        <td>@GescomSaas.Web.Pages.Inventory.MovementLabels.Label(movement.MovementType)</td>
                        <td class="text-end">@DisplayFormatter.Quantity(movement.Quantity)</td>
                        <td class="text-end">@DisplayFormatter.Money(movement.UnitCost)</td>
                        <td class="text-end">@DisplayFormatter.Money(movement.ExtendedValue)</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(movement.LotNumber) || !string.IsNullOrWhiteSpace(movement.SerialNumber))
                            {
                                <span>@(movement.LotNumber ?? movement.SerialNumber)</span>
                                @if (movement.ExpirationDate.HasValue)
                                {
                                    <div class="table-meta">Peremption @movement.ExpirationDate.Value.ToString("dd/MM/yyyy")</div>
                                }
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td>@(movement.ReferenceNumber ?? "-")</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
