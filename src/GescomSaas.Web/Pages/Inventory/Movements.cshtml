@page
@model GescomSaas.Web.Pages.Inventory.MovementsModel
@{
    ViewData["Title"] = "Mouvements de stock";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Mouvements de stock</h1>
        <div class="page-header-sub">Journal complet des entrees, sorties, ajustements et traces lot/serie</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-secondary" asp-page="/Inventory/Index">
            <i class="bi bi-clipboard-data me-1"></i>Synthese
        </a>
        <a class="btn btn-secondary" asp-page="/StockDocuments/Index">
            <i class="bi bi-file-earmark-text me-1"></i>Documents
        </a>
        <a class="btn btn-secondary" asp-page="/Inventory/Lots">
            <i class="bi bi-box me-1"></i>Lots
        </a>
        <a class="btn btn-secondary" asp-page="/Inventory/SerialNumbers">
            <i class="bi bi-upc me-1"></i>Series
        </a>
        <a class="btn btn-primary" asp-page="/Inventory/Adjustments">
            <i class="bi bi-pencil-square me-1"></i>Ajustement
        </a>
    </div>
</div>

<div class="card mb-3">
    <div class="section-header">
        <i class="bi bi-funnel"></i>
        <span>Filtres</span>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-6">
                <label asp-for="ProductId" class="form-label small">Article</label>
                <select asp-for="ProductId" asp-items="Model.Products" class="form-select form-select-sm">
                    <option value="">Tous les articles</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="WarehouseId" class="form-label small">Depot</label>
                <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select form-select-sm">
                    <option value="">Tous les depots</option>
                </select>
            </div>
            <div class="col-12 d-flex justify-content-end gap-2">
                <a class="btn btn-secondary btn-sm" asp-page="/Inventory/Movements">
                    <i class="bi bi-x-circle me-1"></i>Reinitialiser
                </a>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Filtrer
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="section-header">
        <i class="bi bi-arrow-down-up"></i>
        <span>Mouvements</span>
        <span class="ms-auto small text-muted">@Model.Movements.Count resultat(s)</span>
    </div>
    @if (Model.Movements.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox empty-icon"></i>
            <h6>Aucun mouvement trouve</h6>
            <p>Modifie tes filtres ou enregistre un nouvel ajustement de stock.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Article</th>
                        <th>Depot</th>
                        <th>Type</th>
                        <th class="text-end">Qte</th>
                        <th class="text-end">Cout</th>
                        <th class="text-end">Valeur</th>
                        <th>Lot / Serie</th>
                        <th>Reference</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var movement in Model.Movements)
                    {
                        <tr>
                            <td>@movement.MovementDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <strong>@movement.ProductCode</strong>
                                <div class="small text-muted">@movement.ProductLabel</div>
                            </td>
                            <td>
                                <strong>@movement.WarehouseCode</strong>
                                <div class="small text-muted">@movement.WarehouseLabel</div>
                            </td>
                            <td>@GescomSaas.Web.Pages.Inventory.MovementLabels.Label(movement.MovementType)</td>
                            <td class="text-end money @(movement.Quantity < 0 ? "stat-value-neg" : (movement.Quantity > 0 ? "stat-value-pos" : ""))">@DisplayFormatter.Quantity(movement.Quantity)</td>
                            <td class="text-end money">@DisplayFormatter.Money(movement.UnitCost)</td>
                            <td class="text-end money fw-semibold">@DisplayFormatter.Money(movement.ExtendedValue)</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(movement.LotNumber) || !string.IsNullOrWhiteSpace(movement.SerialNumber))
                                {
                                    <strong>@(movement.LotNumber ?? movement.SerialNumber)</strong>
                                    @if (movement.ExpirationDate.HasValue)
                                    {
                                        <div class="small text-muted">Peremption @movement.ExpirationDate.Value.ToString("dd/MM/yyyy")</div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="small">@(movement.ReferenceNumber ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
