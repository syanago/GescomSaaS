@page
@model GescomSaas.Web.Pages.Inventory.AdjustmentsModel
@{
    ViewData["Title"] = "Ajustement d'inventaire";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Stock</span>
        <h1>Ajustement d'inventaire</h1>
        <p class="muted-copy">Saisissez un mouvement manuel pour corriger un écart de stock ou enregistrer un comptage.</p>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/Inventory/Index">Synthèse</a>
        <a class="btn btn-outline-light" asp-page="/Inventory/Movements">Mouvements</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="app-alert">@Model.StatusMessage</div>
}

<section class="panel-card">
    <form method="post" class="stack-form compact-form" data-stock-tracking-form data-stock-tracking-source-id="inventory-adjustment-tracking-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <div>
                <label asp-for="Input.ProductId" class="form-label"></label>
                <select asp-for="Input.ProductId" asp-items="Model.Products" class="form-select" data-stock-tracking-select>
                    <option value="">Choisir un article</option>
                </select>
                <span asp-validation-for="Input.ProductId" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.WarehouseId" class="form-label"></label>
                <select asp-for="Input.WarehouseId" asp-items="Model.Warehouses" class="form-select">
                    <option value="">Choisir un dépôt</option>
                </select>
                <span asp-validation-for="Input.WarehouseId" class="text-danger"></span>
            </div>
            <div><label asp-for="Input.MovementDate" class="form-label"></label><input asp-for="Input.MovementDate" class="form-control" /></div>
            <div><label asp-for="Input.MovementType" class="form-label"></label><select asp-for="Input.MovementType" asp-items="Model.AdjustmentTypes" class="form-select"></select></div>
            <div>
                <label asp-for="Input.Quantity" class="form-label"></label>
                <input asp-for="Input.Quantity" type="hidden" />
                <input type="text" id="Input_Quantity_display" value="@DisplayFormatter.QuantityEditor(Model.Input.Quantity)" class="form-control" inputmode="decimal" data-format-kind="quantity" data-format-target="Input_Quantity" data-stock-tracking-quantity />
                <div class="table-meta" data-format-preview-for="Input_Quantity_display">Rendu : @DisplayFormatter.Quantity(Model.Input.Quantity)</div>
                <div class="table-meta" data-stock-tracking-quantity-hint></div>
                <span asp-validation-for="Input.Quantity" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Input.UnitCost" class="form-label"></label>
                <input asp-for="Input.UnitCost" type="hidden" />
                <input type="text" id="Input_UnitCost_display" value="@DisplayFormatter.MoneyEditor(Model.Input.UnitCost)" class="form-control" inputmode="decimal" data-format-kind="money" data-format-target="Input_UnitCost" />
                <div class="table-meta" data-format-preview-for="Input_UnitCost_display">Rendu : @DisplayFormatter.Money(Model.Input.UnitCost)</div>
                <span asp-validation-for="Input.UnitCost" class="text-danger"></span>
            </div>
            <div class="full-span table-meta" data-stock-tracking-hint></div>
            <div data-stock-tracking-field="lot"><label asp-for="Input.LotNumber" class="form-label"></label><input asp-for="Input.LotNumber" class="form-control" /><span asp-validation-for="Input.LotNumber" class="text-danger"></span></div>
            <div data-stock-tracking-field="serial"><label asp-for="Input.SerialNumber" class="form-label"></label><input asp-for="Input.SerialNumber" class="form-control" /><span asp-validation-for="Input.SerialNumber" class="text-danger"></span></div>
            <div data-stock-tracking-field="expiration"><label asp-for="Input.ExpirationDate" class="form-label"></label><input asp-for="Input.ExpirationDate" class="form-control" /></div>
            <div class="full-span"><label asp-for="Input.ReferenceNumber" class="form-label"></label><input asp-for="Input.ReferenceNumber" class="form-control" /></div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary-soft">Enregistrer l'ajustement</button>
            <a class="btn btn-outline-light" asp-page="/Inventory/Index">Annuler</a>
        </div>
    </form>
</section>

@section Scripts {
    <script id="inventory-adjustment-tracking-data" type="application/json">@Html.Raw(Model.ProductTrackingMetadataJson)</script>
    <partial name="_ValidationScriptsPartial" />
}
