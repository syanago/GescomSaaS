@page
@model GescomSaas.Web.Pages.Inventory.AdjustmentsModel
@{
    ViewData["Title"] = "Ajustement d'inventaire";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Ajustement d'inventaire</h1>
        <div class="page-header-sub">Mouvement manuel pour corriger un ecart de stock ou enregistrer un comptage</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-secondary" asp-page="/Inventory/Index">
            <i class="bi bi-clipboard-data me-1"></i>Synthese
        </a>
        <a class="btn btn-secondary" asp-page="/Inventory/Movements">
            <i class="bi bi-arrow-down-up me-1"></i>Mouvements
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage
    </div>
}

<div class="card">
    <div class="section-header">
        <i class="bi bi-pencil-square"></i>
        <span>Saisie de l'ajustement</span>
    </div>
    <div class="card-body">
        <form method="post"
              data-stock-tracking-form
              data-stock-tracking-source-id="inventory-adjustment-tracking-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.ProductId" class="form-label"></label>
                    <select asp-for="Input.ProductId" asp-items="Model.Products" class="form-select" data-stock-tracking-select>
                        <option value="">Choisir un article</option>
                    </select>
                    <span asp-validation-for="Input.ProductId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.WarehouseId" class="form-label"></label>
                    <select asp-for="Input.WarehouseId" asp-items="Model.Warehouses" class="form-select">
                        <option value="">Choisir un depot</option>
                    </select>
                    <span asp-validation-for="Input.WarehouseId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.MovementDate" class="form-label"></label>
                    <input asp-for="Input.MovementDate" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.MovementType" class="form-label"></label>
                    <select asp-for="Input.MovementType" asp-items="Model.AdjustmentTypes" class="form-select"></select>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.Quantity" class="form-label"></label>
                    <input asp-for="Input.Quantity" type="hidden" />
                    <input type="text"
                           id="Input_Quantity_display"
                           value="@DisplayFormatter.QuantityEditor(Model.Input.Quantity)"
                           class="form-control money"
                           inputmode="decimal"
                           data-format-kind="quantity"
                           data-format-target="Input_Quantity"
                           data-stock-tracking-quantity />
                    <div class="form-text" data-format-preview-for="Input_Quantity_display">
                        Rendu : @DisplayFormatter.Quantity(Model.Input.Quantity)
                    </div>
                    <div class="form-text" data-stock-tracking-quantity-hint></div>
                    <span asp-validation-for="Input.Quantity" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.UnitCost" class="form-label"></label>
                    <input asp-for="Input.UnitCost" type="hidden" />
                    <input type="text"
                           id="Input_UnitCost_display"
                           value="@DisplayFormatter.MoneyEditor(Model.Input.UnitCost)"
                           class="form-control money"
                           inputmode="decimal"
                           data-format-kind="money"
                           data-format-target="Input_UnitCost" />
                    <div class="form-text" data-format-preview-for="Input_UnitCost_display">
                        Rendu : @DisplayFormatter.Money(Model.Input.UnitCost)
                    </div>
                    <span asp-validation-for="Input.UnitCost" class="text-danger small"></span>
                </div>

                <div class="col-12 form-text" data-stock-tracking-hint></div>

                <div class="col-md-6" data-stock-tracking-field="lot">
                    <label asp-for="Input.LotNumber" class="form-label"></label>
                    <input asp-for="Input.LotNumber" class="form-control" />
                    <span asp-validation-for="Input.LotNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6" data-stock-tracking-field="serial">
                    <label asp-for="Input.SerialNumber" class="form-label"></label>
                    <input asp-for="Input.SerialNumber" class="form-control" />
                    <span asp-validation-for="Input.SerialNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6" data-stock-tracking-field="expiration">
                    <label asp-for="Input.ExpirationDate" class="form-label"></label>
                    <input asp-for="Input.ExpirationDate" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Input.ReferenceNumber" class="form-label"></label>
                    <input asp-for="Input.ReferenceNumber" class="form-control" />
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <a class="btn btn-secondary" asp-page="/Inventory/Index">Annuler</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Enregistrer l'ajustement
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script id="inventory-adjustment-tracking-data" type="application/json">@Html.Raw(Model.ProductTrackingMetadataJson)</script>
    <partial name="_ValidationScriptsPartial" />
}
