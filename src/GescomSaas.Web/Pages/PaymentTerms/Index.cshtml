@page
@model GescomSaas.Web.Pages.PaymentTerms.IndexModel
@{
    ViewData["Title"] = "Conditions de paiement";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Conditions de paiement</h1>
        <div class="page-header-sub">Parametrez les echeances utilisees sur les fiches clients et fournisseurs.</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-page="/PaymentTerms/Create"><i class="bi bi-plus-lg me-1"></i>Nouvelle condition</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage
    </div>
}

<div class="card">
    <div class="section-header">
        <i class="bi bi-calendar-check"></i>
        <span>Conditions de paiement</span>
        <span class="ms-auto small text-muted">@Model.PaymentTerms.Count resultat(s)</span>
    </div>
    @if (Model.PaymentTerms.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox empty-icon"></i>
            <h6>Aucune condition de paiement</h6>
            <p>Creez votre premiere condition pour gerer les echeances clients et fournisseurs.</p>
            <a class="btn btn-primary btn-sm" asp-page="/PaymentTerms/Create"><i class="bi bi-plus-lg me-1"></i>Nouvelle condition</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Libelle</th>
                        <th class="text-end money">Jours</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.PaymentTerms)
                    {
                        <tr>
                            <td><strong>@item.Code</strong></td>
                            <td>@item.Label</td>
                            <td class="text-end money">@item.DueInDays</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a class="btn btn-sm btn-secondary" asp-page="/PaymentTerms/Edit" asp-route-id="@item.Id" title="Modifier"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-sm btn-secondary text-danger" asp-page="/PaymentTerms/Delete" asp-route-id="@item.Id" title="Supprimer"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
