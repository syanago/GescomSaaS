@page
@model GescomSaas.Web.Pages.CommercialOperations.IndexModel
@{
    ViewData["Title"] = "Traitements";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Traitements commerciaux</h1>
        <div class="page-header-sub">Point d'entree pour piloter les cycles de vente, achat, finance et stock</div>
    </div>
</div>

@* Modules principaux *@
<div class="row g-3 mb-4">
    @foreach (var card in Model.Cards)
    {
        <div class="col-md-6 col-lg-4">
            <a href="@card.Href" class="card h-100 text-decoration-none" style="transition:transform .15s, box-shadow .15s">
                <div class="card-body">
                    <h5 class="card-title text-primary mb-2">@card.Title</h5>
                    <p class="card-text small text-muted mb-3">@card.Description</p>
                    <span class="small fw-semibold text-primary">
                        Acceder au module <i class="bi bi-arrow-right ms-1"></i>
                    </span>
                </div>
            </a>
        </div>
    }
</div>

<div class="row g-3">
    @* Cycles metier *@
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="section-header">
                <i class="bi bi-diagram-3"></i>
                <span>Flux couverts</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var flow in Model.Flows)
                    {
                        <div class="col-md-6">
                            <div class="card border" style="background:var(--gc-brand-50)">
                                <div class="card-body">
                                    <h6 class="card-title mb-2">@flow.Title</h6>
                                    <p class="card-text small text-muted mb-0">@flow.Description</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Acces rapide *@
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="section-header">
                <i class="bi bi-lightning"></i>
                <span>Actions frequentes</span>
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-2">
                    @foreach (var quickLink in Model.QuickLinks)
                    {
                        <a href="@quickLink.Href" class="card border text-decoration-none" style="transition:background .15s">
                            <div class="card-body py-2">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <div class="fw-semibold text-primary">@quickLink.Title</div>
                                        <div class="small text-muted">@quickLink.Description</div>
                                    </div>
                                    <i class="bi bi-arrow-right text-primary"></i>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
