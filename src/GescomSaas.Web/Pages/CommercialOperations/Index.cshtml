@page
@model GescomSaas.Web.Pages.CommercialOperations.IndexModel
@{
    ViewData["Title"] = "Traitements";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Traitements</span>
        <h1>Vue d'ensemble des traitements commerciaux</h1>
        <p class="muted-copy">Point d'entree pour piloter les cycles de vente, d'achat, de finance et de stock dans LigCom.</p>
    </div>
</section>

<section class="card-grid">
    @foreach (var card in Model.Cards)
    {
        <a class="module-card nav-card" href="@card.Href">
            <h3>@card.Title</h3>
            <p>@card.Description</p>
            <span>Acceder au module</span>
        </a>
    }
</section>

<section class="content-grid mt-4">
    <article class="panel-card">
        <div class="panel-header">
            <div>
                <span class="eyebrow">Cycles metier</span>
                <h2>Flux couverts</h2>
            </div>
        </div>
        <div class="module-stack">
            @foreach (var flow in Model.Flows)
            {
                <div class="module-card">
                    <h3>@flow.Title</h3>
                    <p>@flow.Description</p>
                </div>
            }
        </div>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <div>
                <span class="eyebrow">Acces rapide</span>
                <h2>Actions frequentes</h2>
            </div>
        </div>
        <div class="module-stack">
            @foreach (var quickLink in Model.QuickLinks)
            {
                <a class="module-card nav-card" href="@quickLink.Href">
                    <h3>@quickLink.Title</h3>
                    <p>@quickLink.Description</p>
                    <span>Ouvrir</span>
                </a>
            }
        </div>
    </article>
</section>
