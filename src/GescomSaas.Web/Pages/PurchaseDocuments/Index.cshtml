@page
@model GescomSaas.Web.Pages.PurchaseDocuments.IndexModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="workspace-shell">
    <section class="workspace-hero">
        <div class="workspace-copy">
            <span class="workspace-kicker">Traitements commerciaux</span>
            <h1>@Model.Title</h1>
            <p class="muted-copy">Suivre les demandes, commandes, receptions et factures fournisseurs avec un repere visuel stable par type de piece.</p>
            <div class="workspace-actions">
                <a class="btn btn-primary-soft" asp-page="/PurchaseDocuments/Create" asp-route-type="@Model.CurrentType">Nouvelle piece</a>
                <a class="btn btn-outline-light" asp-page="/CommercialOperations/Index">Retour aux traitements</a>
            </div>
            <div class="segment-bar">
                @foreach (var type in GescomSaas.Web.Pages.PurchaseDocuments.PurchaseDocumentCatalog.PurchaseTypes)
                {
                    var isActive = type == Model.CurrentType;
                    <a class="segment-link @(isActive ? "is-active" : string.Empty)" asp-page="/PurchaseDocuments/Index" asp-route-type="@type">@GescomSaas.Web.Pages.PurchaseDocuments.PurchaseDocumentCatalog.Label(type)</a>
                }
            </div>
        </div>
        <div class="workspace-summary-grid">
            <article class="workspace-summary-card">
                <span class="signal-label">Pieces visibles</span>
                <strong>@DisplayFormatter.Number(Model.Documents.Count, 0)</strong>
                <span class="table-meta">documents du type @Model.Title.ToLowerInvariant()</span>
            </article>
            <article class="workspace-summary-card">
                <span class="signal-label">Montant cumule</span>
                <strong>@DisplayFormatter.Money(Model.Documents.Sum(x => x.TotalIncludingTax), Model.Documents.FirstOrDefault()?.CurrencyCode)</strong>
                <span class="table-meta">total des pieces chargees a l'ecran</span>
            </article>
            @if (Model.DocumentQuota is not null)
            {
                <article class="workspace-summary-card">
                    <span class="signal-label">Documents du mois</span>
                    <strong>@Model.DocumentQuota.Used / @Model.DocumentQuota.Limit</strong>
                    <span class="table-meta">
                        @if (Model.DocumentQuota.IsExceeded)
                        {
                            <text>depassement de @(Model.DocumentQuota.Used - Model.DocumentQuota.Limit)</text>
                        }
                        else
                        {
                            <text>@(Model.DocumentQuota.Limit - Model.DocumentQuota.Used) restant(s)</text>
                        }
                    </span>
                </article>
            }
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="app-alert">@Model.StatusMessage</div>
    }

    <section class="workspace-table">
        <div class="table-shell">
            <table class="table table-darkless align-middle app-table">
                <thead>
                    <tr>
                        <th>Document</th>
                        <th>Date</th>
                        <th>Fournisseur</th>
                        <th>Source</th>
                        <th>Statut</th>
                        <th class="text-end">Montant TTC</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Documents.Count == 0)
                {
                    <tr><td colspan="7" class="empty-cell">Aucune piece pour ce type.</td></tr>
                }
                else
                {
                    @foreach (var document in Model.Documents)
                    {
                        <tr>
                            <td>
                                <div class="doc-number">
                                    <strong>@document.Number</strong>
                                    <span class="doc-meta">@Model.Title · @document.DocumentDate.ToString("dd MMM yyyy")</span>
                                </div>
                            </td>
                            <td>@document.DocumentDate.ToString("dd/MM/yyyy")</td>
                            <td>@document.PartnerName</td>
                            <td>@(document.SourceNumber ?? "-")</td>
                            <td><span class="badge rounded-pill status-pill">@document.Status</span></td>
                            <td class="text-end">@DisplayFormatter.Money(document.TotalIncludingTax, document.CurrencyCode)</td>
                            <td class="text-end">
                                <div class="row-actions">
                                    <a class="action-link" asp-page="/PurchaseDocuments/Details" asp-route-id="@document.Id">Voir</a>
                                    <a class="action-link" asp-page="/PurchaseDocuments/Edit" asp-route-id="@document.Id">Modifier</a>
                                    <a class="action-link" asp-page="/PurchaseDocuments/Delete" asp-route-id="@document.Id">Supprimer</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </section>
</div>
