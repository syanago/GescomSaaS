@page "{id:guid}"
@model GescomSaas.Web.Pages.PurchaseDocuments.EditModel
@{
    ViewData["Title"] = "Modifier une piece d'achat";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Edition</span>
        <h1>@GescomSaas.Web.Pages.PurchaseDocuments.PurchaseDocumentCatalog.Label(Model.Input.DocumentType) @Model.Input.Number</h1>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/PurchaseDocuments/Details" asp-route-id="@Model.Id">Voir le detail</a>
        <a class="btn btn-outline-light" asp-page="/PurchaseDocuments/Index" asp-route-type="@Model.Input.DocumentType">Retour a la liste</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="app-alert">@Model.StatusMessage</div>
}

<section class="content-grid blueprint-grid">
    <article class="panel-card">
        <div class="panel-header">
            <div>
                <span class="eyebrow">Entete</span>
                <h2>Informations du document</h2>
            </div>
        </div>

        <form method="post" asp-route-id="@Model.Id" class="stack-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-grid">
                <div><label asp-for="Input.Number" class="form-label"></label><input asp-for="Input.Number" class="form-control" readonly /></div>
                <div><label asp-for="Input.PartnerId" class="form-label"></label><select asp-for="Input.PartnerId" asp-items="Model.Partners" class="form-select"><option value="">Choisir un fournisseur</option></select></div>
                <div><label asp-for="Input.WarehouseId" class="form-label"></label><select asp-for="Input.WarehouseId" asp-items="Model.Warehouses" class="form-select"><option value="">Aucun depot</option></select></div>
                <div><label asp-for="Input.Status" class="form-label"></label><select asp-for="Input.Status" asp-items="Model.Statuses" class="form-select"></select></div>
                <div><label asp-for="Input.DocumentDate" class="form-label"></label><input asp-for="Input.DocumentDate" class="form-control" /></div>
                <div><label asp-for="Input.DueDate" class="form-label"></label><input asp-for="Input.DueDate" class="form-control" /></div>
                <div><label asp-for="Input.CurrencyCode" class="form-label"></label><input asp-for="Input.CurrencyCode" class="form-control" /></div>
                <div class="full-span"><label asp-for="Input.Notes" class="form-label"></label><textarea asp-for="Input.Notes" rows="4" class="form-control"></textarea></div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary-soft">Mettre a jour</button>
            </div>
        </form>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <div>
                <span class="eyebrow">Nouvelle ligne</span>
                <h2>Ajouter un article</h2>
            </div>
        </div>
        <form method="post" asp-page-handler="AddLine" asp-route-id="@Model.Id" class="stack-form" data-stock-tracking-form data-stock-tracking-source-id="purchase-line-tracking-data">
            <div class="form-grid">
                <div class="full-span"><label asp-for="NewLine.ProductId" class="form-label"></label><select asp-for="NewLine.ProductId" asp-items="Model.Products" class="form-select" data-stock-tracking-select><option value="">Choisir un article</option></select><span asp-validation-for="NewLine.ProductId" class="text-danger"></span></div>
                <div class="full-span"><label asp-for="NewLine.Description" class="form-label"></label><input asp-for="NewLine.Description" class="form-control" /><span asp-validation-for="NewLine.Description" class="text-danger"></span></div>
                <div>
                    <label asp-for="NewLine.Quantity" class="form-label"></label>
                    <input asp-for="NewLine.Quantity" type="hidden" />
                    <input type="text" id="NewLine_Quantity_display" value="@DisplayFormatter.QuantityEditor(Model.NewLine.Quantity)" class="form-control" inputmode="decimal" data-format-kind="quantity" data-format-target="NewLine_Quantity" data-stock-tracking-quantity />
                    <div class="table-meta" data-format-preview-for="NewLine_Quantity_display">Rendu : @DisplayFormatter.Quantity(Model.NewLine.Quantity)</div>
                    <div class="table-meta" data-stock-tracking-quantity-hint></div>
                    <span asp-validation-for="NewLine.Quantity" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="NewLine.UnitPriceExcludingTax" class="form-label"></label>
                    <input asp-for="NewLine.UnitPriceExcludingTax" type="hidden" />
                    <input type="text" id="NewLine_UnitPriceExcludingTax_display" value="@DisplayFormatter.MoneyEditor(Model.NewLine.UnitPriceExcludingTax)" class="form-control" inputmode="decimal" data-format-kind="money" data-format-target="NewLine_UnitPriceExcludingTax" data-format-currency-code="@Model.Input.CurrencyCode" />
                    <div class="table-meta" data-format-preview-for="NewLine_UnitPriceExcludingTax_display">Rendu : @DisplayFormatter.Money(Model.NewLine.UnitPriceExcludingTax, Model.Input.CurrencyCode)</div>
                    <span asp-validation-for="NewLine.UnitPriceExcludingTax" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="NewLine.DiscountRate" class="form-label"></label>
                    <input asp-for="NewLine.DiscountRate" type="hidden" />
                    <input type="text" id="NewLine_DiscountRate_display" value="@DisplayFormatter.RateEditor(Model.NewLine.DiscountRate)" class="form-control" inputmode="decimal" data-format-kind="rate" data-format-target="NewLine_DiscountRate" data-format-decimals="2" />
                    <div class="table-meta" data-format-preview-for="NewLine_DiscountRate_display">Rendu : @DisplayFormatter.Number(Model.NewLine.DiscountRate, 2) %</div>
                    <span asp-validation-for="NewLine.DiscountRate" class="text-danger"></span>
                </div>
                <div>
                    <label asp-for="NewLine.TaxRate" class="form-label"></label>
                    <input asp-for="NewLine.TaxRate" type="hidden" />
                    <input type="text" id="NewLine_TaxRate_display" value="@DisplayFormatter.RateEditor(Model.NewLine.TaxRate)" class="form-control" inputmode="decimal" data-format-kind="rate" data-format-target="NewLine_TaxRate" data-format-decimals="2" />
                    <div class="table-meta" data-format-preview-for="NewLine_TaxRate_display">Rendu : @DisplayFormatter.Number(Model.NewLine.TaxRate, 2) %</div>
                    <span asp-validation-for="NewLine.TaxRate" class="text-danger"></span>
                </div>
                <div class="full-span table-meta" data-stock-tracking-hint></div>
                <div data-stock-tracking-field="lot"><label asp-for="NewLine.LotNumber" class="form-label"></label><input asp-for="NewLine.LotNumber" class="form-control" /><span asp-validation-for="NewLine.LotNumber" class="text-danger"></span></div>
                <div data-stock-tracking-field="serial"><label asp-for="NewLine.SerialNumber" class="form-label"></label><input asp-for="NewLine.SerialNumber" class="form-control" /><span asp-validation-for="NewLine.SerialNumber" class="text-danger"></span></div>
                <div data-stock-tracking-field="expiration"><label asp-for="NewLine.ExpirationDate" class="form-label"></label><input asp-for="NewLine.ExpirationDate" class="form-control" /></div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary-soft">Ajouter la ligne</button>
            </div>
        </form>
    </article>
</section>

<section class="panel-card">
    <div class="panel-header">
        <div>
            <span class="eyebrow">Lignes</span>
            <h2>Contenu du document</h2>
        </div>
    </div>

    <div class="table-shell">
        <table class="table table-darkless align-middle app-table">
            <thead>
                <tr>
                    <th>Article</th>
                    <th>Description</th>
                    <th class="text-end">Qté</th>
                    <th class="text-end">PU HT</th>
                    <th class="text-end">Remise</th>
                    <th class="text-end">Taxe</th>
                    <th>Lot / Serie</th>
                    <th class="text-end">TTC</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Lines.Count == 0)
            {
                <tr><td colspan="9" class="empty-cell">Aucune ligne dans cette piece.</td></tr>
            }
            else
            {
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.ProductCode</td>
                        <td>@line.Description</td>
                        <td class="text-end">@DisplayFormatter.Quantity(line.Quantity)</td>
                        <td class="text-end">@DisplayFormatter.Money(line.UnitPriceExcludingTax, Model.Input.CurrencyCode)</td>
                        <td class="text-end">@DisplayFormatter.Number(line.DiscountRate, 2) %</td>
                        <td class="text-end">@DisplayFormatter.Number(line.TaxRate, 2) %</td>
                        <td>@(line.LotNumber ?? line.SerialNumber ?? "-")</td>
                        <td class="text-end">@DisplayFormatter.Money(line.TotalIncludingTax, Model.Input.CurrencyCode)</td>
                        <td class="text-end">
                            <form method="post" asp-page-handler="DeleteLine" asp-route-id="@Model.Id" class="inline-form">
                                <input type="hidden" name="lineId" value="@line.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-light">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script id="purchase-line-tracking-data" type="application/json">@Html.Raw(Model.ProductTrackingMetadataJson)</script>
    <partial name="_ValidationScriptsPartial" />
}
