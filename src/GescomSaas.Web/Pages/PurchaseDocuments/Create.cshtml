@page
@model GescomSaas.Web.Pages.PurchaseDocuments.CreateModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">@Model.Title</h1>
        <div class="page-header-sub">Creation d'un nouveau document d'achat</div>
    </div>
    <div>
        <a class="btn btn-secondary" asp-page="/PurchaseDocuments/Index" asp-route-type="@Model.Type">
            <i class="bi bi-arrow-left me-1"></i>Retour a la liste
        </a>
    </div>
</div>

<div class="card">
    <div class="section-header">
        <i class="bi bi-file-earmark-plus"></i>
        <span>Informations du document</span>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Type" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div id="purchase-document-quota-warning" class="alert alert-warning" hidden></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.Number" class="form-label"></label>
                    <input asp-for="Input.Number" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Status" class="form-label"></label>
                    <select asp-for="Input.Status" asp-items="Model.Statuses" class="form-select"></select>
                </div>

                <div class="col-12" data-partner-assist data-partner-lookup-mode="@Model.PartnerLookupMode" data-partner-entity-label="fournisseur">
                    <label class="form-label">@Model.PartnerLookupLabel</label>
                    <input asp-for="Input.PartnerId" type="hidden" />
                    <input asp-for="PartnerEntry.Lookup" class="form-control" list="purchase-create-partner-options" placeholder="@Model.PartnerLookupPlaceholder" data-partner-lookup-input />
                    <datalist id="purchase-create-partner-options" data-partner-options>
                        @foreach (var partner in Model.PartnerOptions)
                        {
                            <option value="@partner.DisplayValue">@partner.Caption</option>
                        }
                    </datalist>
                    <div class="form-text">Saisie assistee par @(Model.PartnerLookupMode == GescomSaas.Domain.Enums.PartnerLookupMode.Code ? "code" : "nom"). Si le fournisseur n'existe pas, active la creation rapide.</div>
                    <div class="d-flex align-items-center gap-2 mt-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-partner-create-button>
                            <i class="bi bi-plus-lg me-1"></i>Nouveau fournisseur
                        </button>
                        <span class="form-text mb-0" data-partner-create-status>Selectionne un fournisseur existant ou cree-le a la volee.</span>
                    </div>
                    <span asp-validation-for="Input.PartnerId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.WarehouseId" class="form-label"></label>
                    <select asp-for="Input.WarehouseId" asp-items="Model.Warehouses" class="form-select">
                        <option value="">Aucun depot</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.CurrencyCode" class="form-label"></label>
                    <input asp-for="Input.CurrencyCode" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.DocumentDate" class="form-label"></label>
                    <input asp-for="Input.DocumentDate" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.DueDate" class="form-label"></label>
                    <input asp-for="Input.DueDate" class="form-control" />
                </div>

                <div class="col-12" data-partner-create-panel hidden>
                    <div class="card" style="background:var(--gc-brand-50); border-color:var(--gc-brand-200)">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <strong>Creation rapide du fournisseur</strong>
                                <span class="form-text">S'ouvre automatiquement si aucun fournisseur correspondant n'est trouve.</span>
                            </div>
                            <div class="form-check form-switch mb-3">
                                <input asp-for="PartnerEntry.CreateIfMissing" class="form-check-input" data-partner-create-toggle />
                                <label asp-for="PartnerEntry.CreateIfMissing" class="form-check-label"></label>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="PartnerEntry.NewCode" class="form-label"></label>
                                    <input asp-for="PartnerEntry.NewCode" class="form-control" data-partner-new-code />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="PartnerEntry.NewName" class="form-label"></label>
                                    <input asp-for="PartnerEntry.NewName" class="form-control" data-partner-new-name />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="PartnerEntry.Email" class="form-label"></label>
                                    <input asp-for="PartnerEntry.Email" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="PartnerEntry.PhoneNumber" class="form-label"></label>
                                    <input asp-for="PartnerEntry.PhoneNumber" class="form-control" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="Input.Notes" class="form-label"></label>
                    <textarea asp-for="Input.Notes" rows="3" class="form-control"></textarea>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <a class="btn btn-secondary" asp-page="/PurchaseDocuments/Index" asp-route-type="@Model.Type">Annuler</a>
                <button type="submit" id="purchase-document-submit-button" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>Creer la piece
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const dateInput = document.getElementById('Input_DocumentDate');
            const submitButton = document.getElementById('purchase-document-submit-button');
            const warning = document.getElementById('purchase-document-quota-warning');
            const used = @((Model.DocumentQuota?.Used ?? 0));
            const limit = @((Model.DocumentQuota?.Limit ?? 0));
            const referenceYear = @Model.QuotaReferenceDate.Year;
            const referenceMonth = @Model.QuotaReferenceDate.Month;

            function refreshQuotaGuard() {
                const selectedDate = dateInput?.value ? new Date(dateInput.value + 'T00:00:00') : null;
                const samePeriod = selectedDate
                    && selectedDate.getFullYear() === referenceYear
                    && (selectedDate.getMonth() + 1) === referenceMonth;

                const blocked = samePeriod && used >= limit;
                submitButton.disabled = blocked;
                warning.hidden = !(blocked || !samePeriod);
                warning.textContent = blocked
                    ? `Creation bloquee avant soumission : quota documents du mois atteint (${used}/${limit}) pour la periode selectionnee. Passe ce tenant sur un plan superieur dans SaaS Admin > Tenants, ou demande a l'administrateur plateforme de mettre a niveau l'abonnement.`
                    : `Le blocage visuel couvre la periode @Model.QuotaReferenceDate.ToString("MM/yyyy"). Si tu changes de mois, la validation definitive sera faite a l'enregistrement.`;
            }

            dateInput?.addEventListener('change', refreshQuotaGuard);
            refreshQuotaGuard();
        })();
    </script>
}
