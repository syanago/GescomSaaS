@page
@model GescomSaas.Web.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Articles";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Articles</h1>
        <div class="page-header-sub">References, familles, taxes et prix d'achat/vente</div>
    </div>
    <div>
        <a class="btn btn-primary" asp-page="/Products/Create">
            <i class="bi bi-plus-lg me-1"></i>Nouvel article
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage
    </div>
}

@if (Model.ProductQuota is not null)
{
    var quotaExceeded = Model.ProductQuota.IsExceeded;
    <div class="alert @(quotaExceeded ? "alert-danger" : "alert-info") mb-3">
        <i class="bi bi-speedometer2 me-2"></i>
        <strong>Articles</strong> : @Model.ProductQuota.Used / @Model.ProductQuota.Limit
        @if (quotaExceeded)
        {
            <span>· depasse de @(Model.ProductQuota.Used - Model.ProductQuota.Limit)</span>
        }
        else
        {
            <span>· @(Model.ProductQuota.Limit - Model.ProductQuota.Used) restant(s)</span>
        }
    </div>
}

<div class="card">
    <div class="section-header">
        <i class="bi bi-box-seam"></i>
        <span>Catalogue articles</span>
        <span class="ms-auto small text-muted">@Model.Products.Count article(s)</span>
    </div>
    @if (Model.Products.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox empty-icon"></i>
            <h6>Aucun article</h6>
            <p>Cree ton premier article pour demarrer le catalogue.</p>
            <a class="btn btn-primary btn-sm" asp-page="/Products/Create">
                <i class="bi bi-plus-lg me-1"></i>Nouvel article
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Reference</th>
                        <th>Libelle</th>
                        <th>Type</th>
                        <th>Famille</th>
                        <th>TVA</th>
                        <th>Suivi stock</th>
                        <th>Lot / Serie</th>
                        <th class="text-end">Achat</th>
                        <th class="text-end">Vente</th>
                        <th>Etat</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td><strong>@product.Sku</strong></td>
                            <td>
                                <strong>@product.Label</strong>
                                <div class="small text-muted">@product.UnitOfMeasure @(product.TrackStock ? "• Stocke" : "• Service")</div>
                            </td>
                            <td>@GetTypeLabel(product.ProductType)</td>
                            <td>@product.CategoryLabel</td>
                            <td>@product.TaxCode</td>
                            <td><span class="badge" style="background:#e0f2fe;color:#075985">@GetValuationLabel(product.StockValuationMethod)</span></td>
                            <td>@GetIdentityLabel(product.StockIdentityTrackingMode)</td>
                            <td class="text-end money">@DisplayFormatter.Money(product.PurchasePrice)</td>
                            <td class="text-end money fw-semibold">@DisplayFormatter.Money(product.SalesPrice)</td>
                            <td>
                                @if (product.IsActive)
                                {
                                    <span class="badge" style="background:var(--gc-pill-green-bg); color:var(--gc-pill-green-fg)">Actif</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#f3f4f6; color:#6b7280">Inactif</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a class="btn btn-sm btn-secondary" asp-page="/Products/Edit" asp-route-id="@product.Id" title="Modifier"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-sm btn-secondary text-danger" asp-page="/Products/Delete" asp-route-id="@product.Id" title="Supprimer"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@functions {
    private static string GetTypeLabel(GescomSaas.Domain.Enums.ProductType type) => type switch
    {
        GescomSaas.Domain.Enums.ProductType.StockItem => "Article stocke",
        GescomSaas.Domain.Enums.ProductType.Service => "Service",
        GescomSaas.Domain.Enums.ProductType.Bundle => "Nomenclature",
        _ => type.ToString()
    };

    private static string GetValuationLabel(GescomSaas.Domain.Enums.StockValuationMethod method) => method switch
    {
        GescomSaas.Domain.Enums.StockValuationMethod.Cmup => "CMUP",
        GescomSaas.Domain.Enums.StockValuationMethod.Fifo => "FIFO",
        GescomSaas.Domain.Enums.StockValuationMethod.LastPurchaseCost => "Dernier prix",
        _ => method.ToString()
    };

    private static string GetIdentityLabel(GescomSaas.Domain.Enums.StockIdentityTrackingMode mode) => mode switch
    {
        GescomSaas.Domain.Enums.StockIdentityTrackingMode.None => "—",
        GescomSaas.Domain.Enums.StockIdentityTrackingMode.Lot => "Par lot",
        GescomSaas.Domain.Enums.StockIdentityTrackingMode.SerialNumber => "Par serie",
        _ => mode.ToString()
    };
}
