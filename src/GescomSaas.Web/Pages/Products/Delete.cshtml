@page "{id:guid}"
@model GescomSaas.Web.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Supprimer un article";
    var canDelete = string.IsNullOrWhiteSpace(Model.BlockingReason);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Supprimer @Model.Product?.Sku</h1>
        <div class="page-header-sub">Suppression d'une fiche article</div>
    </div>
    <div>
        <a class="btn btn-secondary" asp-page="/Products/Index">
            <i class="bi bi-arrow-left me-1"></i>Retour a la liste
        </a>
    </div>
</div>

@if (!canDelete)
{
    <div class="alert alert-warning mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Suppression bloquee</strong> — @Model.BlockingReason
    </div>
}
else
{
    <div class="alert alert-danger mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Attention</strong> — l'article <strong>@Model.Product?.Label</strong> sera supprime definitivement.
    </div>
}

<div class="card">
    <div class="section-header">
        <i class="bi bi-trash"></i>
        <span>Recapitulatif</span>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-4">
            <div class="col-md-6"><div class="small text-muted">Reference</div><div class="fw-semibold">@Model.Product?.Sku</div></div>
            <div class="col-md-6"><div class="small text-muted">Type</div><div class="fw-semibold">@Model.Product?.ProductType</div></div>
            <div class="col-md-6"><div class="small text-muted">Libelle</div><div class="fw-semibold">@Model.Product?.Label</div></div>
            <div class="col-md-6"><div class="small text-muted">Prix de vente</div><div class="fw-bold money">@DisplayFormatter.Money(Model.Product?.SalesPrice ?? 0m)</div></div>
        </div>

        <form method="post" class="d-flex justify-content-end gap-2">
            <a class="btn btn-secondary" asp-page="/Products/Index">Annuler</a>
            @if (canDelete)
            {
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>Confirmer la suppression
                </button>
            }
        </form>
    </div>
</div>
