@page "{id:guid}"
@model GescomSaas.Web.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Supprimer un article";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Suppression</span>
        <h1>Supprimer @Model.Product?.Sku</h1>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/Products/Index">Retour a la liste</a>
    </div>
</section>

<section class="panel-card">
    @if (!string.IsNullOrWhiteSpace(Model.BlockingReason))
    {
        <div class="app-alert warning">@Model.BlockingReason</div>
    }
    else
    {
        <p>L'article <strong>@Model.Product?.Label</strong> sera supprime definitivement.</p>
    }

    <dl class="detail-list">
        <div><dt>Reference</dt><dd>@Model.Product?.Sku</dd></div>
        <div><dt>Libelle</dt><dd>@Model.Product?.Label</dd></div>
        <div><dt>Type</dt><dd>@Model.Product?.ProductType</dd></div>
        <div><dt>Prix de vente</dt><dd>@DisplayFormatter.Money(Model.Product?.SalesPrice ?? 0m)</dd></div>
    </dl>

    <form method="post" class="form-actions">
        @if (string.IsNullOrWhiteSpace(Model.BlockingReason))
        {
            <button type="submit" class="btn btn-danger-soft">Confirmer la suppression</button>
        }
        <a class="btn btn-outline-light" asp-page="/Products/Index">Annuler</a>
    </form>
</section>
