@page "{id:guid}"
@model GescomSaas.Web.Pages.Products.EditModel
@{
    ViewData["Title"] = "Modifier un article";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Modifier un article</h1>
        <div class="page-header-sub">Edition de la fiche article</div>
    </div>
    <div>
        <a class="btn btn-secondary" asp-page="/Products/Index">
            <i class="bi bi-arrow-left me-1"></i>Retour a la liste
        </a>
    </div>
</div>

<div class="card">
    <div class="section-header">
        <i class="bi bi-pencil"></i>
        <span>Informations article</span>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div id="product-edit-quota-warning" class="alert alert-warning" hidden></div>

            <div class="row g-3">
                <div class="col-md-6"><label asp-for="Input.Sku" class="form-label"></label><input asp-for="Input.Sku" class="form-control" /><span asp-validation-for="Input.Sku" class="text-danger small"></span></div>
                <div class="col-md-6"><label asp-for="Input.Label" class="form-label"></label><input asp-for="Input.Label" class="form-control" /><span asp-validation-for="Input.Label" class="text-danger small"></span></div>
                <div class="col-md-6"><label asp-for="Input.ProductType" class="form-label"></label><select asp-for="Input.ProductType" asp-items="Model.ProductTypes" class="form-select"></select></div>
                <div class="col-md-6"><label asp-for="Input.UnitOfMeasure" class="form-label"></label><input asp-for="Input.UnitOfMeasure" class="form-control" /></div>
                <div class="col-md-6"><label asp-for="Input.ProductCategoryId" class="form-label"></label><select asp-for="Input.ProductCategoryId" asp-items="Model.Categories" class="form-select"><option value="">Aucune</option></select></div>
                <div class="col-md-6"><label asp-for="Input.TaxCodeId" class="form-label"></label><select asp-for="Input.TaxCodeId" asp-items="Model.TaxCodes" class="form-select"><option value="">Aucune</option></select></div>
                <div class="col-md-6"><label asp-for="Input.StockValuationMethod" class="form-label"></label><select asp-for="Input.StockValuationMethod" asp-items="Model.StockValuationMethodOptions" class="form-select"></select></div>
                <div class="col-md-6"><label asp-for="Input.StockIdentityTrackingMode" class="form-label"></label><select asp-for="Input.StockIdentityTrackingMode" asp-items="Model.StockIdentityTrackingModeOptions" class="form-select"></select></div>

                <div class="col-md-6">
                    <label asp-for="Input.PurchasePrice" class="form-label"></label>
                    <input asp-for="Input.PurchasePrice" type="hidden" />
                    <input type="text" id="Input_PurchasePrice_display" value="@DisplayFormatter.MoneyEditor(Model.Input.PurchasePrice)" class="form-control money" inputmode="decimal" data-format-kind="money" data-format-target="Input_PurchasePrice" />
                    <div class="form-text" data-format-preview-for="Input_PurchasePrice_display">Rendu : @DisplayFormatter.Money(Model.Input.PurchasePrice)</div>
                    <span asp-validation-for="Input.PurchasePrice" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.SalesPrice" class="form-label"></label>
                    <input asp-for="Input.SalesPrice" type="hidden" />
                    <input type="text" id="Input_SalesPrice_display" value="@DisplayFormatter.MoneyEditor(Model.Input.SalesPrice)" class="form-control money" inputmode="decimal" data-format-kind="money" data-format-target="Input_SalesPrice" />
                    <div class="form-text" data-format-preview-for="Input_SalesPrice_display">Rendu : @DisplayFormatter.Money(Model.Input.SalesPrice)</div>
                    <span asp-validation-for="Input.SalesPrice" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Input.Description" class="form-label"></label>
                    <textarea asp-for="Input.Description" rows="3" class="form-control"></textarea>
                </div>

                <div class="col-md-6">
                    <div class="form-check form-switch">
                        <input asp-for="Input.TrackStock" class="form-check-input" />
                        <label asp-for="Input.TrackStock" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check form-switch">
                        <input asp-for="Input.IsActive" class="form-check-input" />
                        <label asp-for="Input.IsActive" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <a class="btn btn-secondary" asp-page="/Products/Index">Annuler</a>
                <button type="submit" id="product-edit-submit-button" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i>Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const isActive = document.getElementById('Input_IsActive');
            const submitButton = document.getElementById('product-edit-submit-button');
            const warning = document.getElementById('product-edit-quota-warning');
            const used = @((Model.ProductQuota?.Used ?? 0));
            const limit = @((Model.ProductQuota?.Limit ?? 0));
            const originalIsActive = @Model.OriginalIsActive.ToString().ToLowerInvariant();

            function refreshQuotaGuard() {
                const active = isActive?.checked ?? false;
                const currentBase = used - (originalIsActive ? 1 : 0);
                const projected = currentBase + (active ? 1 : 0);
                const blocked = projected > limit && projected > used;

                submitButton.disabled = blocked;
                warning.hidden = !blocked;
                warning.textContent = blocked
                    ? `Modification bloquee : quota articles atteint (${used}/${limit}).`
                    : '';
            }

            isActive?.addEventListener('change', refreshQuotaGuard);
            refreshQuotaGuard();
        })();
    </script>
}
