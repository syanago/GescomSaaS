@page
@model GescomSaas.Web.Pages.LigComLibraryModel
@{
    ViewData["Title"] = "Bibliothèque de composants LigCom";
    Layout = "_LayoutLigCom";
}

@section Scripts {
    <script src="~/js/ligcom-library.js" asp-append-version="true"></script>
    <script>lucide.createIcons();</script>
}

<div class="lc-page-header">
    <div>
        <h1 class="lc-page-title">Bibliothèque de composants</h1>
        <p class="lc-page-sub">Référence visuelle complète du design system LigCom — Untitled UI strict, densité élevée, multi-devise FCFA / EUR / USD.</p>
    </div>
</div>

<div class="lc-lib">

    @* =========================== STICKY TOC =========================== *@
    <aside class="lc-lib__nav">
        <a class="lc-lib__nav-item is-active" href="#sec-buttons">Boutons</a>
        <a class="lc-lib__nav-item" href="#sec-inputs">Inputs</a>
        <a class="lc-lib__nav-item" href="#sec-affixes">Préfixe / suffixe</a>
        <a class="lc-lib__nav-item" href="#sec-autocomplete">Autocomplete</a>
        <a class="lc-lib__nav-item" href="#sec-currency">Devise</a>
        <a class="lc-lib__nav-item" href="#sec-toggles">Checkbox / radio / switch</a>
        <a class="lc-lib__nav-item" href="#sec-badges">Badges</a>
        <a class="lc-lib__nav-item" href="#sec-cards">Cards</a>
        <a class="lc-lib__nav-item" href="#sec-pageheader">Page header</a>
        <a class="lc-lib__nav-item" href="#sec-stats">Stat cards</a>
        <a class="lc-lib__nav-item" href="#sec-tabs">Tabs</a>
        <a class="lc-lib__nav-item" href="#sec-breadcrumbs">Breadcrumbs</a>
        <a class="lc-lib__nav-item" href="#sec-avatars">Avatars</a>
        <a class="lc-lib__nav-item" href="#sec-modals">Modals</a>
        <a class="lc-lib__nav-item" href="#sec-drawers">Drawers</a>
        <a class="lc-lib__nav-item" href="#sec-toasts">Toasts</a>
        <a class="lc-lib__nav-item" href="#sec-empty">Empty states</a>
        <a class="lc-lib__nav-item" href="#sec-skeleton">Skeleton</a>
    </aside>

    <div>

    @* ========================================================================
       BOUTONS
       ======================================================================== *@
    <section id="sec-buttons" class="lc-lib__section">
        <h2 class="lc-lib__section-title">Boutons</h2>
        <p class="lc-lib__section-sub">5 variantes × 3 tailles × 6 états · classes .btn-primary / -secondary / -tertiary / -link / -danger.</p>

        <div class="lc-lib__demo">
            <div class="lc-lib__demo-label">Variantes (md)</div>
            <div class="lc-lib__demo-row">
                <button class="btn btn-primary"><i data-lucide="save" style="width:14px;height:14px"></i>Primary</button>
                <button class="btn btn-secondary"><i data-lucide="download" style="width:14px;height:14px"></i>Secondary</button>
                <button class="btn btn-tertiary"><i data-lucide="settings" style="width:14px;height:14px"></i>Tertiary (ghost)</button>
                <button class="btn btn-link">Link · en savoir plus</button>
                <button class="btn btn-danger"><i data-lucide="trash-2" style="width:14px;height:14px"></i>Destructive</button>
            </div>

            <div class="lc-lib__demo-label">Tailles (primary)</div>
            <div class="lc-lib__demo-row">
                <button class="btn btn-primary btn-sm">Small</button>
                <button class="btn btn-primary">Medium</button>
                <button class="btn btn-primary btn-lg">Large</button>
            </div>

            <div class="lc-lib__demo-label">États</div>
            <div class="lc-lib__demo-row">
                <button class="btn btn-primary">Default</button>
                <button class="btn btn-primary" style="background:var(--color-primary-700);border-color:var(--color-primary-700)">Hover (forcé)</button>
                <button class="btn btn-primary" style="box-shadow:var(--focus-ring)">Focus</button>
                <button class="btn btn-primary btn--loading">Loading…</button>
                <button class="btn btn-primary" disabled>Disabled</button>
                <button class="btn btn-primary" data-online-only disabled data-tip="Indisponible hors ligne — sera possible une fois reconnecté">Offline-only</button>
            </div>

            <div class="lc-lib__demo-label">Icon variants</div>
            <div class="lc-lib__demo-row">
                <button class="btn btn-primary"><i data-lucide="plus" style="width:14px;height:14px"></i>Icon leading</button>
                <button class="btn btn-secondary">Icon trailing<i data-lucide="arrow-right" style="width:14px;height:14px"></i></button>
                <button class="btn btn-secondary btn--icon-only" aria-label="Plus"><i data-lucide="more-horizontal" style="width:16px;height:16px"></i></button>
                <button class="btn btn-secondary btn--icon-only btn-sm" aria-label="Modifier"><i data-lucide="pencil" style="width:14px;height:14px"></i></button>
                <button class="btn btn-secondary btn--icon-only btn-lg" aria-label="Imprimer"><i data-lucide="printer" style="width:18px;height:18px"></i></button>
            </div>
        </div>
    </section>

    @* ========================================================================
       INPUTS
       ======================================================================== *@
    <section id="sec-inputs" class="lc-lib__section">
        <h2 class="lc-lib__section-title">Inputs</h2>
        <p class="lc-lib__section-sub">Avec label · hint · états error · variantes spécialisées.</p>

        <div class="lc-lib__demo">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label" for="inp-text">Nom du client</label>
                    <input id="inp-text" class="form-control" type="text" placeholder="Ex. SARL Komlan & Fils" />
                    <div class="form-text">Saisis le nom complet de la société.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="inp-error">Email</label>
                    <input id="inp-error" class="form-control is-invalid" type="email" value="contact@@invalid" />
                    <div class="invalid-feedback">Adresse email invalide.</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="inp-num">Quantité</label>
                    <div class="lc-num-input">
                        <button type="button" class="lc-num-input__btn" data-num-step="down">−</button>
                        <input id="inp-num" type="number" value="12" step="1" />
                        <button type="button" class="lc-num-input__btn" data-num-step="up">+</button>
                    </div>
                    <div class="form-text">Spinners customs (cache les natifs Chrome/Firefox).</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="inp-pwd">Mot de passe</label>
                    <div class="lc-pwd">
                        <input id="inp-pwd" class="form-control" type="password" value="MotDePasseDuRoi42" autocomplete="current-password" />
                        <button type="button" class="lc-pwd__toggle" data-pwd-toggle="inp-pwd" aria-label="Afficher le mot de passe">
                            <i data-lucide="eye" data-pwd-icon="open" style="width:16px;height:16px"></i>
                            <i data-lucide="eye-off" data-pwd-icon="closed" style="width:16px;height:16px;display:none"></i>
                        </button>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="inp-search">Recherche</label>
                    <div style="position:relative">
                        <i data-lucide="search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-tertiary);pointer-events:none"></i>
                        <input id="inp-search" class="form-control" type="search" placeholder="Rechercher…" style="padding-left:34px" />
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="inp-date">Date de facturation</label>
                    <input id="inp-date" class="form-control" type="date" value="2026-04-27" />
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="inp-select">Mode de paiement</label>
                    <select id="inp-select" class="form-select">
                        <option>Virement bancaire</option>
                        <option>Mobile Money (MTN, Moov)</option>
                        <option>Espèces</option>
                        <option>Chèque</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="inp-textarea">Notes</label>
                    <textarea id="inp-textarea" class="form-control" rows="3" placeholder="Conditions particulières…"></textarea>
                </div>

                <div class="col-12">
                    <label class="form-label">Pièces jointes</label>
                    <div class="lc-file-drop">
                        <div class="lc-file-drop__icon"><i data-lucide="upload-cloud" style="width:18px;height:18px"></i></div>
                        <div class="lc-file-drop__title"><strong>Cliquer pour téléverser</strong> ou glisser un fichier</div>
                        <div class="lc-file-drop__hint">PDF, JPG, PNG · max 10 Mo</div>
                        <input type="file" hidden multiple accept=".pdf,.jpg,.png" />
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ========================================================================
       PRÉFIXE / SUFFIXE
       ======================================================================== *@
    <section id="sec-affixes" class="lc-lib__section">
        <h2 class="lc-lib__section-title">Préfixe / suffixe</h2>
        <p class="lc-lib__section-sub">Indispensables pour la saisie monétaire et les pourcentages.</p>

        <div class="lc-lib__demo">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Montant TTC (FCFA)</label>
                    <div class="lc-input-group">
                        <input type="text" value="1 250 000" inputmode="numeric" />
                        <div class="lc-input-group__addon">FCFA</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Montant TTC (EUR)</label>
                    <div class="lc-input-group">
                        <input type="text" value="1 905,93" inputmode="decimal" />
                        <div class="lc-input-group__addon">€</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Montant TTC (USD)</label>
                    <div class="lc-input-group">
                        <div class="lc-input-group__addon lc-input-group__addon--prefix">$</div>
                        <input type="text" value="2 048,12" inputmode="decimal" />
                        <div class="lc-input-group__addon">USD</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Taux TVA</label>
                    <div class="lc-input-group">
                        <input type="text" value="18,00" inputmode="decimal" />
                        <div class="lc-input-group__addon">%</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Remise</label>
                    <div class="lc-input-group">
                        <input type="text" value="5,00" inputmode="decimal" />
                        <div class="lc-input-group__addon">%</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Erreur de saisie</label>
                    <div class="lc-input-group is-invalid">
                        <input type="text" value="abc" />
                        <div class="lc-input-group__addon">FCFA</div>
                    </div>
                    <div class="invalid-feedback">Saisis un nombre entier.</div>
                </div>
            </div>
        </div>
    </section>

    @* ========================================================================
       AUTOCOMPLETE
       ======================================================================== *@
    <section id="sec-autocomplete" class="lc-lib__section">
        <h2 class="lc-lib__section-title">Autocomplete (article / client)</h2>
        <p class="lc-lib__section-sub">Critique pour la saisie. Code mono + libellé. Navigation clavier ↑↓ Enter Esc.</p>

        <div class="lc-lib__demo">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Client</label>
                    <div class="lc-ac" data-ac-source="ac-clients">
                        <input type="text" class="form-control" placeholder="Code ou nom du client (3 lettres min.)" autocomplete="off" />
                        <div class="lc-ac__menu"></div>
                    </div>
                    <div class="form-text">Bordure brand au focus, dropdown liste tous les résultats.</div>
                    <script id="ac-clients" type="application/json">
                        [
                            {"code":"CLI-001","label":"SARL Komlan & Fils","meta":"Lomé"},
                            {"code":"CLI-002","label":"EBC Logistique SA","meta":"Cotonou"},
                            {"code":"CLI-003","label":"Pharmacie Centrale Lomé","meta":"Lomé"},
                            {"code":"CLI-004","label":"Mairie de Cotonou","meta":"Cotonou"},
                            {"code":"CLI-005","label":"Boutique Akwaba","meta":"Abidjan"},
                            {"code":"CLI-006","label":"SOTRAL Transport","meta":"Lomé"},
                            {"code":"CLI-007","label":"BTP Sahel SARL","meta":"Ouagadougou"},
                            {"code":"CLI-008","label":"Hôtel Le Galion","meta":"Dakar"}
                        ]
                    </script>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Article</label>
                    <div class="lc-ac" data-ac-source="ac-articles">
                        <input type="text" class="form-control" placeholder="SKU ou libellé article" autocomplete="off" />
                        <div class="lc-ac__menu"></div>
                    </div>
                    <script id="ac-articles" type="application/json">
                        [
                            {"code":"ART-0125","label":"Ciment CPA 45 sac 50 kg","meta":"4 200 FCFA"},
                            {"code":"ART-0126","label":"Tôle bac galvanisée 0,3 mm","meta":"15 500 FCFA"},
                            {"code":"ART-0127","label":"Riz parfumé 25 kg","meta":"22 000 FCFA"},
                            {"code":"ART-0128","label":"Huile palme 5 L","meta":"5 800 FCFA"},
                            {"code":"ART-0129","label":"Câble électrique 2,5 mm² (m)","meta":"480 FCFA"}
                        ]
                    </script>
                </div>
            </div>
        </div>
    </section>

    @* ========================================================================
       SÉLECTEUR DE DEVISE
       ======================================================================== *@
    <section id="sec-currency" class="lc-lib__section">
        <h2 class="lc-lib__section-title">Sélecteur de devise</h2>
        <p class="lc-lib__section-sub">Drapeau visuel + code ISO + nom complet.</p>

        <div class="lc-lib__demo">
            <div class="lc-dropdown" data-dropdown style="display:inline-block">
                <button type="button" class="btn btn-secondary" data-dropdown-toggle>
                    <span class="lc-currency-flag lc-currency-flag--xof">CI</span>
                    <strong style="margin-left:4px">XOF</strong>
                    <span style="color:var(--text-tertiary);margin-left:4px">FCFA — Franc CFA UEMOA</span>
                    <i data-lucide="chevron-down" style="width:14px;height:14px;margin-left:4px"></i>
                </button>
                <div class="lc-dropdown__menu" style="min-width:280px">
                    <button class="lc-dropdown__item">
                        <span class="lc-currency-flag lc-currency-flag--xof">CI</span>
                        <div style="flex:1">
                            <div style="font-weight:600;color:var(--text-primary)">XOF — Franc CFA UEMOA</div>
                            <div style="font:var(--font-text-xs);color:var(--text-tertiary)">Bénin · Burkina · Côte d'Ivoire · Mali · Niger · Sénégal · Togo</div>
                        </div>
                        <span class="lc-badge lc-badge--primary">Actif</span>
                    </button>
                    <button class="lc-dropdown__item">
                        <span class="lc-currency-flag lc-currency-flag--xof" style="background:linear-gradient(135deg,#FFCD00,#003082)">CM</span>
                        <div style="flex:1">
                            <div style="font-weight:600;color:var(--text-primary)">XAF — Franc CFA CEMAC</div>
                            <div style="font:var(--font-text-xs);color:var(--text-tertiary)">Cameroun · Gabon · Congo · Tchad · RCA · Guinée Eq.</div>
                        </div>
                    </button>
                    <button class="lc-dropdown__item">
                        <span class="lc-currency-flag lc-currency-flag--eur">€</span>
                        <div style="flex:1">
                            <div style="font-weight:600;color:var(--text-primary)">EUR — Euro</div>
                            <div style="font:var(--font-text-xs);color:var(--text-tertiary)">Zone euro</div>
                        </div>
                    </button>
                    <button class="lc-dropdown__item">
                        <span class="lc-currency-flag lc-currency-flag--usd">$</span>
                        <div style="flex:1">
                            <div style="font-weight:600;color:var(--text-primary)">USD — US Dollar</div>
                            <div style="font:var(--font-text-xs);color:var(--text-tertiary)">États-Unis · International</div>
                        </div>
                    </button>
                </div>
            </div>
            <div class="form-text mt-3">Ouvrir le dropdown : clic sur le bouton (cliquer ailleurs pour fermer).</div>
        </div>
    </section>

    @* ========================================================================
       CHECKBOX / RADIO / SWITCH
       ======================================================================== *@
    <section id="sec-toggles" class="lc-lib__section">
        <h2 class="lc-lib__section-title">Checkbox · radio · toggle switch</h2>
        <p class="lc-lib__section-sub">Inputs natifs restylés en Untitled UI strict, focus ring 4px à 24%.</p>

        <div class="lc-lib__demo">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="lc-lib__demo-label">Checkboxes</div>
                    <label class="lc-check"><input type="checkbox" /> Activer les rappels</label><br>
                    <label class="lc-check"><input type="checkbox" checked /> Sauvegarder en local</label><br>
                    <label class="lc-check"><input type="checkbox" disabled /> Désactivé</label><br>
                    <label class="lc-check"><input type="checkbox" checked disabled /> Coché et désactivé</label>
                </div>
                <div class="col-md-4">
                    <div class="lc-lib__demo-label">Radios</div>
                    <label class="lc-radio"><input type="radio" name="r1" /> XOF — FCFA</label><br>
                    <label class="lc-radio"><input type="radio" name="r1" checked /> EUR — €</label><br>
                    <label class="lc-radio"><input type="radio" name="r1" /> USD — $</label>
                </div>
                <div class="col-md-4">
                    <div class="lc-lib__demo-label">Toggles</div>
                    <label class="lc-switch">
                        <input type="checkbox" checked />
                        <span class="lc-switch__track"><span class="lc-switch__thumb"></span></span>
                        Synchronisation automatique
                    </label><br>
                    <label class="lc-switch lc-switch--lg" style="margin-top:8px">
                        <input type="checkbox" />
                        <span class="lc-switch__track"><span class="lc-switch__thumb"></span></span>
                        Mode hors ligne forcé
                    </label>
                </div>
            </div>
        </div>
    </section>

    @* ========================================================================
       BADGES
       ======================================================================== *@
    <section id="sec-badges" class="lc-lib__section">
        <h2 class="lc-lib__section-title">Badges</h2>
        <p class="lc-lib__section-sub">7 sémantiques × dot / icône / closable. Statuts métier gestcom.</p>

        <div class="lc-lib__demo">
            <div class="lc-lib__demo-label">Statuts métier</div>
            <div class="lc-lib__demo-row">
                <span class="lc-badge lc-badge--gray"><span class="lc-badge__dot" style="background:var(--text-quaternary)"></span>Brouillon</span>
                <span class="lc-badge lc-badge--info"><span class="lc-badge__dot"></span>Envoyé</span>
                <span class="lc-badge lc-badge--success"><span class="lc-badge__dot"></span>Accepté / Payé</span>
                <span class="lc-badge lc-badge--warning"><span class="lc-badge__dot"></span>Partiel</span>
                <span class="lc-badge lc-badge--error"><span class="lc-badge__dot"></span>Refusé / En retard</span>
                <span class="lc-badge lc-badge--primary"><span class="lc-badge__dot" style="background:var(--color-primary-600)"></span>Validé</span>
                <span class="lc-badge lc-badge--local">Local</span>
            </div>

            <div class="lc-lib__demo-label">Avec icône</div>
            <div class="lc-lib__demo-row">
                <span class="lc-badge lc-badge--success"><i data-lucide="check" style="width:12px;height:12px"></i>Synchronisé</span>
                <span class="lc-badge lc-badge--warning"><i data-lucide="clock" style="width:12px;height:12px"></i>En attente</span>
                <span class="lc-badge lc-badge--error"><i data-lucide="x-circle" style="width:12px;height:12px"></i>Erreur 409</span>
                <span class="lc-badge lc-badge--info"><i data-lucide="cloud" style="width:12px;height:12px"></i>Distant</span>
            </div>

            <div class="lc-lib__demo-label">Closables (filtres actifs)</div>
            <div class="lc-lib__demo-row">
                <span class="lc-badge lc-badge--primary">
                    Statut : Validé
                    <button style="background:transparent;border:none;padding:0;color:inherit;cursor:pointer;display:grid;place-items:center" aria-label="Retirer">
                        <i data-lucide="x" style="width:12px;height:12px"></i>
                    </button>
                </span>
                <span class="lc-badge lc-badge--gray">
                    Devise : XOF
                    <button style="background:transparent;border:none;padding:0;color:inherit;cursor:pointer;display:grid;place-items:center" aria-label="Retirer">
                        <i data-lucide="x" style="width:12px;height:12px"></i>
                    </button>
                </span>
                <span class="lc-badge lc-badge--gray">
                    Période : avril 2026
                    <button style="background:transparent;border:none;padding:0;color:inherit;cursor:pointer;display:grid;place-items:center" aria-label="Retirer">
                        <i data-lucide="x" style="width:12px;height:12px"></i>
                    </button>
                </span>
            </div>

            <div class="lc-lib__demo-label">Variante "square" (border-radius xs)</div>
            <div class="lc-lib__demo-row">
                <span class="lc-badge lc-badge--primary" style="border-radius:var(--radius-xs)">Nouveau</span>
                <span class="lc-badge lc-badge--success" style="border-radius:var(--radius-xs)">Soldé</span>
                <span class="lc-badge lc-badge--warning" style="border-radius:var(--radius-xs)">Stock bas</span>
            </div>
        </div>
    </section>

    @* ========================================================================
       CARDS
       ======================================================================== *@
    <section id="sec-cards" class="lc-lib__section">
        <h2 class="lc-lib__section-title">Cards</h2>
        <p class="lc-lib__section-sub">3 niveaux d'élévation : flat (sans relief) · outlined (border) · elevated (shadow md).</p>

        <div class="lc-lib__demo">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="lc-card lc-card--flat">
                        <div class="lc-card__header"><h3 class="lc-card__title">Flat</h3></div>
                        <div class="lc-card__body">
                            <p style="margin:0;color:var(--text-tertiary)">Sans bordure ni ombre, fond légèrement teinté. Idéal pour zones imbriquées.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="lc-card lc-card--outlined">
                        <div class="lc-card__header"><h3 class="lc-card__title">Outlined</h3></div>
                        <div class="lc-card__body">
                            <p style="margin:0;color:var(--text-tertiary)">Bordure 1px sans ombre. Cas par défaut pour la plupart des panneaux.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="lc-card lc-card--elevated">
                        <div class="lc-card__header"><h3 class="lc-card__title">Elevated</h3></div>
                        <div class="lc-card__body">
                            <p style="margin:0;color:var(--text-tertiary)">Shadow md, pour modules importants ou éléments flottants.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ========================================================================
       PAGE HEADER
       ======================================================================== *@
    <section id="sec-pageheader" class="lc-lib__section">
        <h2 class="lc-lib__section-title">Page header</h2>
