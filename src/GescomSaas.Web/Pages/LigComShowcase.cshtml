@page
@model GescomSaas.Web.Pages.LigComShowcaseModel
@{
    ViewData["Title"] = "Design system LigCom";
    Layout = "_LayoutLigCom";
}

<div class="lc-page-header">
    <div>
        <h1 class="lc-page-title">Showcase du design system</h1>
        <p class="lc-page-sub">Vérification visuelle des tokens, du shell, et des composants offline.</p>
    </div>
    <div style="display:flex; gap:8px">
        <button type="button" class="btn btn-secondary" onclick="LigCom.setSyncState('syncing', {done:3, total:12})">
            <i data-lucide="cloud-upload" style="width:14px;height:14px"></i>Simuler sync
        </button>
        <button type="button" class="btn btn-secondary" onclick="LigCom.setSyncState('offline', {pending:7})">
            <i data-lucide="wifi-off" style="width:14px;height:14px"></i>Simuler offline
        </button>
        <button type="button" class="btn btn-secondary" onclick="LigCom.setSyncState('online')">
            <i data-lucide="wifi" style="width:14px;height:14px"></i>Simuler online
        </button>
        <button type="button" class="btn btn-primary" onclick="LigCom.openConflict({entityLabel:'Facture FA-2026-0042'})">
            <i data-lucide="git-merge" style="width:14px;height:14px"></i>Tester conflit
        </button>
    </div>
</div>

@* ============================== KPI tiles ============================== *@
<div class="row g-3 mb-3">
    <div class="col-md-3 col-sm-6">
        <div class="lc-stat">
            <div class="lc-stat__icon lc-stat__icon--primary"><i data-lucide="receipt" style="width:18px;height:18px"></i></div>
            <div>
                <div class="lc-stat__label">Chiffre d'affaires</div>
                <div class="lc-stat__value">8 240 500<span style="font:var(--font-text-md);color:var(--text-tertiary);font-weight:500"> FCFA</span></div>
                <div class="lc-stat__delta lc-stat__delta--up">+12,4% vs mois dernier</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="lc-stat">
            <div class="lc-stat__icon lc-stat__icon--warning"><i data-lucide="clock" style="width:18px;height:18px"></i></div>
            <div>
                <div class="lc-stat__label">Factures impayées</div>
                <div class="lc-stat__value">3 480 000<span style="font:var(--font-text-md);color:var(--text-tertiary);font-weight:500"> FCFA</span></div>
                <div class="lc-stat__delta">7 factures · 4 en retard</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="lc-stat">
            <div class="lc-stat__icon lc-stat__icon--info"><i data-lucide="package" style="width:18px;height:18px"></i></div>
            <div>
                <div class="lc-stat__label">Stock valorisé</div>
                <div class="lc-stat__value">14 720 000<span style="font:var(--font-text-md);color:var(--text-tertiary);font-weight:500"> FCFA</span></div>
                <div class="lc-stat__delta">2 dépôts · 156 articles</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="lc-stat">
            <div class="lc-stat__icon lc-stat__icon--success"><i data-lucide="trending-up" style="width:18px;height:18px"></i></div>
            <div>
                <div class="lc-stat__label">Marge brute</div>
                <div class="lc-stat__value">32,8<span style="font:var(--font-text-md);color:var(--text-tertiary);font-weight:500"> %</span></div>
                <div class="lc-stat__delta lc-stat__delta--up">+1,2 pt vs mois dernier</div>
            </div>
        </div>
    </div>
</div>

