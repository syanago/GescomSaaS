@* ============================== Démo formulaire compact ============================== *@
<div class="row g-3 mt-3">
    <div class="col-lg-6">
        <div class="lc-card">
            <div class="lc-card__header">
                <i data-lucide="file-plus" style="width:18px;height:18px;color:var(--color-primary-700)"></i>
                <h3 class="lc-card__title">Nouvelle facture</h3>
            </div>
            <div class="lc-card__body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Numéro</label>
                        <input type="text" class="form-control" value="FA-2026-0043" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" value="2026-04-27" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Client</label>
                        <input type="text" class="form-control" placeholder="Recherche client (3 lettres min.)" />
                        <div class="form-text">Saisis le code ou le nom du client. <kbd class="lc-kbd">↑↓</kbd> pour naviguer.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Devise</label>
                        <select class="form-select">
                            <option>XOF · FCFA</option>
                            <option>EUR · €</option>
                            <option>USD · $</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Taux TVA par défaut</label>
                        <select class="form-select">
                            <option>18 % (UEMOA standard)</option>
                            <option>9 %</option>
                            <option>0 %</option>
                        </select>
                    </div>
                    <div class="col-12 d-flex justify-content-end gap-2 pt-2">
                        <button type="button" class="btn btn-secondary">Annuler</button>
                        <button type="button" class="btn btn-secondary" data-online-only>
                            <i data-lucide="send" style="width:14px;height:14px"></i>Valider et envoyer
                        </button>
                        <button type="button" class="btn btn-primary">
                            <i data-lucide="save" style="width:14px;height:14px"></i>Enregistrer
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ============================== Démo badges et états ============================== *@
    <div class="col-lg-6">
        <div class="lc-card">
            <div class="lc-card__header">
                <i data-lucide="palette" style="width:18px;height:18px;color:var(--color-primary-700)"></i>
                <h3 class="lc-card__title">Badges &amp; pills sémantiques</h3>
            </div>
            <div class="lc-card__body">
                <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px">
                    <span class="lc-badge lc-badge--gray"><span class="lc-badge__dot" style="background:var(--text-quaternary)"></span>Brouillon</span>
                    <span class="lc-badge lc-badge--primary"><span class="lc-badge__dot" style="background:var(--color-primary-600)"></span>Validée</span>
                    <span class="lc-badge lc-badge--success"><span class="lc-badge__dot"></span>Payée</span>
                    <span class="lc-badge lc-badge--warning"><span class="lc-badge__dot"></span>En retard 2j</span>
                    <span class="lc-badge lc-badge--error"><span class="lc-badge__dot"></span>Impayée 12j</span>
                    <span class="lc-badge lc-badge--info"><span class="lc-badge__dot"></span>Partielle</span>
                    <span class="lc-badge lc-badge--local">Local</span>
                </div>

                <div class="form-text mb-3">Indicateurs de connexion (3 états — testables avec les boutons en haut) :</div>
                <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px">
                    <span class="lc-sync-status" data-state="online"><span class="lc-sync-status__dot"></span>En ligne</span>
                    <span class="lc-sync-status" data-state="syncing"><span class="lc-sync-status__dot"></span>Synchronisation… 3/12</span>
                    <span class="lc-sync-status" data-state="offline"><span class="lc-sync-status__dot"></span>Hors ligne — 7 en attente</span>
                </div>

                <div class="form-text mb-2">Multi-devise (tabular-nums alignés) :</div>
                <table class="lc-table" style="border:1px solid var(--border-secondary);border-radius:var(--radius-md)">
                    <tbody>
                        <tr><td>FCFA (XOF)</td><td class="text-end lc-num--strong">1 250 000 <span style="color:var(--text-tertiary)">FCFA</span></td></tr>
                        <tr><td>Équivalent EUR</td><td class="text-end">1 905,93 <span style="color:var(--text-tertiary)">€</span></td></tr>
                        <tr><td>Équivalent USD</td><td class="text-end">2 048,12 <span style="color:var(--text-tertiary)">USD</span></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
