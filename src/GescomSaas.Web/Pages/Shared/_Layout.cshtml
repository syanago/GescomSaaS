@using GescomSaas.Application.Models
@using GescomSaas.Infrastructure.Configuration
@inject GescomSaas.Application.Contracts.IUserPermissionService UserPermissionService
@inject GescomSaas.Application.Contracts.IRuntimeInitializationStateService RuntimeInitializationStateService
@inject Microsoft.Extensions.Options.IOptions<GescomSaas.Infrastructure.Configuration.LigComRuntimeOptions> RuntimeOptionsAccessor
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LigCom</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GescomSaas.Web.styles.css" asp-append-version="true" />
</head>
@{
    var uiSettings = DisplayFormatter.GetSettings();
    var runtimeOptions = RuntimeOptionsAccessor.Value;
    var runtimeState = await RuntimeInitializationStateService.GetStateAsync();
    var permissionKeys = await UserPermissionService.GetCurrentPermissionKeysAsync();
    var currentPage = ViewContext.ActionDescriptor.RouteValues.TryGetValue("page", out var pageValue)
        ? pageValue ?? string.Empty
        : string.Empty;
    var currentTitle = ViewData["Title"]?.ToString() ?? "LigCom";

    bool IsCurrentPage(params string[] prefixes) =>
        prefixes.Any(prefix => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase));

    var canOpenCommercialOperations = permissionKeys.Contains(TenantPermissionKeys.SalesDocumentsManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.PurchasesDocumentsManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.FinanceManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.InventoryManage, StringComparer.OrdinalIgnoreCase);
    var canOpenReferenceData = permissionKeys.Contains(TenantPermissionKeys.ReferencesPartnersManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.ReferencesProductsManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.ReferencesWarehousesManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.ReferencesPricingManage, StringComparer.OrdinalIgnoreCase);
    var canOpenSettings = permissionKeys.Contains(TenantPermissionKeys.SettingsCompanyManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.SettingsNumberingManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.SettingsSageImportManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.SettingsAccessProfilesManage, StringComparer.OrdinalIgnoreCase)
        || permissionKeys.Contains(TenantPermissionKeys.SettingsOfflineSyncManage, StringComparer.OrdinalIgnoreCase);
    var isTenantAdmin = User.IsInRole("PlatformAdmin") || User.IsInRole("TenantOwner");
    var canManageOfflineSync = isTenantAdmin && permissionKeys.Contains(TenantPermissionKeys.SettingsOfflineSyncManage, StringComparer.OrdinalIgnoreCase);

    var cockpitActive = IsCurrentPage("/Index");
    var saasAdminActive = IsCurrentPage("/SaaSAdmin");
    var operationsActive = IsCurrentPage("/CommercialOperations", "/SalesDocuments", "/PurchaseDocuments", "/Finance", "/Inventory", "/StockDocuments");
    var referencesActive = IsCurrentPage("/ReferenceData", "/Partners", "/Products", "/Warehouses", "/PaymentTerms", "/TaxCodes", "/ProductCategories", "/PriceLists");
    var settingsActive = IsCurrentPage("/Settings", "/OfflineBootstrap");
    var blueprintActive = IsCurrentPage("/Blueprint");
    var privacyActive = IsCurrentPage("/Privacy");

    string currentSection = cockpitActive ? "Cockpit"
        : saasAdminActive ? "SaaS Admin"
        : operationsActive ? "Traitements"
        : referencesActive ? "Referentiels"
        : settingsActive ? "Parametres"
        : blueprintActive ? "Architecture"
        : privacyActive ? "Confidentialite"
        : "LigCom";

    var contextShortcuts = new List<(string Label, string Page, bool Active)>();
    var runtimeDisplayMode = runtimeState.RuntimeDisplayMode ?? string.Empty;
    var isLocalNodeActive = string.Equals(runtimeDisplayMode, "LocalNode", StringComparison.OrdinalIgnoreCase);
    var isLocalNodePending = string.Equals(runtimeDisplayMode, "LocalNodePending", StringComparison.OrdinalIgnoreCase);
    var isLocalMode = isLocalNodeActive || isLocalNodePending;
    var canOpenSettingsNavigation = canOpenSettings && (!isLocalMode || isTenantAdmin);
    var modeBadgeLabel = isLocalNodePending
        ? "Base locale a finaliser"
        : isLocalNodeActive
            ? "Base locale active"
            : "Mode connecte";
    var modeHelperLabel = isLocalNodePending
        ? "Terminer l'initialisation"
        : isLocalNodeActive
            ? "Passer en mode connecte"
            : "Configurer la base locale";

    if (saasAdminActive && User.IsInRole("PlatformAdmin"))
    {
        contextShortcuts.Add(("Vue SaaS", "/SaaSAdmin/Index", IsCurrentPage("/SaaSAdmin/Index")));
        contextShortcuts.Add(("Tenants", "/SaaSAdmin/Tenants/Index", IsCurrentPage("/SaaSAdmin/Tenants")));
        contextShortcuts.Add(("Plans", "/SaaSAdmin/Plans/Index", IsCurrentPage("/SaaSAdmin/Plans")));
        contextShortcuts.Add(("Facturation", "/SaaSAdmin/Billing/Index", IsCurrentPage("/SaaSAdmin/Billing")));
    }
    else if (operationsActive)
    {
        if (canOpenCommercialOperations)
        {
            contextShortcuts.Add(("Vue d'ensemble", "/CommercialOperations/Index", IsCurrentPage("/CommercialOperations")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.SalesDocumentsManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Ventes", "/SalesDocuments/Index", IsCurrentPage("/SalesDocuments")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.PurchasesDocumentsManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Achats", "/PurchaseDocuments/Index", IsCurrentPage("/PurchaseDocuments")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.FinanceManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Finances", "/Finance/OpenItems", IsCurrentPage("/Finance")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.InventoryManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Stock", "/Inventory/Index", IsCurrentPage("/Inventory", "/StockDocuments")));
        }
    }
    else if (referencesActive)
    {
        contextShortcuts.Add(("Vue d'ensemble", "/ReferenceData/Index", IsCurrentPage("/ReferenceData")));

        if (permissionKeys.Contains(TenantPermissionKeys.ReferencesPartnersManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Tiers", "/Partners/Index", IsCurrentPage("/Partners")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.ReferencesProductsManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Articles", "/Products/Index", IsCurrentPage("/Products")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.ReferencesWarehousesManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Depots", "/Warehouses/Index", IsCurrentPage("/Warehouses")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.ReferencesPricingManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Tarification", "/PriceLists/Index", IsCurrentPage("/PaymentTerms", "/TaxCodes", "/ProductCategories", "/PriceLists")));
        }
    }
    else if (settingsActive)
    {
        contextShortcuts.Add(("Vue d'ensemble", "/Settings/Index", IsCurrentPage("/Settings/Index")));

        if (permissionKeys.Contains(TenantPermissionKeys.SettingsCompanyManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Societe", "/Settings/Company", IsCurrentPage("/Settings/Company")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.SettingsNumberingManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Numerotation", "/Settings/Numbering", IsCurrentPage("/Settings/Numbering")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.SettingsAccessProfilesManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Profils", "/Settings/AccessProfiles", IsCurrentPage("/Settings/AccessProfiles")));
        }

        if (permissionKeys.Contains(TenantPermissionKeys.SettingsOfflineSyncManage, StringComparer.OrdinalIgnoreCase))
        {
            contextShortcuts.Add(("Base locale et synchronisation", "/Settings/Offline", IsCurrentPage("/Settings/Offline", "/OfflineBootstrap")));
        }
    }
    else
    {
        contextShortcuts.Add(("Cockpit", "/Index", cockpitActive));
        if (canOpenCommercialOperations)
        {
            contextShortcuts.Add(("Traitements", "/CommercialOperations/Index", operationsActive));
        }

        if (canOpenReferenceData)
        {
            contextShortcuts.Add(("Referentiels", "/ReferenceData/Index", referencesActive));
        }

        if (canOpenSettingsNavigation)
        {
            contextShortcuts.Add(("Parametres", "/Settings/Index", settingsActive));
        }
    }
}
<body class="@uiSettings.ThemeCssClass"
      data-tenant-currency-code="@uiSettings.CurrencyCode"
      data-tenant-cash-currency-code="@uiSettings.CashCurrencyCode"
      data-currency-symbol="@uiSettings.CurrencySymbol"
      data-currency-symbol-position="@uiSettings.CurrencySymbolPosition"
      data-money-decimals="@uiSettings.MoneyDecimalPlaces"
      data-money-decimal-separator="@uiSettings.MoneyDecimalSeparator"
      data-money-group-separator="@uiSettings.MoneyGroupSeparator"
      data-quantity-decimals="@uiSettings.QuantityDecimalPlaces"
      data-quantity-decimal-separator="@uiSettings.QuantityDecimalSeparator"
      data-quantity-group-separator="@uiSettings.QuantityGroupSeparator"
      data-server-decimal-separator="@System.Globalization.CultureInfo.CurrentCulture.NumberFormat.NumberDecimalSeparator"
      data-runtime-mode="@runtimeOptions.Mode"
      data-database-provider="@runtimeOptions.DatabaseProvider"
      data-runtime-ready="@runtimeState.IsReady"
      data-runtime-display-mode="@runtimeState.RuntimeDisplayMode">
    <a class="skip-link" href="#main-content">Aller au contenu</a>
    <div class="nav-backdrop" data-nav-backdrop hidden></div>

    <div class="app-shell">
        <header class="topbar">
            <div class="container topbar-shell">
                <div class="topbar-brand-row">
                    <a class="brand-mark brand-shell" asp-area="" asp-page="/Index">
                        <span class="brand-orb">LG</span>
                        <span class="tenant-context">
                            <span class="brand-kicker">ERP SaaS</span>
                            <strong>LigCom</strong>
                            <small>@uiSettings.CompanyName</small>
                        </span>
                    </a>

                    <button type="button"
                            class="topbar-menu-toggle"
                            aria-expanded="false"
                            aria-controls="main-navigation"
                            data-nav-toggle>
                        <span class="topbar-menu-toggle-bar"></span>
                        <span class="topbar-menu-toggle-bar"></span>
                        <span class="topbar-menu-toggle-bar"></span>
                        <span class="topbar-menu-toggle-label">Menu</span>
                    </button>
                </div>

                <nav id="main-navigation" class="main-nav nav-cluster" data-main-nav>
                    <a class="nav-link-shell @(cockpitActive ? "is-active" : null)" asp-area="" asp-page="/Index">Cockpit</a>

                    @if (User.IsInRole("PlatformAdmin"))
                    {
                        <a class="nav-link-shell @(saasAdminActive ? "is-active" : null)" asp-area="" asp-page="/SaaSAdmin/Index">SaaS Admin</a>
                    }

                    @if (canOpenCommercialOperations)
                    {
                        <div class="nav-dropdown @(operationsActive ? "is-active" : null)" data-nav-dropdown>
                            <button type="button" class="nav-dropdown-toggle @(operationsActive ? "is-active" : null)" aria-expanded="false" data-nav-dropdown-toggle>
                                Traitements
                                <span class="nav-dropdown-chevron" aria-hidden="true"></span>
                            </button>
                            <div class="nav-dropdown-menu">
                                <a asp-area="" asp-page="/CommercialOperations/Index">Vue d'ensemble</a>
                                @if (permissionKeys.Contains(TenantPermissionKeys.SalesDocumentsManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/SalesDocuments/Index">Ventes</a>
                                }
                                @if (permissionKeys.Contains(TenantPermissionKeys.PurchasesDocumentsManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/PurchaseDocuments/Index">Achats</a>
                                }
                                @if (permissionKeys.Contains(TenantPermissionKeys.FinanceManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/Finance/OpenItems">Finances</a>
                                }
                                @if (permissionKeys.Contains(TenantPermissionKeys.InventoryManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/Inventory/Index">Stock</a>
                                }
                            </div>
                        </div>
                    }

                    @if (canOpenReferenceData)
                    {
                        <div class="nav-dropdown @(referencesActive ? "is-active" : null)" data-nav-dropdown>
                            <button type="button" class="nav-dropdown-toggle @(referencesActive ? "is-active" : null)" aria-expanded="false" data-nav-dropdown-toggle>
                                Referentiels
                                <span class="nav-dropdown-chevron" aria-hidden="true"></span>
                            </button>
                            <div class="nav-dropdown-menu">
                                <a asp-area="" asp-page="/ReferenceData/Index">Vue d'ensemble</a>
                                @if (permissionKeys.Contains(TenantPermissionKeys.ReferencesPartnersManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/Partners/Index">Tiers</a>
                                }
                                @if (permissionKeys.Contains(TenantPermissionKeys.ReferencesProductsManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/Products/Index">Articles</a>
                                }
                                @if (permissionKeys.Contains(TenantPermissionKeys.ReferencesWarehousesManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/Warehouses/Index">Depots</a>
                                }
                                @if (permissionKeys.Contains(TenantPermissionKeys.ReferencesPricingManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/PaymentTerms/Index">Conditions de paiement</a>
                                    <a asp-area="" asp-page="/TaxCodes/Index">Taxes</a>
                                    <a asp-area="" asp-page="/ProductCategories/Index">Familles</a>
                                    <a asp-area="" asp-page="/PriceLists/Index">Listes de prix</a>
                                }
                            </div>
                        </div>
                    }

                    @if (canOpenSettingsNavigation)
                    {
                        <div class="nav-dropdown @(settingsActive ? "is-active" : null)" data-nav-dropdown>
                            <button type="button" class="nav-dropdown-toggle @(settingsActive ? "is-active" : null)" aria-expanded="false" data-nav-dropdown-toggle>
                                Parametres
                                <span class="nav-dropdown-chevron" aria-hidden="true"></span>
                            </button>
                            <div class="nav-dropdown-menu">
                                <a asp-area="" asp-page="/Settings/Index">Vue d'ensemble</a>
                                @if (permissionKeys.Contains(TenantPermissionKeys.SettingsCompanyManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/Settings/Company">Societe et formats</a>
                                }
                                @if (permissionKeys.Contains(TenantPermissionKeys.SettingsNumberingManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/Settings/Numbering">Numerotation</a>
                                }
                                @if (permissionKeys.Contains(TenantPermissionKeys.SettingsSageImportManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/Settings/SageImport">Import Sage SQL</a>
                                }
                                @if (permissionKeys.Contains(TenantPermissionKeys.SettingsAccessProfilesManage, StringComparer.OrdinalIgnoreCase))
                                {
                                    <a asp-area="" asp-page="/Settings/AccessProfiles">Profils et droits</a>
                                }
                                @if (canManageOfflineSync)
                                {
                                    <a asp-area="" asp-page="/Settings/Offline">Base locale et synchro</a>
                                    <a asp-area="" asp-page="/OfflineBootstrap">Initialiser base locale</a>
                                }
                            </div>
                        </div>
                    }

                    <a class="nav-link-shell @(blueprintActive ? "is-active" : null)" asp-area="" asp-page="/Blueprint">Architecture</a>
                    <a class="nav-link-shell @(privacyActive ? "is-active" : null)" asp-area="" asp-page="/Privacy">Confidentialite</a>
                </nav>

                <div class="auth-actions">
                    <span id="connectivity-indicator"
                          class="context-chip connectivity-chip"
                          data-connectivity-indicator
                          data-runtime-mode="@runtimeOptions.Mode"
                          data-database-provider="@runtimeOptions.DatabaseProvider"
                          data-runtime-ready="@runtimeState.IsReady"
                          data-runtime-display-mode="@runtimeState.RuntimeDisplayMode">
                        <span class="connectivity-dot" aria-hidden="true"></span>
                        <span class="connectivity-label">Verification reseau...</span>
                    </span>
                    <span class="context-chip context-chip-subtle">@uiSettings.ThemeLabel</span>
                    <partial name="_LoginPartial" />
                </div>
            </div>

            <div class="container topbar-subline">
                <div class="topbar-page-context">
                    <span class="eyebrow">Navigation</span>
                    <div class="topbar-page-title-row">
                        <span class="section-badge">@currentSection</span>
                        <strong>@currentTitle</strong>
                    </div>
                </div>

                <div class="topbar-subline-actions">
                    @if (contextShortcuts.Count > 0)
                    {
                        <div class="topbar-shortcuts" aria-label="Acces rapides du module">
                            @foreach (var shortcut in contextShortcuts)
                            {
                                <a class="topbar-shortcut @(shortcut.Active ? "is-active" : null)"
                                   asp-area=""
                                   asp-page="@shortcut.Page">
                                    @shortcut.Label
                                </a>
                            }
                        </div>
                    }

                    @if (canManageOfflineSync)
                    {
                        <div class="topbar-mode-switch" aria-label="Acces rapide au changement de mode">
                            <a class="context-chip topbar-mode-chip @(isLocalMode ? "is-local" : "is-online")"
                               asp-area=""
                               asp-page="/Settings/Offline">
                                <span class="connectivity-dot" aria-hidden="true"></span>
                                <span>@modeBadgeLabel</span>
                            </a>

                            @if (isLocalNodeActive)
                            {
                                <form method="post" asp-page="/Settings/Offline" asp-page-handler="ReturnToConnected" class="inline-form">
                                    <button type="submit" class="btn btn-outline-light btn-sm topbar-mode-button">@modeHelperLabel</button>
                                </form>
                            }
                            else if (isLocalNodePending)
                            {
                                <a class="btn btn-primary-soft btn-sm topbar-mode-button" asp-area="" asp-page="/OfflineBootstrap">@modeHelperLabel</a>
                            }
                            else
                            {
                                <a class="btn btn-primary-soft btn-sm topbar-mode-button" href="/Settings/Offline#activation-panel">@modeHelperLabel</a>
                            }
                        </div>
                    }
                </div>
            </div>
        </header>

        <main id="main-content" class="container page-body app-content-shell">
            @RenderBody()
        </main>

        <footer class="container footer-bar">
            <span>LigCom 2026</span>
            <span>Base de gestion commerciale multi-tenant en ASP.NET Core et SQL Server.</span>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
