@*
    Layout "GescomSaaS-Compta-like" - gabarit identique au screenshot LigFin
    avec palette VERTE remplacant le bleu.

    Structure copiee fidelement du screenshot :
      - Sidebar claire (fond presque blanc) avec border droite
      - Logo carre sombre + texte "GescomSaaS" en haut
      - Sections en MAJUSCULES tres petites
      - Item actif : fond vert pale + border-left vert vif
      - Topbar blanche : breadcrumb a gauche, pill mode + recherche + tenant + avatar a droite
      - Bouton "+ Nouveau document" vert vif (= Nouvelle ecriture du screenshot)
      - Footer sidebar : avatar carre + email + deconnexion en rouge

    Pour activer : mettre dans Pages/_ViewStart.cshtml
        @{ Layout = "_LayoutCompta"; }
*@
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LigCom</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/gescomsaas-ui.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@{
    var isAuth = User.Identity?.IsAuthenticated == true;
}

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="d-flex" style="min-height:100vh">

    @* ══════════════════════════════════════════════════════════════
       SIDEBAR claire (gabarit LigFin)
       ══════════════════════════════════════════════════════════════ *@
    <nav class="sidebar" id="sidebar">

        @* Logo : carre sombre + texte - meme structure que LigFin *@
        <div class="sidebar-logo">
            <div class="sidebar-logo-mark">L</div>
            <span class="sidebar-logo-text">LigCom</span>
        </div>

        <div class="sidebar-scroll">
        <ul class="nav flex-column gap-0" id="sidebarNav">

            @* Tableau de bord (toujours en haut, comme LigFin) *@
            <li class="nav-item">
                <a class="nav-link" asp-page="/Index" title="Tableau de bord">
                    <i class="bi bi-speedometer2"></i><span>Tableau de bord</span>
                </a>
            </li>

            @* ── COMMERCIAL (= COMPTABILITE de LigFin) ─────────────── *@
            <li><div class="nav-section">Commercial</div></li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/SalesDocuments/Index" title="Devis & Factures">
                    <i class="bi bi-file-earmark-text"></i><span>Devis & Factures</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/PurchaseDocuments/Index" title="Achats">
                    <i class="bi bi-cart-plus"></i><span>Commandes & Achats</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/CommercialOperations/Index" title="Operations">
                    <i class="bi bi-graph-up-arrow"></i><span>Operations</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Partners/Index" title="Tiers">
                    <i class="bi bi-people"></i><span>Tiers</span>
                </a>
            </li>

            @* ── CATALOGUE (= CONSULTATION de LigFin) ──────────────── *@
            <li><div class="nav-section">Catalogue</div></li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Products/Index" title="Articles">
                    <i class="bi bi-box-seam"></i><span>Articles</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/ProductCategories/Index" title="Categories">
                    <i class="bi bi-tags"></i><span>Categories</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/PriceLists/Index" title="Listes de prix">
                    <i class="bi bi-currency-euro"></i><span>Listes de prix</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/TaxCodes/Index" title="Codes taxe">
                    <i class="bi bi-percent"></i><span>Codes taxe</span>
                </a>
            </li>

            @* ── STOCK (= FISCAL & CLOTURE de LigFin) ──────────────── *@
            <li><div class="nav-section">Stock</div></li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Inventory/Index" title="Etat du stock">
                    <i class="bi bi-clipboard-data"></i><span>Etat du stock</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/StockDocuments/Index" title="Mouvements">
                    <i class="bi bi-box-arrow-in-down"></i><span>Mouvements</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Warehouses/Index" title="Depots">
                    <i class="bi bi-house-gear"></i><span>Depots</span>
                </a>
            </li>

            @* ── FINANCE (= GESTION de LigFin) ─────────────────────── *@
            <li><div class="nav-section">Finance</div></li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Finance/Index" title="Encaissements">
                    <i class="bi bi-wallet2"></i><span>Encaissements</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/PaymentTerms/Index" title="Conditions de paiement">
                    <i class="bi bi-calendar-check"></i><span>Conditions paiement</span>
                </a>
            </li>

            @* ── ADMINISTRATION (= MESSAGERIE de LigFin) ────────────── *@
            <li><div class="nav-section">Administration</div></li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Invitations/Index" title="Inviter des utilisateurs">
                    <i class="bi bi-person-plus"></i><span>Utilisateurs</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/Settings/Index" title="Parametres">
                    <i class="bi bi-gear"></i><span>Parametres</span>
                </a>
            </li>

            @* ── PLATEFORME (visible uniquement aux admins SaaS) ────── *@
            @if (User.IsInRole("PlatformAdmin"))
            {
            <li><div class="nav-section">Plateforme SaaS</div></li>
            <li class="nav-item">
                <a class="nav-link" asp-page="/SaaSAdmin/Index" title="Gestion plateforme">
                    <i class="bi bi-building"></i><span>Tenants</span>
                </a>
            </li>
            }

        </ul>
        </div>

        @* Footer sidebar : avatar carre + email + deconnexion (cf. screenshot) *@
        <div class="sidebar-footer">
            @if (isAuth)
            {
                <div class="sidebar-user" title="@User.Identity?.Name">
                    <div class="sidebar-avatar" id="sidebarAvatar">?</div>
                    <span class="sidebar-username">@User.Identity?.Name</span>
                </div>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="mt-1">
                    <button type="submit" class="nav-link btn btn-link w-100 text-start text-danger px-2"
                            style="font-size:.78rem; border-radius:7px; font-weight:500;" title="Deconnexion">
                        <i class="bi bi-box-arrow-left" style="color:#dc2626"></i><span> Deconnexion</span>
                    </button>
                </form>
            }
            else
            {
                <a class="nav-link btn btn-link w-100 text-start px-2"
                   asp-area="Identity" asp-page="/Account/Login"
                   style="font-size:.82rem; border-radius:7px; font-weight:500; color:var(--gc-brand-hover)" title="Connexion">
                    <i class="bi bi-box-arrow-in-right" style="color:var(--gc-brand)"></i><span> Connexion</span>
                </a>
            }
        </div>
    </nav>

    @* ══════════════════════════════════════════════════════════════
       CONTENU PRINCIPAL
       ══════════════════════════════════════════════════════════════ *@
    <div class="main-content" id="mainContent">

        @* ── Topbar : breadcrumb a gauche / pill mode + recherche + tenant + avatar a droite ── *@
        <div class="topbar">
            <div class="topbar-left">
                <button class="topbar-hamburger" id="btnHamburger" aria-label="Menu">
                    <i class="bi bi-list"></i>
                </button>

                @if (ViewData["Breadcrumb"] != null)
                {
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">@Html.Raw(ViewData["Breadcrumb"])</ol>
                    </nav>
                }
                else
                {
                    <span class="topbar-title">@ViewData["Title"]</span>
                }
            </div>

            <div class="topbar-right">
                @* Pill "En ligne" / "Hors ligne" (cf. screenshot, en vert) *@
                <span class="mode-pill mode-online" title="Mode connecte">
                    <i class="bi bi-wifi"></i>
                    <span>En ligne</span>
                </span>

                @* Recherche globale Ctrl+K *@
                <button class="topbar-search" id="btnSearch" title="Recherche globale (Ctrl+K)">
                    <i class="bi bi-search"></i>
                    <span>Rechercher…</span>
                    <kbd>Ctrl K</kbd>
                </button>

                @* Tenant courant (= "Exercice 2026" du screenshot, en vert) *@
                <a id="topbarTenant" class="tenant-topbar" asp-page="/Settings/Index" title="Tenant courant">
                    <i class="bi bi-building"></i>
                    <span id="topbarTenantLabel">Tenant…</span>
                    <i class="bi bi-chevron-down" style="font-size:.65rem;opacity:.7"></i>
                </a>

                @* Avatar utilisateur *@
                @if (isAuth)
                {
                    <div class="dropdown">
                        <button class="topbar-btn" data-bs-toggle="dropdown" style="padding:3px;border-radius:8px">
                            <div class="sidebar-avatar" id="topAvatar" style="width:32px;height:32px;font-size:.78rem">?</div>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">@User.Identity?.Name</h6></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" asp-page="/Settings/Index"><i class="bi bi-gear me-2"></i>Parametres</a></li>
                            <li>
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-left me-2"></i>Deconnexion</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Login">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Connexion
                    </a>
                }
            </div>
        </div>

        @* ── Corps de page ─────────────────────────────────────── *@
        <div class="page-body">
            @RenderBody()
        </div>

    </div><!-- /main-content -->
    </div><!-- /d-flex -->

    @* Toasts container *@
    <div class="toast-container" id="toastContainer" aria-live="polite"></div>

    @* Command Palette (Ctrl+K) *@
    <div id="cmdPalette" role="dialog" aria-modal="true" aria-label="Recherche globale">
        <div id="cmdBox">
            <input id="cmdInput" type="text" placeholder="Naviguer, chercher un client, un article…" autocomplete="off" />
            <div id="cmdResults"></div>
            <div id="cmdFooter">
                <span><kbd>↑↓</kbd> Naviguer</span>
                <span><kbd>Enter</kbd> Ouvrir</span>
                <span><kbd>Esc</kbd> Fermer</span>
            </div>
        </div>
    </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
// ── Avatar initiales (sidebar + topbar) ─────────────────────────
(function() {
    const name = '@(User.Identity?.Name ?? "")';
    if (!name) return;
    const parts = name.split(/[\s@@.]/);
    const initials = parts.length >= 2
        ? (parts[0][0] + parts[1][0]).toUpperCase()
        : name.substring(0, 2).toUpperCase();
    document.querySelectorAll('#sidebarAvatar, #topAvatar').forEach(el => el.textContent = initials);
})();

// ── Hamburger mobile ────────────────────────────────────────────
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('sidebarOverlay');
document.getElementById('btnHamburger')?.addEventListener('click', () => {
    sidebar.classList.toggle('sidebar-open');
    overlay.classList.toggle('active');
});
overlay?.addEventListener('click', () => {
    sidebar.classList.remove('sidebar-open');
    overlay.classList.remove('active');
});

// ── Toasts (consomme TempData) ──────────────────────────────────
function showToast(message, type = 'success') {
    const icons = { success: 'check-circle-fill', danger: 'exclamation-triangle-fill', warning: 'exclamation-circle-fill', info: 'info-circle-fill' };
    const labels = { success: 'Succes', danger: 'Erreur', warning: 'Attention', info: 'Info' };
    const id = 'toast_' + Date.now();
    const html = `
    <div id="${id}" class="toast toast-${type} align-items-center show" role="alert" data-bs-delay="4500" data-bs-autohide="true">
        <div class="toast-header">
            <i class="bi bi-${icons[type] || 'info-circle-fill'} me-2"></i>
            <strong class="me-auto">${labels[type] || type}</strong>
            <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body">${message}</div>
    </div>`;
    document.getElementById('toastContainer').insertAdjacentHTML('beforeend', html);
    const toastEl = document.getElementById(id);
    new bootstrap.Toast(toastEl, { delay: 4500 }).show();
    toastEl.addEventListener('hidden.bs.toast', () => toastEl.remove());
}
@{
    var statusMessage = TempData["StatusMessage"]?.ToString();
    if (!string.IsNullOrEmpty(statusMessage))
    {
        var msgType = statusMessage.StartsWith("Error") ? "danger" : "success";
        var msgText = statusMessage.StartsWith("Error:") ? statusMessage.Substring(6).Trim() : statusMessage;
        <text>showToast(@Json.Serialize(msgText), '@msgType');</text>
    }
}

// ── Command Palette (Ctrl+K) ────────────────────────────────────
const cmdPalette = document.getElementById('cmdPalette');
const cmdInput   = document.getElementById('cmdInput');
const cmdResults = document.getElementById('cmdResults');
let cmdIndex = -1;

const NAV_ITEMS = [
    { icon: 'speedometer2',        label: 'Tableau de bord',          url: '/' },
    { icon: 'file-earmark-text',   label: 'Devis & Factures',         url: '/SalesDocuments' },
    { icon: 'cart-plus',           label: 'Commandes & Achats',       url: '/PurchaseDocuments' },
    { icon: 'graph-up-arrow',      label: 'Operations commerciales',  url: '/CommercialOperations' },
    { icon: 'people',              label: 'Tiers',                    url: '/Partners' },
    { icon: 'box-seam',            label: 'Articles',                 url: '/Products' },
    { icon: 'tags',                label: 'Categories',               url: '/ProductCategories' },
    { icon: 'currency-euro',       label: 'Listes de prix',           url: '/PriceLists' },
    { icon: 'percent',             label: 'Codes taxe',               url: '/TaxCodes' },
    { icon: 'clipboard-data',      label: 'Etat du stock',            url: '/Inventory' },
    { icon: 'box-arrow-in-down',   label: 'Mouvements de stock',      url: '/StockDocuments' },
    { icon: 'house-gear',          label: 'Depots',                   url: '/Warehouses' },
    { icon: 'wallet2',             label: 'Encaissements',            url: '/Finance' },
    { icon: 'calendar-check',      label: 'Conditions paiement',      url: '/PaymentTerms' },
    { icon: 'person-plus',         label: 'Inviter un utilisateur',   url: '/Invitations' },
    { icon: 'gear',                label: 'Parametres',               url: '/Settings' },
];

function openCmd() { cmdPalette.classList.add('active'); cmdInput.value = ''; renderCmd(''); cmdInput.focus(); }
function closeCmd() { cmdPalette.classList.remove('active'); }
function renderCmd(q) {
    cmdIndex = -1;
    const filtered = q.trim() === '' ? NAV_ITEMS : NAV_ITEMS.filter(i => i.label.toLowerCase().includes(q.toLowerCase()));
    if (!filtered.length) { cmdResults.innerHTML = '<div class="cmd-item text-muted">Aucun resultat</div>'; return; }
    const section = q.trim() === '' ? '<div class="cmd-section-title">Navigation</div>' : '';
    cmdResults.innerHTML = section + filtered.map((i, idx) =>
        `<div class="cmd-item" data-url="${i.url}" data-idx="${idx}">
            <i class="bi bi-${i.icon}"></i>${i.label}
        </div>`).join('');
    cmdResults.querySelectorAll('.cmd-item[data-url]').forEach(el => {
        el.addEventListener('click', () => { window.location.href = el.dataset.url; closeCmd(); });
    });
}
function cmdMove(dir) {
    const items = cmdResults.querySelectorAll('.cmd-item[data-url]');
    if (!items.length) return;
    items[cmdIndex]?.classList.remove('cmd-active');
    cmdIndex = (cmdIndex + dir + items.length) % items.length;
    items[cmdIndex].classList.add('cmd-active');
    items[cmdIndex].scrollIntoView({ block: 'nearest' });
}
cmdInput?.addEventListener('input', e => renderCmd(e.target.value));
cmdInput?.addEventListener('keydown', e => {
    if (e.key === 'ArrowDown') { e.preventDefault(); cmdMove(1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); cmdMove(-1); }
    else if (e.key === 'Enter') {
        const active = cmdResults.querySelector('.cmd-item.cmd-active');
        if (active?.dataset.url) { window.location.href = active.dataset.url; closeCmd(); }
    }
    else if (e.key === 'Escape') closeCmd();
});
cmdPalette?.addEventListener('click', e => { if (e.target === cmdPalette) closeCmd(); });
document.getElementById('btnSearch')?.addEventListener('click', openCmd);
document.addEventListener('keydown', e => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); openCmd(); }
});

// ── Active link auto en fonction du path ────────────────────────
(function highlightActiveNav() {
    const path = window.location.pathname.toLowerCase();
    let bestMatch = null;
    let bestLen = 0;
    document.querySelectorAll('.sidebar .nav-link[href]').forEach(link => {
        const href = link.getAttribute('href')?.toLowerCase() ?? '';
        if (href === '/' && path === '/') { bestMatch = link; bestLen = 999; }
        else if (href !== '/' && path.startsWith(href) && href.length > bestLen) {
            bestMatch = link;
            bestLen = href.length;
        }
    });
    bestMatch?.classList.add('active');
})();

// ── Tenant courant dans la topbar ───────────────────────────────
(async function loadTenant() {
    try {
        const r = await fetch('/api/v1/context');
        if (!r.ok) return;
        const d = await r.json();
        const lbl = document.getElementById('topbarTenantLabel');
        if (lbl && d?.tenantName) lbl.textContent = d.tenantName;
    } catch { }
})();
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
