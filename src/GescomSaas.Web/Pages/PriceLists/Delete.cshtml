@page "{id:guid}"
@model GescomSaas.Web.Pages.PriceLists.DeleteModel
@{
    ViewData["Title"] = "Supprimer une liste de prix";
    var canDelete = string.IsNullOrWhiteSpace(Model.BlockingReason);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Supprimer @Model.PriceList?.Code</h1>
        <div class="page-header-sub">Suppression d'une liste de prix</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-secondary" asp-page="/PriceLists/Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
    </div>
</div>

@if (!canDelete)
{
    <div class="alert alert-warning mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Suppression bloquee</strong> &mdash; @Model.BlockingReason</div>
}
else
{
    <div class="alert alert-danger mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Attention</strong> &mdash; la liste de prix <strong>@Model.PriceList?.Label</strong> sera supprimee, avec ses @Model.LineCount ligne(s).</div>
}

<div class="card">
    <div class="section-header">
        <i class="bi bi-trash"></i>
        <span>Recapitulatif</span>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="small text-muted">Code</div>
                <div class="fw-semibold">@Model.PriceList?.Code</div>
            </div>
            <div class="col-md-6">
                <div class="small text-muted">Libelle</div>
                <div class="fw-semibold">@Model.PriceList?.Label</div>
            </div>
            <div class="col-md-6">
                <div class="small text-muted">Devise</div>
                <div class="fw-semibold">@Model.PriceList?.CurrencyCode</div>
            </div>
            <div class="col-md-6">
                <div class="small text-muted">Lignes</div>
                <div class="fw-semibold">@Model.LineCount</div>
            </div>
        </div>
        <form method="post" class="d-flex justify-content-end gap-2">
            <a class="btn btn-secondary" asp-page="/PriceLists/Index">Annuler</a>
            @if (canDelete)
            {
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Confirmer la suppression</button>
            }
        </form>
    </div>
</div>
