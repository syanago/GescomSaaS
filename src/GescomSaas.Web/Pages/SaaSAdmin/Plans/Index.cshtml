@page
@model GescomSaas.Web.Pages.SaaSAdmin.Plans.IndexModel
@{
    ViewData["Title"] = "Plans SaaS";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Plateforme</span>
        <h1>Plans SaaS</h1>
        <p class="muted-copy">Maintenez les editions, les limites et la logique d'overage de la plateforme.</p>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/SaaSAdmin/Index">Cockpit</a>
        <a class="btn btn-primary-soft" asp-page="/SaaSAdmin/Plans/Create">Nouveau plan</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="app-alert">@Model.StatusMessage</div>
}

<section class="panel-card">
    <div class="table-shell">
        <table class="table table-darkless align-middle app-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Libelle</th>
                    <th>Edition</th>
                    <th class="text-end">Prix mensuel</th>
                    <th>Utilisateurs</th>
                    <th>Articles</th>
                    <th>Docs/mois</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var plan in Model.Plans)
            {
                <tr>
                    <td>@plan.Code</td>
                    <td>@plan.Label</td>
                    <td>@plan.Edition</td>
                    <td class="text-end">@DisplayFormatter.Money(plan.MonthlyPrice)</td>
                    <td>@plan.MaxUsers</td>
                    <td>@plan.MaxProducts</td>
                    <td>@plan.MaxMonthlyDocuments</td>
                    <td class="text-end action-cell">
                        <a asp-page="/SaaSAdmin/Plans/Edit" asp-route-id="@plan.Id">Editer</a>
                        <a asp-page="/SaaSAdmin/Plans/Delete" asp-route-id="@plan.Id">Supprimer</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
