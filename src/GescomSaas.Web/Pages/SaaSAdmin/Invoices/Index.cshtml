@page
@model GescomSaas.Web.Pages.SaaSAdmin.Invoices.IndexModel
@{
    ViewData["Title"] = "Facturation plateforme";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Facturation plateforme</h1>
        <div class="page-header-sub">Suivez les emissions, les echeances et les reglements des abonnements SaaS.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-secondary" asp-page="/SaaSAdmin/Index"><i class="bi bi-speedometer2 me-1"></i>Cockpit</a>
        <a class="btn btn-secondary" asp-page="/SaaSAdmin/Tenants/Index"><i class="bi bi-building me-1"></i>Tenants</a>
    </div>
</div>

<div class="card">
    <div class="section-header"><i class="bi bi-receipt"></i><span>Factures plateforme</span></div>
    <div class="card-body">
        @if (Model.Invoices.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <h6>Aucune facture</h6>
                <p class="mb-0">Aucune facture plateforme.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Numero</th>
                            <th>Tenant</th>
                            <th>Date</th>
                            <th>Echeance</th>
                            <th>Statut</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var invoice in Model.Invoices)
                    {
                        <tr>
                            <td>@invoice.InvoiceNumber</td>
                            <td>@invoice.TenantName</td>
                            <td>@invoice.IssueDate.ToString("dd/MM/yyyy")</td>
                            <td>@invoice.DueDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge" style="background:var(--gc-pill-green-bg); color:var(--gc-pill-green-fg)">@invoice.Status</span></td>
                            <td class="text-end money">@DisplayFormatter.Money(invoice.TotalIncludingTax, invoice.CurrencyCode)</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a class="btn btn-sm btn-secondary" asp-page="/SaaSAdmin/Invoices/Details" asp-route-id="@invoice.Id" title="Ouvrir"><i class="bi bi-eye"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
