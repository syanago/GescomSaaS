@page
@model GescomSaas.Web.Pages.SaaSAdmin.Invoices.IndexModel
@{
    ViewData["Title"] = "Facturation plateforme";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Plateforme</span>
        <h1>Facturation plateforme</h1>
        <p class="muted-copy">Suivez les emissions, les echeances et les reglements des abonnements SaaS.</p>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/SaaSAdmin/Index">Cockpit</a>
        <a class="btn btn-outline-light" asp-page="/SaaSAdmin/Tenants/Index">Tenants</a>
    </div>
</section>

<section class="panel-card">
    <div class="table-shell">
        <table class="table table-darkless align-middle app-table">
            <thead>
                <tr>
                    <th>Numero</th>
                    <th>Tenant</th>
                    <th>Date</th>
                    <th>Echeance</th>
                    <th>Statut</th>
                    <th class="text-end">Total</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Invoices.Count == 0)
            {
                <tr><td colspan="7" class="empty-cell">Aucune facture plateforme.</td></tr>
            }
            else
            {
                @foreach (var invoice in Model.Invoices)
                {
                    <tr>
                        <td>@invoice.InvoiceNumber</td>
                        <td>@invoice.TenantName</td>
                        <td>@invoice.IssueDate.ToString("dd/MM/yyyy")</td>
                        <td>@invoice.DueDate.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge rounded-pill status-pill">@invoice.Status</span></td>
                        <td class="text-end">@DisplayFormatter.Money(invoice.TotalIncludingTax, invoice.CurrencyCode)</td>
                        <td class="text-end action-cell">
                            <a asp-page="/SaaSAdmin/Invoices/Details" asp-route-id="@invoice.Id">Ouvrir</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
