@page
@{
    Layout = "_LayoutCompta";
    ViewData["Title"] = "Tableau de bord";
}

@*
    Reproduit FIDELEMENT le dashboard LigFin (screenshot)
    avec les memes 8 KPI tiles + chart Produits/Charges + 2 panels droits.
*@

<div class="page-header">
    <div>
        <h1 class="page-header-title">Tableau de bord</h1>
    </div>
    <div>
        <a class="btn btn-primary" asp-page="/SalesDocuments/Index">
            <i class="bi bi-plus-lg me-1"></i>Nouveau document
        </a>
    </div>
</div>

@* ── KPI tiles : 4 sur la 1ere ligne, 4 sur la 2eme (= LigFin) ── *@
<div class="row g-3 mb-3">
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-card-icon stat-icon-amber"><i class="bi bi-bank"></i></div>
            <div class="stat-card-body">
                <div class="stat-card-label">Tresorerie</div>
                <div class="stat-card-value stat-value-neg">-156 269 421 FCFA</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-card-icon stat-icon-rose"><i class="bi bi-pie-chart"></i></div>
            <div class="stat-card-body">
                <div class="stat-card-label">Resultat exercice</div>
                <div class="stat-card-value stat-value-neg">-141 937 021 FCFA</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-card-icon stat-icon-blue"><i class="bi bi-graph-up"></i></div>
            <div class="stat-card-body">
                <div class="stat-card-label">Produits (exercice)</div>
                <div class="stat-card-value">1 012 377 269 FCFA</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-card-icon stat-icon-rose"><i class="bi bi-graph-down"></i></div>
            <div class="stat-card-body">
                <div class="stat-card-label">Charges (exercice)</div>
                <div class="stat-card-value">1 154 314 290 FCFA</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-card-body">
                <div class="stat-card-label">Creances clients</div>
                <div class="stat-card-value stat-value-pos">1 040 217 392 FCFA</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-card-body">
                <div class="stat-card-label">Dettes fournisseurs</div>
                <div class="stat-card-value stat-value-neg">1 106 900 201 FCFA</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-card-body">
                <div class="stat-card-label">Brouillons</div>
                <div class="stat-card-value stat-value-pos">0</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-card-body">
                <div class="stat-card-label">TVA a payer</div>
                <div class="stat-card-value stat-value-pos">0 FCFA</div>
            </div>
        </div>
    </div>
</div>

@* ── Graphique evolution + 2 panels droits (= LigFin) ── *@
<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="section-header">
                <i class="bi bi-bar-chart"></i>
                <span>Evolution mensuelle - Produits / Charges</span>
            </div>
            <div class="card-body">
                <canvas id="chartMonthly" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4 d-flex flex-column gap-3">
        <div class="card">
            <div class="section-header" style="color:#b45309">
                <i class="bi bi-exclamation-circle"></i>
                <span>A traiter</span>
            </div>
            <div class="empty-state">
                <i class="bi bi-check-circle-fill empty-icon"></i>
                <p class="mb-0">Tout est en ordre</p>
            </div>
        </div>
        <div class="card">
            <div class="section-header" style="color:#b45309">
                <i class="bi bi-arrow-up-right-circle"></i>
                <span>Top charges</span>
            </div>
            <div class="empty-state">
                <p class="mb-0">Aucune charge enregistree.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
    (function() {
        const ctx = document.getElementById('chartMonthly');
        if (!ctx) return;
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Jan','Fev','Mar','Avr','Mai','Jun','Jul','Aou','Sep','Oct','Nov','Dec'],
                datasets: [
                    {
                        label: 'Produits',
                        data: [980000000, 0, 30000000, 0, 0, 0, 0, 0, 0, 0, 0, 0],
                        backgroundColor: 'rgba(96,165,250,.85)',  // blue-400, comme LigFin
                        borderRadius: 4,
                        maxBarThickness: 36
                    },
                    {
                        label: 'Charges',
                        data: [50000000, 920000000, 90000000, 30000000, 0, 0, 0, 0, 0, 0, 0, 0],
                        backgroundColor: 'rgba(252,165,165,.85)',  // red-300/saumon, comme LigFin
                        borderRadius: 4,
                        maxBarThickness: 36
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 10, boxHeight: 10, padding: 14, font: { size: 12 } } }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(0,0,0,.05)' },
                        ticks: { font: { size: 11 }, callback: v => v.toLocaleString('fr-FR') }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 11 } }
                    }
                }
            }
        });
    })();
    </script>
}
