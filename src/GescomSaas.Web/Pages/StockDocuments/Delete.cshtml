@page "{id:guid}"
@model GescomSaas.Web.Pages.StockDocuments.DeleteModel
@{
    ViewData["Title"] = "Supprimer un document de stock";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Stock</span>
        <h1>Supprimer @Model.Document!.Number</h1>
        <p class="muted-copy">Cette action est reservee aux documents de stock en brouillon.</p>
    </div>
</section>

<section class="panel-card">
    <dl class="details-grid">
        <div><dt>Numero</dt><dd>@Model.Document.Number</dd></div>
        <div><dt>Type</dt><dd>@GescomSaas.Web.Pages.StockDocuments.StockDocumentCatalog.Label(Model.Document.DocumentType)</dd></div>
        <div><dt>Statut</dt><dd>@Model.Document.Status</dd></div>
        <div><dt>Date</dt><dd>@Model.Document.DocumentDate.ToString("dd/MM/yyyy")</dd></div>
    </dl>

    <form method="post" class="form-actions">
        <button type="submit" class="btn btn-danger">Supprimer</button>
        <a class="btn btn-outline-light" asp-page="/StockDocuments/Details" asp-route-id="@Model.Document.Id">Annuler</a>
    </form>
</section>
