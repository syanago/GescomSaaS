@page "{id:guid}"
@model GescomSaas.Web.Pages.StockDocuments.DeleteModel
@{
    ViewData["Title"] = "Supprimer un document de stock";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Supprimer @Model.Document!.Number</h1>
        <div class="page-header-sub">Action reservee aux documents en brouillon</div>
    </div>
    <div>
        <a class="btn btn-secondary" asp-page="/StockDocuments/Details" asp-route-id="@Model.Document.Id">
            <i class="bi bi-arrow-left me-1"></i>Annuler
        </a>
    </div>
</div>

<div class="alert alert-danger mb-3">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <strong>Attention</strong> — cette action est definitive. Le document sera supprime de la base de donnees.
</div>

<div class="card">
    <div class="section-header">
        <i class="bi bi-trash"></i>
        <span>Confirmer la suppression</span>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="small text-muted">Numero</div>
                <div class="fw-semibold">@Model.Document.Number</div>
            </div>
            <div class="col-md-6">
                <div class="small text-muted">Type</div>
                <div class="fw-semibold">@GescomSaas.Web.Pages.StockDocuments.StockDocumentCatalog.Label(Model.Document.DocumentType)</div>
            </div>
            <div class="col-md-6">
                <div class="small text-muted">Statut</div>
                <div><span class="badge doc-status-@Model.Document.Status.ToString().ToLowerInvariant()">@Model.Document.Status</span></div>
            </div>
            <div class="col-md-6">
                <div class="small text-muted">Date</div>
                <div class="fw-semibold">@Model.Document.DocumentDate.ToString("dd/MM/yyyy")</div>
            </div>
        </div>

        <form method="post" class="d-flex justify-content-end gap-2">
            <a class="btn btn-secondary" asp-page="/StockDocuments/Details" asp-route-id="@Model.Document.Id">Annuler</a>
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i>Supprimer definitivement
            </button>
        </form>
    </div>
</div>
