@page
@model GescomSaas.Web.Pages.StockDocuments.CreateModel
@{
    ViewData["Title"] = "Nouveau document de stock";
    var docLabel = GescomSaas.Web.Pages.StockDocuments.StockDocumentCatalog.Label(Model.CurrentType).ToLowerInvariant();
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Nouveau @docLabel</h1>
        <div class="page-header-sub">Cree d'abord l'en-tete du document, puis ajoute les lignes d'article sur l'ecran suivant</div>
    </div>
    <div>
        <a class="btn btn-secondary" asp-page="/StockDocuments/Index" asp-route-type="@Model.CurrentType">
            <i class="bi bi-arrow-left me-1"></i>Retour a la liste
        </a>
    </div>
</div>

@* Onglets de types *@
<ul class="nav nav-pills mb-3 flex-wrap">
    @foreach (var type in Enum.GetValues<GescomSaas.Domain.Enums.StockDocumentType>())
    {
        var isActive = type == Model.CurrentType;
        <li class="nav-item">
            <a class="nav-link @(isActive ? "active" : "")" asp-page="/StockDocuments/Create" asp-route-type="@type">
                @GescomSaas.Web.Pages.StockDocuments.StockDocumentCatalog.ShortLabel(type)
            </a>
        </li>
    }
</ul>

@if (Model.DocumentQuota is not null)
{
    var quotaExceeded = Model.DocumentQuota.IsExceeded;
    <div class="alert @(quotaExceeded ? "alert-danger" : "alert-info") mb-3">
        <i class="bi bi-speedometer2 me-2"></i>
        <strong>Documents du mois</strong> : @Model.DocumentQuota.Used / @Model.DocumentQuota.Limit
    </div>
}

<div class="card">
    <div class="section-header">
        <i class="bi bi-file-earmark-plus"></i>
        <span>Informations du document</span>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.Number" class="form-label"></label>
                    <input asp-for="Input.Number" class="form-control" readonly />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.DocumentDate" class="form-label"></label>
                    <input asp-for="Input.DocumentDate" class="form-control" />
                </div>

                @if (Model.UsesSourceWarehouse)
                {
                    <div class="col-md-6">
                        <label asp-for="Input.SourceWarehouseId" class="form-label"></label>
                        <select asp-for="Input.SourceWarehouseId" asp-items="Model.Warehouses" class="form-select">
                            <option value="">Choisir un depot</option>
                        </select>
                        <span asp-validation-for="Input.SourceWarehouseId" class="text-danger small"></span>
                    </div>
                }
                @if (Model.UsesDestinationWarehouse)
                {
                    <div class="col-md-6">
                        <label asp-for="Input.DestinationWarehouseId" class="form-label"></label>
                        <select asp-for="Input.DestinationWarehouseId" asp-items="Model.Warehouses" class="form-select">
                            <option value="">Choisir un depot</option>
                        </select>
                        <span asp-validation-for="Input.DestinationWarehouseId" class="text-danger small"></span>
                    </div>
                }

                <div class="col-12">
                    <label asp-for="Input.Notes" class="form-label"></label>
                    <textarea asp-for="Input.Notes" rows="3" class="form-control"></textarea>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <a class="btn btn-secondary" asp-page="/StockDocuments/Index" asp-route-type="@Model.CurrentType">Annuler</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>Creer le document
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
