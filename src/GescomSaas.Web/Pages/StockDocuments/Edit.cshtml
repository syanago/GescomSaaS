@page "{id:guid}"
@model GescomSaas.Web.Pages.StockDocuments.EditModel
@{
    ViewData["Title"] = "Modifier un document de stock";
}

<section class="page-header-card">
    <div>
        <span class="eyebrow">Edition</span>
        <h1>@GescomSaas.Web.Pages.StockDocuments.StockDocumentCatalog.Label(Model.CurrentType) @Model.Input.Number</h1>
    </div>
    <div class="header-actions">
        <a class="btn btn-outline-light" asp-page="/StockDocuments/Details" asp-route-id="@Model.Id">Voir le detail</a>
        <a class="btn btn-outline-light" asp-page="/StockDocuments/Index" asp-route-type="@Model.CurrentType">Retour a la liste</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="app-alert">@Model.StatusMessage</div>
}

<section class="content-grid blueprint-grid">
    <article class="panel-card">
        <div class="panel-header">
            <div>
                <span class="eyebrow">Entete</span>
                <h2>Informations du document</h2>
            </div>
        </div>
        <form method="post" asp-route-id="@Model.Id" class="stack-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-grid">
                <div><label asp-for="Input.Number" class="form-label"></label><input asp-for="Input.Number" class="form-control" readonly /></div>
                <div><label asp-for="Input.Status" class="form-label"></label><input value="@Model.Input.Status" class="form-control" readonly /></div>
                @if (Model.IsPosted)
                {
                    <div><label asp-for="Input.DocumentDate" class="form-label"></label><input asp-for="Input.DocumentDate" class="form-control" readonly /></div>
                }
                else
                {
                    <div><label asp-for="Input.DocumentDate" class="form-label"></label><input asp-for="Input.DocumentDate" class="form-control" /></div>
                }
                @if (Model.UsesSourceWarehouse)
                {
                    <div><label asp-for="Input.SourceWarehouseId" class="form-label"></label><select asp-for="Input.SourceWarehouseId" asp-items="Model.Warehouses" class="form-select" disabled="@Model.IsPosted"><option value="">Choisir un depot</option></select></div>
                }
                @if (Model.UsesDestinationWarehouse)
                {
                    <div><label asp-for="Input.DestinationWarehouseId" class="form-label"></label><select asp-for="Input.DestinationWarehouseId" asp-items="Model.Warehouses" class="form-select" disabled="@Model.IsPosted"><option value="">Choisir un depot</option></select></div>
                }
                @if (Model.IsPosted)
                {
                    <div class="full-span"><label asp-for="Input.Notes" class="form-label"></label><textarea asp-for="Input.Notes" rows="4" class="form-control" readonly></textarea></div>
                }
                else
                {
                    <div class="full-span"><label asp-for="Input.Notes" class="form-label"></label><textarea asp-for="Input.Notes" rows="4" class="form-control"></textarea></div>
                }
            </div>
            @if (!Model.IsPosted)
            {
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary-soft">Mettre a jour</button>
                </div>
            }
        </form>
    </article>

    <article class="panel-card">
        <div class="panel-header">
            <div>
                <span class="eyebrow">Nouvelle ligne</span>
                <h2>Ajouter un article</h2>
            </div>
        </div>
        @if (Model.IsPosted)
        {
            <div class="app-alert">Le document est valide. Les lignes ne sont plus modifiables.</div>
        }
        else
        {
            <form method="post" asp-page-handler="AddLine" asp-route-id="@Model.Id" class="stack-form" data-stock-tracking-form data-stock-tracking-source-id="stock-document-line-tracking-data" data-require-serialized-batch="@(Model.RequiresSerializedOutputs ? "true" : "false")">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-grid">
                    <div class="full-span"><label asp-for="NewLine.ProductId" class="form-label"></label><select asp-for="NewLine.ProductId" asp-items="Model.Products" class="form-select" data-stock-tracking-select><option value="">Choisir un article</option></select><span asp-validation-for="NewLine.ProductId" class="text-danger"></span></div>
                    <div class="full-span"><label asp-for="NewLine.Description" class="form-label"></label><input asp-for="NewLine.Description" class="form-control" data-stock-product-description /><span asp-validation-for="NewLine.Description" class="text-danger"></span></div>
                    <div>
                        <label asp-for="NewLine.Quantity" class="form-label"></label>
                        <input asp-for="NewLine.Quantity" type="hidden" />
                        <input type="text" id="NewLine_Quantity_display" value="@DisplayFormatter.QuantityEditor(Model.NewLine.Quantity)" class="form-control" inputmode="decimal" data-format-kind="quantity" data-format-target="NewLine_Quantity" data-stock-tracking-quantity />
                        <div class="table-meta" data-format-preview-for="NewLine_Quantity_display">Rendu : @DisplayFormatter.Quantity(Model.NewLine.Quantity)</div>
                        <div class="table-meta" data-stock-tracking-quantity-hint></div>
                        <span asp-validation-for="NewLine.Quantity" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="NewLine.UnitCost" class="form-label"></label>
                        <input asp-for="NewLine.UnitCost" type="hidden" />
                        <input type="text" id="NewLine_UnitCost_display" value="@DisplayFormatter.MoneyEditor(Model.NewLine.UnitCost)" class="form-control" inputmode="decimal" data-format-kind="money" data-format-target="NewLine_UnitCost" data-stock-product-cost />
                        <div class="table-meta" data-format-preview-for="NewLine_UnitCost_display">Rendu : @DisplayFormatter.Money(Model.NewLine.UnitCost)</div>
                        <span asp-validation-for="NewLine.UnitCost" class="text-danger"></span>
                    </div>
                    <div class="full-span table-meta" data-stock-tracking-hint></div>
                    <div data-stock-tracking-field="lot"><label asp-for="NewLine.LotNumber" class="form-label"></label><input asp-for="NewLine.LotNumber" class="form-control" /><span asp-validation-for="NewLine.LotNumber" class="text-danger"></span></div>
                    @if (Model.RequiresSerializedOutputs)
                    {
                        <div><label asp-for="NewLine.LotEntryMode" class="form-label"></label><select asp-for="NewLine.LotEntryMode" asp-items="Model.LotEntryModes" class="form-select" data-lot-entry-mode></select></div>
                        <div class="full-span"><label asp-for="NewLine.LotBreakdown" class="form-label"></label><textarea asp-for="NewLine.LotBreakdown" rows="4" class="form-control" placeholder="Exemple : LOTA;2&#10;LOTB;3"></textarea><div class="table-meta">Repartition : une ligne par lot au format LOT;QUANTITE.</div><span asp-validation-for="NewLine.LotBreakdown" class="text-danger"></span></div>
                    }
                    else
                    {
                        <div data-stock-tracking-field="lot-batch-mode"><label asp-for="NewLine.LotEntryMode" class="form-label"></label><select asp-for="NewLine.LotEntryMode" asp-items="Model.LotEntryModes" class="form-select" data-lot-entry-mode></select></div>
                        <div class="full-span" data-stock-tracking-field="lot-batch-list"><label asp-for="NewLine.LotBreakdown" class="form-label"></label><textarea asp-for="NewLine.LotBreakdown" rows="4" class="form-control" placeholder="Exemple : LOTA;2&#10;LOTB;3"></textarea><div class="table-meta">Repartition : une ligne par lot au format LOT;QUANTITE.</div><span asp-validation-for="NewLine.LotBreakdown" class="text-danger"></span></div>
                    }
                    <div data-stock-tracking-field="serial"><label asp-for="NewLine.SerialNumber" class="form-label"></label><input asp-for="NewLine.SerialNumber" class="form-control" /><span asp-validation-for="NewLine.SerialNumber" class="text-danger"></span></div>
                    @if (Model.RequiresSerializedOutputs)
                    {
                        <div><label asp-for="NewLine.SerialEntryMode" class="form-label"></label><select asp-for="NewLine.SerialEntryMode" asp-items="Model.SerialEntryModes" class="form-select" data-serial-entry-mode></select></div>
                        <div class="full-span"><label asp-for="NewLine.SerialNumberList" class="form-label"></label><textarea asp-for="NewLine.SerialNumberList" rows="4" class="form-control" placeholder="Exemple : SN0001, SN0002, SN0003"></textarea><div class="table-meta">Enumeration : un numero par ligne, ou separes par virgule / point-virgule.</div><span asp-validation-for="NewLine.SerialNumberList" class="text-danger"></span></div>
                        <div><label asp-for="NewLine.SerialRangeStart" class="form-label"></label><input asp-for="NewLine.SerialRangeStart" class="form-control" placeholder="Exemple : SN0001" /><span asp-validation-for="NewLine.SerialRangeStart" class="text-danger"></span></div>
                        <div><label asp-for="NewLine.SerialRangeEnd" class="form-label"></label><input asp-for="NewLine.SerialRangeEnd" class="form-control" placeholder="Exemple : SN0005" /><span asp-validation-for="NewLine.SerialRangeEnd" class="text-danger"></span></div>
                    }
                    else
                    {
                        <div data-stock-tracking-field="serial-batch-mode"><label asp-for="NewLine.SerialEntryMode" class="form-label"></label><select asp-for="NewLine.SerialEntryMode" asp-items="Model.SerialEntryModes" class="form-select" data-serial-entry-mode></select></div>
                        <div class="full-span" data-stock-tracking-field="serial-batch-list"><label asp-for="NewLine.SerialNumberList" class="form-label"></label><textarea asp-for="NewLine.SerialNumberList" rows="4" class="form-control" placeholder="Exemple : SN0001, SN0002, SN0003"></textarea><div class="table-meta">Saisis un numero par ligne, ou separe-les par virgule ou point-virgule.</div><span asp-validation-for="NewLine.SerialNumberList" class="text-danger"></span></div>
                        <div data-stock-tracking-field="serial-batch-start"><label asp-for="NewLine.SerialRangeStart" class="form-label"></label><input asp-for="NewLine.SerialRangeStart" class="form-control" placeholder="Exemple : SN0001" /><span asp-validation-for="NewLine.SerialRangeStart" class="text-danger"></span></div>
                        <div data-stock-tracking-field="serial-batch-end"><label asp-for="NewLine.SerialRangeEnd" class="form-label"></label><input asp-for="NewLine.SerialRangeEnd" class="form-control" placeholder="Exemple : SN0005" /><span asp-validation-for="NewLine.SerialRangeEnd" class="text-danger"></span></div>
                    }
                    <div data-stock-tracking-field="expiration"><label asp-for="NewLine.ExpirationDate" class="form-label"></label><input asp-for="NewLine.ExpirationDate" class="form-control" /></div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary-soft">Ajouter la ligne</button>
                </div>
            </form>
        }
    </article>
</section>

<section class="panel-card">
    <div class="panel-header">
        <div>
            <span class="eyebrow">Lignes</span>
            <h2>Contenu du document</h2>
        </div>
    </div>
    <div class="table-shell">
        <table class="table table-darkless align-middle app-table">
            <thead>
                <tr>
                    <th>Article</th>
                    <th>Description</th>
                    <th class="text-end">Qte</th>
                    <th class="text-end">Cout</th>
                    <th>Lot / Serie</th>
                    <th>Peremption</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Lines.Count == 0)
            {
                <tr><td colspan="7" class="empty-cell">Aucune ligne dans ce document.</td></tr>
            }
            else
            {
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.ProductCode</td>
                        <td>@line.Description</td>
                        <td class="text-end">@DisplayFormatter.Quantity(line.Quantity)</td>
                        <td class="text-end">@DisplayFormatter.Money(line.UnitCost)</td>
                        <td>@(line.LotNumber ?? line.SerialNumber ?? "-")</td>
                        <td>@(line.ExpirationDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td class="text-end">
                            @if (!Model.IsPosted)
                            {
                                <form method="post" asp-page-handler="DeleteLine" asp-route-id="@Model.Id" class="inline-form">
                                    <input type="hidden" name="lineId" value="@line.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-light">Supprimer</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script id="stock-document-line-tracking-data" type="application/json">@Html.Raw(Model.ProductTrackingMetadataJson)</script>
    <partial name="_ValidationScriptsPartial" />
}
