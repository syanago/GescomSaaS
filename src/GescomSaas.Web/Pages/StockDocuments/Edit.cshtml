@page "{id:guid}"
@model GescomSaas.Web.Pages.StockDocuments.EditModel
@{
    ViewData["Title"] = "Modifier un document de stock";
    var docLabel = GescomSaas.Web.Pages.StockDocuments.StockDocumentCatalog.Label(Model.CurrentType);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">@docLabel @Model.Input.Number</h1>
        <div class="page-header-sub">
            <span class="badge doc-status-@Model.Input.Status.ToString().ToLowerInvariant()">@Model.Input.Status</span>
            <span class="ms-2">· @Model.Lines.Count ligne(s)</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-secondary" asp-page="/StockDocuments/Details" asp-route-id="@Model.Id">
            <i class="bi bi-eye me-1"></i>Voir le detail
        </a>
        <a class="btn btn-secondary" asp-page="/StockDocuments/Index" asp-route-type="@Model.CurrentType">
            <i class="bi bi-arrow-left me-1"></i>Retour a la liste
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage
    </div>
}

<div class="row g-3">

    @* En-tete *@
    <div class="col-lg-6">
        <div class="card">
            <div class="section-header">
                <i class="bi bi-file-earmark-text"></i>
                <span>Informations du document</span>
            </div>
            <div class="card-body">
                <form method="post" asp-route-id="@Model.Id">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.Number" class="form-label"></label>
                            <input asp-for="Input.Number" class="form-control" readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Status" class="form-label"></label>
                            <input value="@Model.Input.Status" class="form-control" readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.DocumentDate" class="form-label"></label>
                            <input asp-for="Input.DocumentDate" class="form-control" readonly="@Model.IsPosted" />
                        </div>
                        @if (Model.UsesSourceWarehouse)
                        {
                            <div class="col-md-6">
                                <label asp-for="Input.SourceWarehouseId" class="form-label"></label>
                                <select asp-for="Input.SourceWarehouseId" asp-items="Model.Warehouses" class="form-select" disabled="@Model.IsPosted">
                                    <option value="">Choisir un depot</option>
                                </select>
                            </div>
                        }
                        @if (Model.UsesDestinationWarehouse)
                        {
                            <div class="col-md-6">
                                <label asp-for="Input.DestinationWarehouseId" class="form-label"></label>
                                <select asp-for="Input.DestinationWarehouseId" asp-items="Model.Warehouses" class="form-select" disabled="@Model.IsPosted">
                                    <option value="">Choisir un depot</option>
                                </select>
                            </div>
                        }
                        <div class="col-12">
                            <label asp-for="Input.Notes" class="form-label"></label>
                            <textarea asp-for="Input.Notes" rows="3" class="form-control" readonly="@Model.IsPosted"></textarea>
                        </div>
                    </div>
                    @if (!Model.IsPosted)
                    {
                        <div class="d-flex justify-content-end mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>Mettre a jour
                            </button>
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>

    @* Saisie nouvelle ligne *@
    <div class="col-lg-6">
        <div class="card">
            <div class="section-header">
                <i class="bi bi-plus-square"></i>
                <span>Ajouter un article</span>
            </div>
            <div class="card-body">
                @if (Model.IsPosted)
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Le document est valide. Les lignes ne sont plus modifiables.
                    </div>
                }
                else
                {
                    <form method="post" asp-page-handler="AddLine" asp-route-id="@Model.Id"
                          data-stock-tracking-form
                          data-stock-tracking-source-id="stock-document-line-tracking-data"
                          data-require-serialized-batch="@(Model.RequiresSerializedOutputs ? "true" : "false")">
                        <div asp-validation-summary="All" class="alert alert-danger"></div>
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="NewLine.ProductId" class="form-label"></label>
                                <select asp-for="NewLine.ProductId" asp-items="Model.Products" class="form-select" data-stock-tracking-select>
                                    <option value="">Choisir un article</option>
                                </select>
                                <span asp-validation-for="NewLine.ProductId" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="NewLine.Description" class="form-label"></label>
                                <input asp-for="NewLine.Description" class="form-control" data-stock-product-description />
                                <span asp-validation-for="NewLine.Description" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewLine.Quantity" class="form-label"></label>
                                <input asp-for="NewLine.Quantity" type="hidden" />
                                <input type="text" id="NewLine_Quantity_display" value="@DisplayFormatter.QuantityEditor(Model.NewLine.Quantity)" class="form-control money" inputmode="decimal" data-format-kind="quantity" data-format-target="NewLine_Quantity" data-stock-tracking-quantity />
                                <div class="form-text" data-format-preview-for="NewLine_Quantity_display">Rendu : @DisplayFormatter.Quantity(Model.NewLine.Quantity)</div>
                                <div class="form-text" data-stock-tracking-quantity-hint></div>
                                <span asp-validation-for="NewLine.Quantity" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewLine.UnitCost" class="form-label"></label>
                                <input asp-for="NewLine.UnitCost" type="hidden" />
                                <input type="text" id="NewLine_UnitCost_display" value="@DisplayFormatter.MoneyEditor(Model.NewLine.UnitCost)" class="form-control money" inputmode="decimal" data-format-kind="money" data-format-target="NewLine_UnitCost" data-stock-product-cost />
                                <div class="form-text" data-format-preview-for="NewLine_UnitCost_display">Rendu : @DisplayFormatter.Money(Model.NewLine.UnitCost)</div>
                                <span asp-validation-for="NewLine.UnitCost" class="text-danger small"></span>
                            </div>

                            <div class="col-12 form-text" data-stock-tracking-hint></div>

                            <div class="col-md-6" data-stock-tracking-field="lot">
                                <label asp-for="NewLine.LotNumber" class="form-label"></label>
                                <input asp-for="NewLine.LotNumber" class="form-control" />
                                <span asp-validation-for="NewLine.LotNumber" class="text-danger small"></span>
                            </div>
                            @if (Model.RequiresSerializedOutputs)
                            {
                                <div class="col-md-6">
                                    <label asp-for="NewLine.LotEntryMode" class="form-label"></label>
                                    <select asp-for="NewLine.LotEntryMode" asp-items="Model.LotEntryModes" class="form-select" data-lot-entry-mode></select>
                                </div>
                                <div class="col-12">
                                    <label asp-for="NewLine.LotBreakdown" class="form-label"></label>
                                    <textarea asp-for="NewLine.LotBreakdown" rows="3" class="form-control" placeholder="Exemple : LOTA;2&#10;LOTB;3"></textarea>
                                    <div class="form-text">Repartition : une ligne par lot au format LOT;QUANTITE.</div>
                                    <span asp-validation-for="NewLine.LotBreakdown" class="text-danger small"></span>
                                </div>
                            }
                            else
                            {
                                <div class="col-md-6" data-stock-tracking-field="lot-batch-mode">
                                    <label asp-for="NewLine.LotEntryMode" class="form-label"></label>
                                    <select asp-for="NewLine.LotEntryMode" asp-items="Model.LotEntryModes" class="form-select" data-lot-entry-mode></select>
                                </div>
                                <div class="col-12" data-stock-tracking-field="lot-batch-list">
                                    <label asp-for="NewLine.LotBreakdown" class="form-label"></label>
                                    <textarea asp-for="NewLine.LotBreakdown" rows="3" class="form-control" placeholder="Exemple : LOTA;2&#10;LOTB;3"></textarea>
                                    <div class="form-text">Repartition : une ligne par lot au format LOT;QUANTITE.</div>
                                    <span asp-validation-for="NewLine.LotBreakdown" class="text-danger small"></span>
                                </div>
                            }

                            <div class="col-md-6" data-stock-tracking-field="serial">
                                <label asp-for="NewLine.SerialNumber" class="form-label"></label>
                                <input asp-for="NewLine.SerialNumber" class="form-control" />
                                <span asp-validation-for="NewLine.SerialNumber" class="text-danger small"></span>
                            </div>
                            @if (Model.RequiresSerializedOutputs)
                            {
                                <div class="col-md-6">
                                    <label asp-for="NewLine.SerialEntryMode" class="form-label"></label>
                                    <select asp-for="NewLine.SerialEntryMode" asp-items="Model.SerialEntryModes" class="form-select" data-serial-entry-mode></select>
                                </div>
                                <div class="col-12">
                                    <label asp-for="NewLine.SerialNumberList" class="form-label"></label>
                                    <textarea asp-for="NewLine.SerialNumberList" rows="3" class="form-control" placeholder="Exemple : SN0001, SN0002, SN0003"></textarea>
                                    <div class="form-text">Enumeration : un numero par ligne, ou separes par virgule / point-virgule.</div>
                                    <span asp-validation-for="NewLine.SerialNumberList" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="NewLine.SerialRangeStart" class="form-label"></label>
                                    <input asp-for="NewLine.SerialRangeStart" class="form-control" placeholder="Exemple : SN0001" />
                                    <span asp-validation-for="NewLine.SerialRangeStart" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="NewLine.SerialRangeEnd" class="form-label"></label>
                                    <input asp-for="NewLine.SerialRangeEnd" class="form-control" placeholder="Exemple : SN0005" />
                                    <span asp-validation-for="NewLine.SerialRangeEnd" class="text-danger small"></span>
                                </div>
                            }
                            else
                            {
                                <div class="col-md-6" data-stock-tracking-field="serial-batch-mode">
                                    <label asp-for="NewLine.SerialEntryMode" class="form-label"></label>
                                    <select asp-for="NewLine.SerialEntryMode" asp-items="Model.SerialEntryModes" class="form-select" data-serial-entry-mode></select>
                                </div>
                                <div class="col-12" data-stock-tracking-field="serial-batch-list">
                                    <label asp-for="NewLine.SerialNumberList" class="form-label"></label>
                                    <textarea asp-for="NewLine.SerialNumberList" rows="3" class="form-control" placeholder="Exemple : SN0001, SN0002, SN0003"></textarea>
                                    <div class="form-text">Saisis un numero par ligne, ou separe-les par virgule ou point-virgule.</div>
                                    <span asp-validation-for="NewLine.SerialNumberList" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6" data-stock-tracking-field="serial-batch-start">
                                    <label asp-for="NewLine.SerialRangeStart" class="form-label"></label>
                                    <input asp-for="NewLine.SerialRangeStart" class="form-control" placeholder="Exemple : SN0001" />
                                    <span asp-validation-for="NewLine.SerialRangeStart" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6" data-stock-tracking-field="serial-batch-end">
                                    <label asp-for="NewLine.SerialRangeEnd" class="form-label"></label>
                                    <input asp-for="NewLine.SerialRangeEnd" class="form-control" placeholder="Exemple : SN0005" />
                                    <span asp-validation-for="NewLine.SerialRangeEnd" class="text-danger small"></span>
                                </div>
                            }

                            <div class="col-md-6" data-stock-tracking-field="expiration">
                                <label asp-for="NewLine.ExpirationDate" class="form-label"></label>
                                <input asp-for="NewLine.ExpirationDate" class="form-control" />
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-lg me-1"></i>Ajouter la ligne
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@* Tableau des lignes *@
<div class="card mt-3">
    <div class="section-header">
        <i class="bi bi-list-ul"></i>
        <span>Contenu du document</span>
        <span class="ms-auto small text-muted">@Model.Lines.Count ligne(s)</span>
    </div>
    @if (Model.Lines.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox empty-icon"></i>
            <h6>Aucune ligne dans ce document</h6>
            <p>Utilise le formulaire ci-dessus pour ajouter ton premier article.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Article</th>
                        <th>Description</th>
                        <th class="text-end">Qte</th>
                        <th class="text-end">Cout</th>
                        <th>Lot / Serie</th>
                        <th>Peremption</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Lines)
                    {
                        <tr>
                            <td><strong>@line.ProductCode</strong></td>
                            <td>@line.Description</td>
                            <td class="text-end money">@DisplayFormatter.Quantity(line.Quantity)</td>
                            <td class="text-end money">@DisplayFormatter.Money(line.UnitCost)</td>
                            <td>@(line.LotNumber ?? line.SerialNumber ?? "—")</td>
                            <td class="small">@(line.ExpirationDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td class="text-end">
                                @if (!Model.IsPosted)
                                {
                                    <form method="post" asp-page-handler="DeleteLine" asp-route-id="@Model.Id" class="d-inline">
                                        <input type="hidden" name="lineId" value="@line.Id" />
                                        <button type="submit" class="btn btn-sm btn-secondary"
                                                aria-label="Supprimer la ligne @line.ProductCode"
                                                onclick="return confirm('Supprimer cette ligne ?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script id="stock-document-line-tracking-data" type="application/json">@Html.Raw(Model.ProductTrackingMetadataJson)</script>
    <partial name="_ValidationScriptsPartial" />
}
