@page
@using GescomSaas.Domain.Enums
@using System.Globalization
@model IndexModel
@{
    ViewData["Title"] = "Tableau de bord";
    var d = Model.Dashboard;
    var fr = CultureInfo.GetCultureInfo("fr-FR");

    string Money(decimal v) => v.ToString("N0", fr) + " FCFA";
    string MoneyShort(decimal v)
    {
        if (Math.Abs(v) >= 1_000_000) return (v / 1_000_000m).ToString("N1", fr) + " M";
        if (Math.Abs(v) >= 1_000)     return (v / 1_000m).ToString("N0", fr) + " k";
        return v.ToString("N0", fr);
    }
    string Date(DateOnly date) => date.ToString("dd/MM/yyyy", fr);

    (string label, string css) MapStatus(CommercialDocumentStatus s) => s switch
    {
        CommercialDocumentStatus.Draft               => ("Brouillon",   "lc-badge--gray"),
        CommercialDocumentStatus.Open                => ("Validé",      "lc-badge--primary"),
        CommercialDocumentStatus.PartiallyProcessed  => ("Partiel",     "lc-badge--info"),
        CommercialDocumentStatus.Completed           => ("Terminé",     "lc-badge--success"),
        CommercialDocumentStatus.Cancelled           => ("Annulé",      "lc-badge--error"),
        _                                            => (s.ToString(),  "lc-badge--gray")
    };

    string DocTypeLabel(CommercialDocumentType t) => t switch
    {
        CommercialDocumentType.SalesQuote          => "Devis",
        CommercialDocumentType.SalesOrder          => "Commande",
        CommercialDocumentType.DeliveryNote        => "Bon livraison",
        CommercialDocumentType.SalesInvoice        => "Facture",
        CommercialDocumentType.SalesCreditNote     => "Avoir",
        CommercialDocumentType.PurchaseRequest     => "Demande achat",
        CommercialDocumentType.PurchaseOrder       => "Cmde achat",
        CommercialDocumentType.GoodsReceipt        => "Réception",
        CommercialDocumentType.PurchaseInvoice     => "Facture achat",
        CommercialDocumentType.SupplierCreditNote  => "Avoir fourn.",
        _                                          => t.ToString()
    };
}

<div class="lc-page-header">
    <div>
        <h1 class="lc-page-title">Tableau de bord</h1>
        <p class="lc-page-sub">@d.TenantName · Plan @d.PlanName · @d.ReportingPeriodLabel</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-secondary" asp-page="/Finance/RegisterPayment">
            <i data-lucide="banknote" style="width:14px;height:14px"></i>Saisir un règlement
        </a>
        <a class="btn btn-primary" asp-page="/SalesDocuments/Create" asp-route-type="@CommercialDocumentType.SalesQuote">
            <i data-lucide="plus" style="width:14px;height:14px"></i>Nouveau devis
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
{
    <div class="lc-data-freshness" style="background:var(--color-error-50);border-color:var(--color-error-100);color:var(--color-error-700)">
        <i data-lucide="alert-circle" style="width:16px;height:16px"></i>
        <span><strong>Connexion SQL indisponible.</strong> @Model.LoadErrorMessage</span>
    </div>
}

@* ============================== 4 STAT CARDS ============================== *@
<div class="row g-3 mb-3">
    <div class="col-md-6 col-xl-3">
        <div class="lc-stat">
            <div style="flex:1; min-width:0">
                <div class="lc-stat__label">CA du mois</div>
                <div class="lc-stat__value">@MoneyShort(d.Sales.RevenueThisMonth)<span style="font:var(--font-text-md);color:var(--text-tertiary);font-weight:500;margin-left:2px"> FCFA</span></div>
                <div class="lc-stat__delta">@d.Sales.InvoiceCountThisMonth facture(s) émise(s) ce mois</div>
            </div>
            <svg class="lc-stat__spark" viewBox="0 0 90 36" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <polyline points="0,28 12,24 24,20 36,18 48,12 60,14 72,8 90,4" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
                <polyline points="0,28 12,24 24,20 36,18 48,12 60,14 72,8 90,4 90,36 0,36" fill="currentColor" opacity=".1"/>
            </svg>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="lc-stat">
            <div style="flex:1; min-width:0">
                <div class="lc-stat__label">Encours clients</div>
                <div class="lc-stat__value">@MoneyShort(d.Finance.ReceivableBalance)<span style="font:var(--font-text-md);color:var(--text-tertiary);font-weight:500;margin-left:2px"> FCFA</span></div>
                @if (d.Finance.OverdueReceivableCount > 0)
                {
                    <div class="lc-stat__delta lc-stat__delta--down">@d.Finance.OverdueReceivableCount en retard · @Money(d.Finance.OverdueReceivableBalance)</div>
                }
                else
                {
                    <div class="lc-stat__delta">@d.Finance.ReceivableCount facture(s) ouverte(s)</div>
                }
            </div>
            <svg class="lc-stat__spark @(d.Finance.OverdueReceivableCount > 0 ? "lc-stat__spark--down" : "")" viewBox="0 0 90 36" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <polyline points="0,18 12,16 24,20 36,14 48,22 60,18 72,26 90,30" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
            </svg>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="lc-stat">
            <div style="flex:1; min-width:0">
                <div class="lc-stat__label">Devis ouverts</div>
                <div class="lc-stat__value">@d.Sales.OpenQuoteCount<span style="font:var(--font-text-md);color:var(--text-tertiary);font-weight:500;margin-left:2px"> document(s)</span></div>
                <div class="lc-stat__delta">@d.Sales.OpenOrderCount commande(s) en cours</div>
            </div>
            <svg class="lc-stat__spark" viewBox="0 0 90 36" fill="none" preserveAspectRatio="none" aria-hidden="true" style="color:var(--color-info-600)">
                <polyline points="0,20 15,18 30,22 45,16 60,18 75,12 90,14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
            </svg>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="lc-stat">
            <div style="flex:1; min-width:0">
                <div class="lc-stat__label">Valeur du stock</div>
                <div class="lc-stat__value">@MoneyShort(d.Stock.TotalStockValue)<span style="font:var(--font-text-md);color:var(--text-tertiary);font-weight:500;margin-left:2px"> FCFA</span></div>
                <div class="lc-stat__delta">@d.Stock.TrackedProductCount article(s) suivi(s)@(d.Stock.WatchItemCount > 0 ? " · " + d.Stock.WatchItemCount + " sous seuil" : "")</div>
            </div>
            <svg class="lc-stat__spark lc-stat__spark--up" viewBox="0 0 90 36" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <polyline points="0,24 12,22 24,18 36,20 48,14 60,12 72,10 90,8" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
            </svg>
        </div>
    </div>
</div>

@* ============================== 2 CHARTS CÔTE À CÔTE ============================== *@
<div class="row g-3 mb-3">
    <div class="col-lg-7">
        <div class="lc-card lc-chart-card">
            <div class="lc-chart-card__header">
                <span class="lc-chart-card__title">Évolution du CA · 12 derniers mois</span>
                <a class="btn btn-tertiary btn-sm" asp-page="/SalesDocuments/Index" asp-route-type="@CommercialDocumentType.SalesInvoice">Détails</a>
            </div>
            @{
                // Mensualités factices pour le visuel ; à remplacer par d.Sales.RevenueByMonth si exposé.
                var bars = new[] { 30, 42, 55, 48, 62, 58, 71, 65, 74, 69, 78, 85 };
                var months = new[] { "Mai", "Juin", "Juil", "Août", "Sept", "Oct", "Nov", "Déc", "Jan", "Fév", "Mars", "Avril" };
            }
            <div class="lc-chart-bars" role="img" aria-label="Évolution du chiffre d'affaires sur 12 mois">
                @for (int i = 0; i < bars.Length; i++)
                {
                    var cls = (i % 4 == 3) ? "lc-chart-bar lc-chart-bar--secondary" : "lc-chart-bar";
                    <div class="@cls" style="height:@(bars[i])%" data-tip="@months[i]"></div>
                }
            </div>
            <div class="lc-chart-x">
                @foreach (var m in months) { <span>@m</span> }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="lc-card">
            <div class="lc-chart-card__header">
                <span class="lc-chart-card__title">Quotas du plan</span>
                <a class="btn btn-tertiary btn-sm" asp-page="/Settings/Index">Gérer</a>
            </div>
            <div class="lc-hbar-list">
                @if (d.Quotas.Count == 0)
                {
                    <div class="empty-state" style="padding:24px;text-align:center;color:var(--text-tertiary)">Aucun quota configuré pour ce plan.</div>
                }
                else
                {
                    foreach (var q in d.Quotas)
                    {
                        var pct = q.Limit > 0 ? Math.Min(100, (q.Used * 100) / q.Limit) : 0;
                        var fillStyle = q.IsExceeded ? "background:var(--color-error-600)" : (pct > 80 ? "background:var(--color-warning-600)" : "");
                        <div class="lc-hbar">
                            <span class="lc-hbar__name">@q.Label</span>
                            <div class="lc-hbar__bar"><div class="lc-hbar__fill" style="width:@pct%;@fillStyle"></div></div>
                            <span class="lc-hbar__value">@q.Used / @q.Limit</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@* ============================== TABLE RÉCENTS + ACTIVITÉ ============================== *@
<div class="row g-3">
    <div class="col-lg-8">
        <div class="lc-table-card">
            <div class="lc-table-toolbar">
                <span class="lc-table-toolbar__title">Documents récents</span>
                <span class="lc-table-toolbar__count">@d.RecentDocuments.Count</span>
                <a class="btn btn-tertiary btn-sm ms-auto" asp-page="/SalesDocuments/Index" asp-route-type="@CommercialDocumentType.SalesInvoice">
                    Voir tous <i data-lucide="arrow-right" style="width:14px;height:14px"></i>
                </a>
            </div>
            @if (d.RecentDocuments.Count == 0)
            {
                <div style="padding:48px 24px;text-align:center;color:var(--text-tertiary)">
                    <i data-lucide="inbox" style="width:32px;height:32px;color:var(--text-quaternary);margin-bottom:8px"></i>
                    <p style="margin:0">Aucun document récent. Crée ta première facture pour démarrer.</p>
                </div>
            }
            else
            {
                <table class="lc-table">
                    <thead>
                        <tr>
                            <th>Numéro</th>
                            <th>Type</th>
                            <th>Tiers</th>
                            <th>Date</th>
                            <th>Statut</th>
                            <th class="text-end">Montant TTC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in d.RecentDocuments.Take(10))
                        {
                            var (label, badgeCss) = MapStatus(doc.Status);
                            <tr>
                                <td data-label="Numéro"><strong>@doc.Number</strong></td>
                                <td data-label="Type">@DocTypeLabel(doc.DocumentType)</td>
                                <td data-label="Tiers">@doc.PartnerName</td>
                                <td data-label="Date">@Date(doc.DocumentDate)</td>
                                <td data-label="Statut"><span class="lc-badge @badgeCss"><span class="dot"></span>@label</span></td>
                                <td data-label="Montant" class="text-end num--strong">@Money(doc.TotalIncludingTax)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
    <div class="col-lg-4">
        <div class="lc-card">
            <div class="lc-card__header"><h3 class="lc-card__title">À traiter</h3></div>
            <div class="lc-timeline">
                @if (d.Sales.OverdueReceivableCount > 0)
                {
                    <div class="lc-tl-item">
                        <span class="lc-tl-item__dot" style="background:var(--color-error-600)"></span>
                        <div class="lc-tl-item__body">
                            <div class="lc-tl-item__title"><strong>@d.Sales.OverdueReceivableCount facture(s) client en retard</strong></div>
                            <div class="lc-tl-item__time">@Money(d.Sales.OverdueReceivables) à recouvrer</div>
                            <a class="btn btn-link btn-sm mt-1" asp-page="/Finance/Reminders">Gérer les relances <i data-lucide="arrow-right" style="width:12px;height:12px"></i></a>
                        </div>
                    </div>
                }
                @if (d.Finance.OverduePayableCount > 0)
                {
                    <div class="lc-tl-item">
                        <span class="lc-tl-item__dot" style="background:var(--color-warning-600)"></span>
                        <div class="lc-tl-item__body">
                            <div class="lc-tl-item__title"><strong>@d.Finance.OverduePayableCount échéance(s) fournisseur</strong></div>
                            <div class="lc-tl-item__time">@Money(d.Finance.OverduePayableBalance) à régler</div>
                            <a class="btn btn-link btn-sm mt-1" asp-page="/Finance/OpenItems">Voir l'échéancier <i data-lucide="arrow-right" style="width:12px;height:12px"></i></a>
                        </div>
                    </div>
                }
                @if (d.Stock.WatchItemCount > 0)
                {
                    <div class="lc-tl-item">
                        <span class="lc-tl-item__dot" style="background:var(--color-warning-600)"></span>
                        <div class="lc-tl-item__body">
                            <div class="lc-tl-item__title"><strong>@d.Stock.WatchItemCount article(s) sous seuil</strong></div>
                            <div class="lc-tl-item__time">À réapprovisionner</div>
                            <a class="btn btn-link btn-sm mt-1" asp-page="/Inventory/Index">Voir l'inventaire <i data-lucide="arrow-right" style="width:12px;height:12px"></i></a>
                        </div>
                    </div>
                }
                @if (d.Sales.OpenQuoteCount > 0)
                {
                    <div class="lc-tl-item">
                        <span class="lc-tl-item__dot" style="background:var(--color-info-600)"></span>
                        <div class="lc-tl-item__body">
                            <div class="lc-tl-item__title">@d.Sales.OpenQuoteCount devis ouvert(s)</div>
                            <div class="lc-tl-item__time">À convertir en commande</div>
                            <a class="btn btn-link btn-sm mt-1" asp-page="/SalesDocuments/Index" asp-route-type="@CommercialDocumentType.SalesQuote">Voir les devis <i data-lucide="arrow-right" style="width:12px;height:12px"></i></a>
                        </div>
                    </div>
                }
                @if (d.Sales.OverdueReceivableCount == 0 && d.Finance.OverduePayableCount == 0 && d.Stock.WatchItemCount == 0 && d.Sales.OpenQuoteCount == 0)
                {
                    <div style="padding:32px 16px;text-align:center;color:var(--text-tertiary)">
                        <i data-lucide="check-circle-2" style="width:32px;height:32px;color:var(--color-success-600);margin-bottom:8px"></i>
                        <p style="margin:0;font-weight:600;color:var(--text-primary)">Tout est à jour !</p>
                        <p style="margin:0;font:var(--font-text-xs)">Aucune action en attente.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
