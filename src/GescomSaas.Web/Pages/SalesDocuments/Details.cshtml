@page "{id:guid}"
@model GescomSaas.Web.Pages.SalesDocuments.DetailsModel
@{
    ViewData["Title"] = "Detail de la piece";
    var docLabel = GescomSaas.Web.Pages.SalesDocuments.SalesDocumentCatalog.Label(Model.Document!.DocumentType);
    var targets = GescomSaas.Web.Pages.SalesDocuments.SalesDocumentCatalog.GetTargets(Model.Document.DocumentType);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">@docLabel @Model.Document.Number</h1>
        <div class="page-header-sub">
            <span class="badge doc-status-@Model.Document.Status.ToString().ToLowerInvariant()">@Model.Document.Status</span>
            <span class="ms-2">· @Model.Document.PartnerName</span>
            <span class="ms-2">· @Model.Document.DocumentDate.ToString("dd/MM/yyyy")</span>
        </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-secondary" asp-page="/SalesDocuments/Details" asp-route-id="@Model.Document.Id" asp-page-handler="Pdf">
            <i class="bi bi-download me-1"></i>Telecharger PDF
        </a>
        <a class="btn btn-secondary" asp-page="/SalesDocuments/Edit" asp-route-id="@Model.Document.Id">
            <i class="bi bi-pencil me-1"></i>Modifier
        </a>
        <a class="btn btn-secondary" asp-page="/SalesDocuments/Index" asp-route-type="@Model.Document.DocumentType">
            <i class="bi bi-arrow-left me-1"></i>Retour a la liste
        </a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage
    </div>
}

@* KPI tiles : Total HT / Taxe / TTC *@
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-card-icon stat-icon-blue"><i class="bi bi-calculator"></i></div>
            <div class="stat-card-body">
                <div class="stat-card-label">Total HT</div>
                <div class="stat-card-value money">@DisplayFormatter.Money(Model.Document.TotalExcludingTax, Model.Document.CurrencyCode)</div>
                <div class="form-text mb-0">base avant taxes et remises</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-card-icon stat-icon-amber"><i class="bi bi-percent"></i></div>
            <div class="stat-card-body">
                <div class="stat-card-label">Taxe</div>
                <div class="stat-card-value money">@DisplayFormatter.Money(Model.Document.TotalTax, Model.Document.CurrencyCode)</div>
                <div class="form-text mb-0">montant fiscal cumule</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-card-icon stat-icon-emerald"><i class="bi bi-cash-stack"></i></div>
            <div class="stat-card-body">
                <div class="stat-card-label">Total TTC</div>
                <div class="stat-card-value money fw-bold">@DisplayFormatter.Money(Model.Document.TotalIncludingTax, Model.Document.CurrencyCode)</div>
                <div class="form-text mb-0">lecture finale de la piece</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    @* Informations generales *@
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="section-header">
                <i class="bi bi-info-circle"></i>
                <span>Informations generales</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="small text-muted">Numero</div>
                        <div class="fw-semibold">@Model.Document.Number</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Type</div>
                        <div class="fw-semibold">@docLabel</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Statut</div>
                        <div><span class="badge doc-status-@Model.Document.Status.ToString().ToLowerInvariant()">@Model.Document.Status</span></div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Date</div>
                        <div class="fw-semibold">@Model.Document.DocumentDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Echeance</div>
                        <div class="fw-semibold">@(Model.Document.DueDate?.ToString("dd/MM/yyyy") ?? "—")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Client</div>
                        <div class="fw-semibold">@Model.Document.PartnerName</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Depot</div>
                        <div class="fw-semibold">@(Model.Document.WarehouseLabel ?? "—")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-muted">Source</div>
                        <div class="fw-semibold">@(Model.Document.SourceNumber ?? "—")</div>
                    </div>
                    <div class="col-12">
                        <div class="small text-muted">Notes</div>
                        <div>@(string.IsNullOrWhiteSpace(Model.Document.Notes) ? "—" : Model.Document.Notes)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Transformations disponibles *@
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="section-header">
                <i class="bi bi-arrow-right-circle"></i>
                <span>Actions disponibles</span>
            </div>
            <div class="card-body">
                @if (targets.Count == 0
                    && !(Model.Document.DocumentType == GescomSaas.Domain.Enums.CommercialDocumentType.DeliveryNote
                        && Model.Document.Status != GescomSaas.Domain.Enums.CommercialDocumentStatus.Completed))
                {
                    <div class="empty-state py-3">
                        <i class="bi bi-check-circle-fill empty-icon"></i>
                        <h6>Cycle complet</h6>
                        <p class="mb-0">Cette piece est deja au bout de son cycle.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @if (Model.Document.DocumentType == GescomSaas.Domain.Enums.CommercialDocumentType.DeliveryNote
                            && Model.Document.Status != GescomSaas.Domain.Enums.CommercialDocumentStatus.Completed)
                        {
                            <form method="post" asp-page-handler="PostStock" asp-route-id="@Model.Document.Id">
                                <button type="submit" class="btn btn-primary w-100"
                                        onclick="return confirm('Valider la sortie de stock ?')">
                                    <i class="bi bi-box-arrow-up me-1"></i>Valider la sortie de stock
                                </button>
                            </form>
                        }
                        @foreach (var target in targets)
                        {
                            <form method="post" asp-page-handler="Transform" asp-route-id="@Model.Document.Id">
                                <input type="hidden" name="targetType" value="@target" />
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-arrow-right me-1"></i>Creer @GescomSaas.Web.Pages.SalesDocuments.SalesDocumentCatalog.Label(target)
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* Tableau des lignes *@
<div class="card">
    <div class="section-header">
        <i class="bi bi-list-ul"></i>
        <span>Contenu de la piece</span>
        <span class="ms-auto small text-muted">@Model.Document.Lines.Count ligne(s)</span>
    </div>
    @if (Model.Document.Lines.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox empty-icon"></i>
            <p class="mb-0">Aucune ligne dans cette piece.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Article</th>
                        <th>Description</th>
                        <th class="text-end">Qte</th>
                        <th class="text-end">PU HT</th>
                        <th class="text-end">Remise</th>
                        <th class="text-end">Taxe</th>
                        <th>Lot / Serie</th>
                        <th class="text-end">TTC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Document.Lines)
                    {
                        <tr>
                            <td><strong>@line.ProductCode</strong></td>
                            <td>@line.Description</td>
                            <td class="text-end money">@DisplayFormatter.Quantity(line.Quantity)</td>
                            <td class="text-end money">@DisplayFormatter.Money(line.UnitPriceExcludingTax, Model.Document.CurrencyCode)</td>
                            <td class="text-end money">@DisplayFormatter.Number(line.DiscountRate, 2) %</td>
                            <td class="text-end money">@DisplayFormatter.Number(line.TaxRate, 2) %</td>
                            <td>@(line.LotNumber ?? line.SerialNumber ?? "—")</td>
                            <td class="text-end money fw-semibold">@DisplayFormatter.Money(line.TotalIncludingTax, Model.Document.CurrencyCode)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
