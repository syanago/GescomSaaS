@page "{id:guid}"
@model GescomSaas.Web.Pages.SalesDocuments.DeleteModel
@{
    ViewData["Title"] = "Supprimer une piece commerciale";
    var canDelete = string.IsNullOrWhiteSpace(Model.BlockingReason);
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Supprimer @Model.Document?.Number</h1>
        <div class="page-header-sub">Suppression d'une piece commerciale</div>
    </div>
    <div>
        <a class="btn btn-secondary" asp-page="/SalesDocuments/Index" asp-route-type="@Model.Document?.DocumentType">
            <i class="bi bi-arrow-left me-1"></i>Retour a la liste
        </a>
    </div>
</div>

@if (!canDelete)
{
    <div class="alert alert-warning mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Suppression bloquee</strong> — @Model.BlockingReason
    </div>
}
else
{
    <div class="alert alert-danger mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Attention</strong> — la piece <strong>@Model.Document?.Number</strong> sera supprimee, ainsi que ses lignes et mouvements eventuels lies a son numero.
    </div>
}

<div class="card">
    <div class="section-header">
        <i class="bi bi-trash"></i>
        <span>Recapitulatif</span>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="small text-muted">Numero</div>
                <div class="fw-semibold">@Model.Document?.Number</div>
            </div>
            <div class="col-md-4">
                <div class="small text-muted">Type</div>
                <div class="fw-semibold">@Model.Document?.DocumentType</div>
            </div>
            <div class="col-md-4">
                <div class="small text-muted">Statut</div>
                <div><span class="badge doc-status-@(Model.Document?.Status.ToString().ToLowerInvariant())">@Model.Document?.Status</span></div>
            </div>
            <div class="col-12">
                <div class="small text-muted">Montant TTC</div>
                <div class="fw-bold money fs-5">@DisplayFormatter.Money(Model.Document?.TotalIncludingTax ?? 0m, Model.Document?.CurrencyCode)</div>
            </div>
        </div>

        <form method="post" class="d-flex justify-content-end gap-2">
            <a class="btn btn-secondary" asp-page="/SalesDocuments/Index" asp-route-type="@Model.Document?.DocumentType">Annuler</a>
            @if (canDelete)
            {
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>Confirmer la suppression
                </button>
            }
        </form>
    </div>
</div>
