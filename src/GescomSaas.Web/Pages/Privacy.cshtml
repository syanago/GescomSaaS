@page
@model PrivacyModel
@{
    ViewData["Title"] = "Confidentialite";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Confidentialite et isolation des tenants</h1>
        <div class="page-header-sub">Conformite et separation des comptes SaaS</div>
    </div>
</div>

<div class="card">
    <div class="section-header">
        <i class="bi bi-shield-lock"></i>
        <span>Politique de confidentialite</span>
    </div>
    <div class="card-body">
        <p class="mb-0">
            Cette base pose deja une separation des comptes SaaS par tenant, mais la securisation
            complete d'une plateforme en production demandera encore l'ajout de politiques d'autorisation
            fines, de journalisation d'audit, de sauvegardes, de chiffrement des secrets et d'un volet
            RGPD plus detaille.
        </p>
    </div>
</div>
