@page
@model PrivacyModel
@{
    ViewData["Title"] = "Confidentialite";
}

<section class="plain-panel">
    <span class="eyebrow">Conformite</span>
    <h1>Confidentialite et isolation des tenants</h1>
    <p>
        Cette base pose deja une separation des comptes SaaS par tenant, mais la securisation complete
        d'une plateforme en production demandera encore l'ajout de politiques d'autorisation fines,
        de journalisation d'audit, de sauvegardes, de chiffrement des secrets et d'un volet RGPD plus detaille.
    </p>
</section>
