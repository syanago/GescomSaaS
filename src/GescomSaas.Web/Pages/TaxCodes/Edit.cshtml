@page "{id:guid}"
@model GescomSaas.Web.Pages.TaxCodes.EditModel
@{
    ViewData["Title"] = "Modifier un code taxe";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Modifier un code taxe</h1>
        <div class="page-header-sub">Edition d'un code taxe</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-secondary" asp-page="/TaxCodes/Index"><i class="bi bi-arrow-left me-1"></i>Retour</a>
    </div>
</div>

<div class="card">
    <div class="section-header">
        <i class="bi bi-percent"></i>
        <span>Informations</span>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.Code" class="form-label"></label>
                    <input asp-for="Input.Code" class="form-control" />
                    <span asp-validation-for="Input.Code" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Label" class="form-label"></label>
                    <input asp-for="Input.Label" class="form-control" />
                    <span asp-validation-for="Input.Label" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Rate" class="form-label"></label>
                    <input asp-for="Input.Rate" class="form-control" />
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2 mt-3">
                <a class="btn btn-secondary" asp-page="/TaxCodes/Index">Annuler</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Enregistrer</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
