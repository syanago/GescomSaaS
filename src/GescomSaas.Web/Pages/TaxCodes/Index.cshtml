@page
@model GescomSaas.Web.Pages.TaxCodes.IndexModel
@{
    ViewData["Title"] = "Taxes";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Taxes</h1>
        <div class="page-header-sub">Definissez les codes et taux applicables aux articles et documents.</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-page="/TaxCodes/Create"><i class="bi bi-plus-lg me-1"></i>Nouveau code taxe</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage
    </div>
}

<div class="card">
    <div class="section-header">
        <i class="bi bi-percent"></i>
        <span>Codes taxes</span>
        <span class="ms-auto small text-muted">@Model.TaxCodes.Count resultat(s)</span>
    </div>
    @if (Model.TaxCodes.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-inbox empty-icon"></i>
            <h6>Aucun code taxe</h6>
            <p>Creez un premier code taxe pour pouvoir l'appliquer aux articles et documents.</p>
            <a class="btn btn-primary btn-sm" asp-page="/TaxCodes/Create"><i class="bi bi-plus-lg me-1"></i>Nouveau code taxe</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Libelle</th>
                        <th class="text-end money">Taux</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.TaxCodes)
                    {
                        <tr>
                            <td><strong>@item.Code</strong></td>
                            <td>@item.Label</td>
                            <td class="text-end money">@DisplayFormatter.Number(item.Rate, 2) %</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-1">
                                    <a class="btn btn-sm btn-secondary" asp-page="/TaxCodes/Edit" asp-route-id="@item.Id" title="Modifier"><i class="bi bi-pencil"></i></a>
                                    <a class="btn btn-sm btn-secondary text-danger" asp-page="/TaxCodes/Delete" asp-route-id="@item.Id" title="Supprimer"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
